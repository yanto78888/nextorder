<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    .price-row-price, .value, .mono { color: var(--cyan) !important; }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'harga', user, config }) %>

  <div class="main no-bottom-nav">
    <div class="topbar" style="margin-bottom: 12px;">
      <h2 style="margin:0; font-size:20px;"><i class="fa-solid fa-tags"></i> Daftar Harga Layanan</h2>
    </div>

    <div class="card price-hero-card">
      <div class="stat-card">
        <div class="label">Produk Aktif</div>
        <div class="value"><%= totalProducts %></div>
      </div>
      <div style="font-size:12px; color:var(--text-dim); max-width:320px; text-align:right;">
        Semua harga di bawah ini <b style="color:var(--text-main);">transparan &amp; berlaku untuk semua orang</b>, tidak perlu login untuk melihatnya.
        <% if (memberDiscount > 0) { %>
          Harga yang ditampilkan sudah termasuk potongan member <b style="color:var(--cyan);"><%= memberDiscount %>%</b> punyamu.
        <% } else if (!user) { %>
          <a href="/register" style="color:var(--cyan);">Daftar akun</a> untuk kesempatan dapat diskon member.
        <% } %>
      </div>
    </div>

    <div class="catalog-search-bar">
      <input type="text" id="hargaSearchInput" placeholder="Cari nama produk atau layanan...">
      <button type="button" class="catalog-search-btn" id="hargaSearchBtn" aria-label="Cari produk"><i class="fa-solid fa-magnifying-glass"></i></button>
    </div>
    <div id="hargaSearchEmpty" class="card empty-state" style="display:none;">Produk "<span id="hargaSearchEmptyTerm"></span>" tidak ditemukan.</div>

    <% if (groups.length > 1) { %>
    <div class="price-list-jump">
      <% groups.forEach(g => { %>
        <a href="#cat-<%= g.category.replace(/[^a-zA-Z0-9]/g,'-') %>"><%= g.category %></a>
      <% }) %>
    </div>
    <% } %>

    <% if (groups.length === 0) { %>
      <div class="card empty-state">Belum ada produk tersedia saat ini.</div>
    <% } else { %>
      <% groups.forEach(g => { %>
        <div class="price-list-group" data-price-group data-category="<%= g.category %>" id="cat-<%= g.category.replace(/[^a-zA-Z0-9]/g,'-') %>">
          <div class="section-title"><h3><i class="fa-solid fa-gamepad"></i> <%= g.category %></h3><div class="line"></div></div>
          <div class="price-row-list">
            <% g.products.forEach(p => { %>
              <a href="/produk/<%= p.id %>" class="price-row" data-name="<%= p.name.toLowerCase() %>">
                <div class="price-row-info">
                  <div class="price-row-name"><%= p.name %></div>
                  <% const isAuto = p.provider === 'digiflazz'; const stockCount = p.stockItems ? p.stockItems.length : 0; %>
                  <div class="price-row-meta"><%= isAuto ? 'Pengiriman instan otomatis' : (stockCount > 0 ? stockCount + ' stok tersedia' : 'Stok manual diproses admin') %></div>
                </div>
                <div class="price-row-price-wrap">
                  <% if (p.finalPrice < p.price) { %><span class="price-row-price-old">Rp <%= p.price.toLocaleString('id-ID') %></span><% } %>
                  <span class="price-row-price">Rp <%= p.finalPrice.toLocaleString('id-ID') %></span>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } %>

    <%- include('partials/footer') %>
  </div>
</div>
</body>
</html>

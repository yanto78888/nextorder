<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'digiflazz' }) %>

  <div class="main no-bottom-nav">
    
    <div class="admin-header-modern">
      <h2><i class="fa-solid fa-bolt" style="color: var(--primary-color);"></i> Produk Digiflazz</h2>
    </div>

    <% if (success) { %><div class="alert success"><i class="fa-solid fa-circle-check"></i> <%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div><% } %>

    <% const df = config.digiflazz || {}; %>
    <% if (!df.enabled || !df.username || !df.apiKey) { %>
      <div class="alert error" style="display: flex; gap: 10px; align-items: center;">
        <i class="fa-solid fa-circle-xmark" style="font-size: 24px;"></i>
        <div>
          <strong>Digiflazz belum aktif/lengkap.</strong><br> 
          Isi Username &amp; API Key lalu centang "Aktifkan" di <a href="/admin/settings" style="color:#fff; text-decoration:underline; font-weight: bold;">Pengaturan</a> terlebih dahulu sebelum mengimpor produk.
        </div>
      </div>
    <% } %>

    <div class="grid grid-2">
      <!-- Pengaturan Margin -->
      <div class="card card-modern">
        <h3 class="card-title-modern"><i class="fa-solid fa-percent"></i> Margin Default</h3>
        <p class="helper-text-modern">Margin ini otomatis dipakai untuk semua produk Digiflazz yang tidak memiliki margin khusus (override).<br><em>Rumus: Harga Jual = Harga Modal + Margin (dibulatkan ke atas kelipatan Rp100).</em></p>
        <form method="POST" action="/admin/digiflazz/margin" class="mt-16">
          <div class="grid grid-2 form-mini-grid">
            <div class="form-group-modern">
              <label>Tipe Margin</label>
              <select name="marginType" class="input-modern">
                <option value="percent" <%= (df.marginType || 'percent') === 'percent' ? 'selected' : '' %>>Persentase (%)</option>
                <option value="fixed" <%= df.marginType === 'fixed' ? 'selected' : '' %>>Nominal Tetap (Rp)</option>
              </select>
            </div>
            <div class="form-group-modern">
              <label>Nilai Margin</label>
              <input type="number" step="0.01" name="marginValue" class="input-modern" value="<%= (typeof df.marginValue !== 'undefined' && df.marginValue !== null) ? df.marginValue : 10 %>">
            </div>
          </div>
          <button class="btn-modern solid mt-16" type="submit" style="width: 100%;"><i class="fa-solid fa-floppy-disk"></i> Simpan Margin</button>
        </form>
      </div>

      <!-- Ringkasan & Sinkronisasi -->
      <div class="card card-modern">
        <h3 class="card-title-modern"><i class="fa-solid fa-chart-pie"></i> Ringkasan</h3>
        <div class="stat-box-modern">
          <div class="stat-value"><%= digiflazzProducts.length %></div>
          <div class="stat-label">Total Produk Terhubung</div>
        </div>
        <form method="POST" action="/admin/digiflazz/sync-all" class="mt-16">
          <button class="btn-modern outline" type="submit" style="width:100%;">
            <i class="fa-solid fa-rotate"></i> Sinkron Semua Harga Modal
          </button>
        </form>
        <div class="helper-text-modern mt-16" style="font-size: 12px;">
          Sinkronisasi akan mengambil harga modal terbaru dari Digiflazz untuk semua produk yang sudah diimport, lalu menghitung ulang harga jual berdasarkan margin masing-masing.
        </div>
      </div>
    </div>

    <!-- Area Pencarian & Import -->
    <div class="card card-modern mt-24">
      <h3 class="card-title-modern"><i class="fa-solid fa-cloud-arrow-down"></i> Cari &amp; Import Produk</h3>
      <p class="helper-text-modern" style="margin-bottom: 20px;">
        Pilih Kategori &rarr; Brand/Judul &rarr; Tipe agar hasil lebih fokus, atau langsung ketik nama/SKU produk. 
        Centang hasil yang ingin ditambahkan. Nama produk dapat diedit sebelum menekan tombol import.
      </p>

      <div class="df-toolbar-modern">
        <select id="dfCategorySelect" class="input-modern"><option value="">Semua Kategori</option></select>
        <select id="dfBrandSelect" class="input-modern" disabled><option value="">Semua Brand/Judul</option></select>
        <select id="dfTypeSelect" class="input-modern" style="display:none;"><option value="">Semua Tipe</option></select>
        <div class="search-input-wrapper">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="dfSearchInput" class="input-modern" placeholder="Ketik nama produk atau SKU...">
        </div>
        <button type="button" class="btn-modern solid" id="dfSearchBtn">Cari</button>
      </div>

      <div id="dfBulkBar" class="df-bulk-bar-modern" style="display:none;">
        <label class="df-select-all-modern">
          <input type="checkbox" id="dfSelectAllChk"> <span>Pilih semua di halaman ini</span>
        </label>
        <span id="dfSelectedCount" class="badge-modern neutral">0 dipilih</span>
        <button type="button" class="btn-modern primary small" id="dfAddSelectedBtn" disabled>
          <i class="fa-solid fa-plus"></i> Import Terpilih
        </button>
      </div>

      <div id="dfSearchResults" class="table-responsive-modern mt-16"></div>
    </div>

    <!-- Daftar Produk Terhubung -->
    <div class="card card-modern mt-24">
      <div class="flex-between-modern">
        <h3 class="card-title-modern mb-0"><i class="fa-solid fa-link"></i> Produk Terhubung (<%= digiflazzProducts.length %>)</h3>
        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
          <!-- Tombol Bulk Unlink -->
          <button type="button" id="btnBulkUnlink" class="btn-modern danger small" style="display:none;" onclick="processBulkUnlink()">
            <i class="fa-solid fa-link-slash"></i> Lepas Terpilih
          </button>
          <a href="/admin/produk" class="btn-modern ghost small"><i class="fa-solid fa-screwdriver-wrench"></i> Kelola Stok Manual</a>
        </div>
      </div>
      <p class="helper-text-modern mt-16">
        Gunakan <i>checkbox</i> di sebelah kiri nama layanan untuk memilih banyak produk sekaligus lalu tekan "Lepas Terpilih". Produk dengan Grup Varian yang sama otomatis dikelompokkan ke dalam satu folder.
      </p>
      
      <% if (digiflazzProducts.length === 0) { %>
        <div class="empty-state-modern mt-24">
          <i class="fa-solid fa-box-open empty-icon"></i>
          <div>Belum ada produk yang diimport dari Digiflazz.</div>
        </div>
      <% } else { %>
        <% const dfCatOrder = []; const dfCatGroups = {}; %>
        <% digiflazzProducts.forEach(p => { const cat = p.category || 'Umum'; if (!dfCatGroups[cat]) { dfCatGroups[cat] = []; dfCatOrder.push(cat); } dfCatGroups[cat].push(p); }) %>
        <% dfCatOrder.sort().forEach(cat => { %>
          <% const catProducts = dfCatGroups[cat]; %>
          <% const folderOrder = []; const folders = {}; const singles = []; %>
          <% catProducts.forEach(p => {
               if (p.variantGroup) {
                 if (!folders[p.variantGroup]) { folders[p.variantGroup] = []; folderOrder.push(p.variantGroup); }
                 folders[p.variantGroup].push(p);
               } else { singles.push(p); }
             }); %>

          <div class="section-divider-modern">
            <h4><%= cat %></h4>
            <span class="badge-modern neutral"><%= catProducts.length %> produk</span>
            <div class="line"></div>
          </div>

          <!-- Folders -->
          <% folderOrder.forEach(groupName => { %>
            <% const groupProducts = folders[groupName]; %>
            <% const thumb = groupThumbnails[groupName] || ''; %>
            <div class="df-group-card-modern" data-df-group>
              <div class="df-group-header-modern" data-df-group-toggle>
                <div class="df-group-thumb-wrapper">
                  <% if (thumb) { %>
                    <img src="<%= thumb %>" alt="<%= groupName %>">
                  <% } else { %>
                    <div class="placeholder"><%= groupName.charAt(0).toUpperCase() %></div>
                  <% } %>
                </div>
                <div class="df-group-info">
                  <div class="name"><%= groupName %></div>
                  <div class="count"><%= groupProducts.length %> pilihan nominal tersedia</div>
                </div>
                <div class="df-group-actions" onclick="event.stopPropagation()">
                  <!-- Upload Gambar Original (Kembali ke standar) -->
                  <form method="POST" action="/admin/digiflazz/group/<%= encodeURIComponent(groupName) %>/thumbnail" enctype="multipart/form-data">
                    <input type="file" name="groupThumbnailFile" accept="image/png,image/jpeg,image/webp,image/gif" id="file-<%= encodeURIComponent(groupName) %>" class="hidden-file-input" onchange="this.form.submit()">
                    <label for="file-<%= encodeURIComponent(groupName) %>" class="btn-modern outline small upload-btn">
                      <i class="fa-solid fa-image"></i> <%= thumb ? 'Ganti Foto' : 'Upload Foto' %>
                    </label>
                  </form>
                </div>
                <i class="fa-solid fa-chevron-down caret"></i>
              </div>

              <div class="df-group-body-modern">
                <div class="table-responsive-modern">
                  <table class="table-modern">
                    <thead>
                      <tr>
                        <th style="width: 30px;"><input type="checkbox" onchange="toggleTableUnlink(this)" title="Pilih Semua di Folder Ini"></th>
                        <th>Nama Layanan</th>
                        <th>SKU</th>
                        <th>Modal</th>
                        <th>Margin</th>
                        <th>Harga Jual</th>
                        <th class="text-right">Aksi</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% groupProducts.slice().sort((a, b) => a.price - b.price).forEach(p => { %>
                      <tr>
                        <td><input type="checkbox" class="df-unlink-chk" value="<%= p.id %>" onchange="updateBulkUnlinkBtn()"></td>
                        <td class="font-medium"><%= p.name %></td>
                        <td><span class="badge-modern sku-badge"><%= p.digiflazzSku %></span></td>
                        <td class="font-mono text-dim">Rp <%= (p.digiflazzBasePrice || 0).toLocaleString('id-ID') %></td>
                        <td>
                          <form method="POST" action="/admin/digiflazz/<%= p.id %>/margin" class="inline-flex-form">
                            <select name="marginType" class="input-modern mini">
                              <option value="" <%= !p.marginType ? 'selected' : '' %>>Def</option>
                              <option value="percent" <%= p.marginType === 'percent' ? 'selected' : '' %>>%</option>
                              <option value="fixed" <%= p.marginType === 'fixed' ? 'selected' : '' %>>Rp</option>
                            </select>
                            <input type="number" step="0.01" name="marginValue" value="<%= p.marginValue !== null ? p.marginValue : '' %>" placeholder="-" class="input-modern mini w-70">
                            <button type="submit" class="btn-modern ghost small box-btn" title="Simpan Margin"><i class="fa-solid fa-check"></i></button>
                          </form>
                        </td>
                        <td class="font-mono text-primary font-bold">Rp <%= p.price.toLocaleString('id-ID') %></td>
                        <td class="text-right">
                          <div class="action-buttons-modern">
                            <form method="POST" action="/admin/digiflazz/<%= p.id %>/resync">
                              <button class="btn-modern ghost small icon-only" type="submit" title="Sync ulang"><i class="fa-solid fa-rotate"></i></button>
                            </form>
                            <a href="/admin/produk/<%= p.id %>/edit" class="btn-modern outline small">Edit</a>
                            <form method="POST" action="/admin/digiflazz/<%= p.id %>/unlink" onsubmit="return confirm('Lepas produk ini dari Digiflazz? Produk akan jadi stok manual biasa.')">
                              <button class="btn-modern danger small icon-only" type="submit" title="Lepas Tautan"><i class="fa-solid fa-link-slash"></i></button>
                            </form>
                          </div>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          <% }) %>

          <!-- Singles (Produk Tanpa Folder) -->
          <% if (singles.length > 0) { %>
            <div class="table-responsive-modern mt-16 mb-24">
              <table class="table-modern">
                <thead>
                  <tr>
                    <th style="width: 30px;"><input type="checkbox" onchange="toggleTableUnlink(this)" title="Pilih Semua"></th>
                    <th>Nama Layanan</th>
                    <th>SKU</th>
                    <th>Modal</th>
                    <th>Margin</th>
                    <th>Harga Jual</th>
                    <th class="text-right">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% singles.slice().sort((a, b) => a.price - b.price).forEach(p => { %>
                  <tr>
                    <td><input type="checkbox" class="df-unlink-chk" value="<%= p.id %>" onchange="updateBulkUnlinkBtn()"></td>
                    <td class="font-medium"><%= p.name %></td>
                    <td><span class="badge-modern sku-badge"><%= p.digiflazzSku %></span></td>
                    <td class="font-mono text-dim">Rp <%= (p.digiflazzBasePrice || 0).toLocaleString('id-ID') %></td>
                    <td>
                      <form method="POST" action="/admin/digiflazz/<%= p.id %>/margin" class="inline-flex-form">
                        <select name="marginType" class="input-modern mini">
                          <option value="" <%= !p.marginType ? 'selected' : '' %>>Def</option>
                          <option value="percent" <%= p.marginType === 'percent' ? 'selected' : '' %>>%</option>
                          <option value="fixed" <%= p.marginType === 'fixed' ? 'selected' : '' %>>Rp</option>
                        </select>
                        <input type="number" step="0.01" name="marginValue" value="<%= p.marginValue !== null ? p.marginValue : '' %>" placeholder="-" class="input-modern mini w-70">
                        <button type="submit" class="btn-modern ghost small box-btn"><i class="fa-solid fa-check"></i></button>
                      </form>
                    </td>
                    <td class="font-mono text-primary font-bold">Rp <%= p.price.toLocaleString('id-ID') %></td>
                    <td class="text-right">
                      <div class="action-buttons-modern">
                        <form method="POST" action="/admin/digiflazz/<%= p.id %>/resync">
                          <button class="btn-modern ghost small icon-only" type="submit" title="Sync ulang"><i class="fa-solid fa-rotate"></i></button>
                        </form>
                        <a href="/admin/produk/<%= p.id %>/edit" class="btn-modern outline small">Edit</a>
                        <form method="POST" action="/admin/digiflazz/<%= p.id %>/unlink" onsubmit="return confirm('Lepas tautan dari Digiflazz?')">
                          <button class="btn-modern danger small icon-only" type="submit"><i class="fa-solid fa-link-slash"></i></button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<style>
  /* ADMIN DIGIFLAZZ MODERN CSS STYLES */
  .admin-header-modern { margin-bottom: 24px; }
  .admin-header-modern h2 { font-size: 24px; font-weight: 800; color: var(--text-dark); display: flex; align-items: center; gap: 12px; margin: 0; }
  
  .card-modern { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: 24px; box-shadow: var(--shadow-sm); }
  .card-title-modern { font-size: 16px; font-weight: 700; color: var(--text-dark); display: flex; align-items: center; gap: 10px; margin: 0 0 8px 0; }
  .card-title-modern i { color: var(--primary-color); opacity: 0.8; }
  
  .helper-text-modern { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
  
  .stat-box-modern { background: rgba(0, 123, 255, 0.05); border: 1px dashed rgba(0, 123, 255, 0.3); border-radius: 12px; padding: 20px; text-align: center; margin-top: 16px; }
  .stat-box-modern .stat-value { font-size: 32px; font-weight: 900; color: var(--primary-color); line-height: 1; margin-bottom: 5px; }
  .stat-box-modern .stat-label { font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  
  /* Toolbar */
  .df-toolbar-modern { display: flex; flex-wrap: wrap; gap: 12px; background: var(--bg-color); padding: 16px; border-radius: 12px; border: 1px solid var(--border-color); }
  .search-input-wrapper { flex: 1; min-width: 200px; position: relative; }
  .search-input-wrapper i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
  .search-input-wrapper input { width: 100%; padding-left: 40px !important; }
  .input-modern { padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 14px; background: var(--card-bg); color: var(--text-dark); transition: 0.2s; outline: none; }
  .input-modern:focus { border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(0,123,255,0.1); }
  .input-modern.mini { padding: 6px 10px; font-size: 12px; border-radius: 6px; }
  .w-70 { width: 70px; }
  
  /* Buttons */
  .btn-modern { padding: 10px 20px; font-size: 14px; font-weight: 600; border-radius: 8px; cursor: pointer; transition: 0.2s; border: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Inter', sans-serif; text-decoration: none; }
  .btn-modern.small { padding: 6px 12px; font-size: 12px; border-radius: 6px; }
  .btn-modern.solid { background: var(--primary-color); color: #fff; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
  .btn-modern.solid:hover { background: var(--primary-hover); transform: translateY(-1px); }
  .btn-modern.outline { background: transparent; color: var(--primary-color); border: 1px solid var(--primary-color); }
  .btn-modern.outline:hover { background: rgba(0,123,255,0.05); }
  .btn-modern.ghost { background: transparent; color: var(--text-muted); }
  .btn-modern.ghost:hover { background: var(--bg-color); color: var(--text-dark); }
  .btn-modern.danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  .btn-modern.danger:hover { background: #ef4444; color: #fff; }
  .btn-modern.box-btn { padding: 6px; width: 30px; height: 30px; border-radius: 6px; background: var(--bg-color); }
  .btn-modern.icon-only { padding: 6px; width: 30px; height: 30px; border-radius: 6px; }
  
  /* Tables */
  .table-responsive-modern { overflow-x: auto; width: 100%; border-radius: 12px; border: 1px solid var(--border-color); }
  .table-modern { width: 100%; border-collapse: collapse; text-align: left; background: var(--card-bg); font-size: 13px; }
  .table-modern th { background: var(--bg-color); padding: 14px 16px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-size: 11px; border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  .table-modern td { padding: 14px 16px; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
  .table-modern tr:last-child td { border-bottom: none; }
  .table-modern tr:hover { background: rgba(0,0,0,0.01); }
  
  /* Typography & Badges */
  .font-mono { font-family: monospace; }
  .font-medium { font-weight: 600; color: var(--text-dark); }
  .font-bold { font-weight: 700; }
  .text-dim { color: var(--text-muted); }
  .text-primary { color: var(--primary-color); }
  .text-right { text-align: right !important; }
  .action-buttons-modern { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }
  .inline-flex-form { display: flex; gap: 6px; align-items: center; }
  
  .badge-modern { padding: 4px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; line-height: 1; display: inline-block; }
  .badge-modern.neutral { background: var(--bg-color); color: var(--text-muted); border: 1px solid var(--border-color); }
  .badge-modern.sku-badge { background: #f1f5f9; color: #475569; font-family: monospace; letter-spacing: 0.5px; }
  .badge-modern.completed { background: rgba(34, 197, 94, 0.1); color: #16a34a; }
  
  /* Groups / Folders */
  .flex-between-modern { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
  .section-divider-modern { display: flex; align-items: center; gap: 12px; margin: 32px 0 16px; }
  .section-divider-modern h4 { font-size: 16px; font-weight: 800; color: var(--text-dark); margin: 0; }
  .section-divider-modern .line { flex: 1; height: 1px; background: var(--border-color); }
  
  .df-group-card-modern { border: 1px solid var(--border-color); border-radius: 12px; background: var(--card-bg); margin-bottom: 12px; transition: 0.3s; overflow: hidden; }
  .df-group-header-modern { display: flex; align-items: center; gap: 16px; padding: 16px 20px; cursor: pointer; background: var(--card-bg); transition: 0.2s; border-bottom: 1px solid transparent; }
  .df-group-header-modern:hover { background: var(--bg-color); }
  .df-group-card-modern.open .df-group-header-modern { border-bottom-color: var(--border-color); background: var(--bg-color); }
  
  .df-group-thumb-wrapper { width: 44px; height: 44px; flex-shrink: 0; border-radius: 10px; overflow: hidden; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
  .df-group-thumb-wrapper img { width: 100%; height: 100%; object-fit: contain; }
  .df-group-thumb-wrapper .placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--primary-color); color: #fff; font-weight: 800; font-size: 18px; }
  
  .df-group-info { flex: 1; min-width: 0; }
  .df-group-info .name { font-weight: 700; color: var(--text-dark); font-size: 15px; margin-bottom: 4px; }
  .df-group-info .count { font-size: 12px; color: var(--text-muted); }
  
  .df-group-actions { margin-right: 10px; }
  .hidden-file-input { display: none; }
  .upload-btn { cursor: pointer; margin: 0; background: #fff; }
  
  .df-group-header-modern .caret { color: var(--text-muted); transition: 0.3s; font-size: 14px; }
  .df-group-card-modern.open .df-group-header-modern .caret { transform: rotate(180deg); }
  
  .df-group-body-modern { display: none; padding: 16px; background: #fcfcfc; }
  .df-group-card-modern.open .df-group-body-modern { display: block; }
  
  /* Bulk Bar & Checkboxes */
  .df-bulk-bar-modern { display: flex; align-items: center; gap: 16px; padding: 12px 16px; background: rgba(0,123,255,0.05); border: 1px dashed rgba(0,123,255,0.3); border-radius: 12px; margin-top: 16px; }
  .df-select-all-modern { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 13px; cursor: pointer; color: var(--text-dark); }
  .df-select-all-modern input { cursor: pointer; width: 16px; height: 16px; }
  
  input[type="checkbox"] { cursor: pointer; width: 16px; height: 16px; accent-color: var(--primary-color); }
  
  .empty-state-modern { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 14px; background: var(--bg-color); border-radius: 12px; border: 1px dashed var(--border-color); }
  .empty-icon { font-size: 40px; margin-bottom: 16px; color: #cbd5e1; }
  
  @media (max-width: 768px) {
    .df-toolbar-modern select, .df-toolbar-modern .search-input-wrapper { min-width: 100%; flex: 100%; }
    .df-group-header-modern { flex-wrap: wrap; }
    .df-group-actions { width: 100%; margin-top: 10px; }
  }
</style>

<script>
// ===== FUNGSI PENCARIAN & IMPORT =====
(function () {
  var searchBtn = document.getElementById('dfSearchBtn');
  var searchInput = document.getElementById('dfSearchInput');
  var categorySelect = document.getElementById('dfCategorySelect');
  var brandSelect = document.getElementById('dfBrandSelect');
  var typeSelect = document.getElementById('dfTypeSelect');
  var resultsBox = document.getElementById('dfSearchResults');
  var bulkBar = document.getElementById('dfBulkBar');
  var selectAllChk = document.getElementById('dfSelectAllChk');
  var selectedCountEl = document.getElementById('dfSelectedCount');
  var addSelectedBtn = document.getElementById('dfAddSelectedBtn');
  if (!searchBtn) return;

  var lastResults = []; 

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function resetSelect(sel, placeholder) {
    sel.innerHTML = '';
    var opt = document.createElement('option');
    opt.value = ''; opt.textContent = placeholder;
    sel.appendChild(opt);
  }

  fetch('/admin/digiflazz/categories')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.ok || !categorySelect) return;
      data.categories.forEach(function (cat) {
        var opt = document.createElement('option');
        opt.value = cat; opt.textContent = cat;
        categorySelect.appendChild(opt);
      });
    })
    .catch(function () {});

  function loadBrands(category) {
    resetSelect(brandSelect, 'Semua Brand/Judul');
    hideTypeSelect();
    if (!category) { brandSelect.disabled = true; return; }
    brandSelect.disabled = true;
    fetch('/admin/digiflazz/brands?category=' + encodeURIComponent(category))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) return;
        data.brands.forEach(function (b) {
          var opt = document.createElement('option');
          opt.value = b; opt.textContent = b;
          brandSelect.appendChild(opt);
        });
        brandSelect.disabled = false;
      })
      .catch(function () {});
  }

  function hideTypeSelect() {
    resetSelect(typeSelect, 'Semua Tipe');
    typeSelect.style.display = 'none';
  }

  function loadTypes(category, brand) {
    hideTypeSelect();
    if (!brand) return;
    fetch('/admin/digiflazz/types?category=' + encodeURIComponent(category) + '&brand=' + encodeURIComponent(brand))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) return;
        var total = (data.modes || []).length + (data.regions || []).length;
        if (total <= 1) return; 

        if (data.modes && data.modes.length) {
          var g1 = document.createElement('optgroup');
          g1.label = 'Tipe';
          data.modes.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = t; opt.textContent = t;
            g1.appendChild(opt);
          });
          typeSelect.appendChild(g1);
        }
        if (data.regions && data.regions.length) {
          var g2 = document.createElement('optgroup');
          g2.label = 'Negara / Lainnya';
          data.regions.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = t; opt.textContent = t;
            g2.appendChild(opt);
          });
          typeSelect.appendChild(g2);
        }
        typeSelect.style.display = '';
      })
      .catch(function () {});
  }

  function doSearch() {
    var q = searchInput.value.trim();
    var category = categorySelect ? categorySelect.value : '';
    var brand = brandSelect ? brandSelect.value : '';
    var type = typeSelect ? typeSelect.value : '';
    resultsBox.innerHTML = '<div class="empty-state-modern"><i class="fa-solid fa-spinner fa-spin empty-icon"></i><div>Mencari data...</div></div>';
    bulkBar.style.display = 'none';

    var qs = '?q=' + encodeURIComponent(q) + '&category=' + encodeURIComponent(category) +
      '&brand=' + encodeURIComponent(brand) + '&type=' + encodeURIComponent(type);

    fetch('/admin/digiflazz/search' + qs)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) { resultsBox.innerHTML = '<div class="alert error">' + esc(data.error) + '</div>'; return; }
        if (!data.results.length) { resultsBox.innerHTML = '<div class="empty-state-modern"><i class="fa-solid fa-magnifying-glass empty-icon"></i><div>Tidak ada hasil ditemukan.</div></div>'; return; }

        lastResults = data.results;
        renderResultsTable();
      })
      .catch(function (err) { resultsBox.innerHTML = '<div class="alert error">' + esc(err.message) + '</div>'; });
  }

  function updateBulkBar() {
    var boxes = resultsBox.querySelectorAll('.df-row-chk');
    var checked = resultsBox.querySelectorAll('.df-row-chk:checked');
    var anySelectable = boxes.length > 0;
    bulkBar.style.display = anySelectable ? 'flex' : 'none';
    selectedCountEl.textContent = checked.length + ' dipilih';
    addSelectedBtn.disabled = checked.length === 0;
    if (selectAllChk) selectAllChk.checked = boxes.length > 0 && checked.length === boxes.length;
  }

  function renderResultsTable() {
    var table = document.createElement('table');
    table.className = 'table-modern';
    table.innerHTML = '<thead><tr><th style="width:28px;"></th><th>Produk</th><th>Kategori</th><th>SKU</th><th>Modal</th><th>Preview Jual</th><th>Aksi</th></tr></thead>';
    var tbody = document.createElement('tbody');

    lastResults.forEach(function (item, idx) {
      var tr = document.createElement('tr');
      var priceStr = 'Rp ' + Number(item.price || 0).toLocaleString('id-ID');
      var sellStr = 'Rp ' + Number(item.sellPricePreview || 0).toLocaleString('id-ID');

      var chkTd = document.createElement('td');
      if (!item.alreadyImported) {
        var chk = document.createElement('input');
        chk.type = 'checkbox';
        chk.className = 'df-row-chk';
        chk.dataset.idx = idx;
        chk.addEventListener('change', updateBulkBar);
        chkTd.appendChild(chk);
      }
      tr.appendChild(chkTd);

      var nameTd = document.createElement('td');
      var nameInput = document.createElement('input');
      nameInput.type = 'text';
      nameInput.className = 'input-modern mini';
      nameInput.value = item.product_name;
      nameInput.disabled = !!item.alreadyImported;
      nameInput.style.marginBottom = '6px';
      nameInput.style.width = '100%';
      nameTd.appendChild(nameInput);
      var brandHint = document.createElement('div');
      brandHint.className = 'helper-text-modern';
      brandHint.style.fontSize = '11px';
      brandHint.textContent = (item.brand || '') + (item.type ? ' · ' + item.type : '');
      nameTd.appendChild(brandHint);
      tr.appendChild(nameTd);

      var catTd = document.createElement('td');
      catTd.innerHTML = '<span class="badge-modern neutral">' + esc(item.category || '-') + '</span>';
      tr.appendChild(catTd);

      var skuTd = document.createElement('td');
      skuTd.innerHTML = '<span class="badge-modern sku-badge">' + item.buyer_sku_code + '</span>';
      tr.appendChild(skuTd);

      var modalTd = document.createElement('td');
      modalTd.className = 'font-mono text-dim';
      modalTd.textContent = priceStr;
      tr.appendChild(modalTd);

      var sellTd = document.createElement('td');
      sellTd.className = 'font-mono text-primary font-bold';
      sellTd.textContent = sellStr;
      tr.appendChild(sellTd);

      var actionTd = document.createElement('td');
      if (item.alreadyImported) {
        var span = document.createElement('span');
        span.className = 'badge-modern completed';
        span.innerHTML = '<i class="fa-solid fa-check"></i> Sudah diimport';
        actionTd.appendChild(span);
      } else {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'btn-modern solid small';
        btn.innerHTML = '<i class="fa-solid fa-plus"></i> Import';
        btn.addEventListener('click', function () { importSingle(item, nameInput.value.trim(), btn); });
        actionTd.appendChild(btn);
      }
      tr.appendChild(actionTd);

      tbody.appendChild(tr);
    });

    table.appendChild(tbody);
    resultsBox.innerHTML = '';
    resultsBox.appendChild(table);
    updateBulkBar();
  }

  function importSingle(item, productName, btn) {
    if (!productName) { alert('Judul produk tidak boleh kosong.'); return; }
    btn.disabled = true;
    btn.textContent = '...';
    fetch('/admin/digiflazz/import', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        buyerSkuCode: item.buyer_sku_code,
        productName: productName,
        category: item.category || 'Games',
        brand: item.brand || '',
        basePrice: item.price
      })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) { alert('Gagal: ' + data.error); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-plus"></i> Import'; return; }
        item.alreadyImported = true;
        renderResultsTable();
      })
      .catch(function (err) { alert('Gagal: ' + err.message); btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-plus"></i> Import'; });
  }

  searchBtn.addEventListener('click', doSearch);
  searchInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
  });
  categorySelect.addEventListener('change', function () {
    loadBrands(categorySelect.value);
    doSearch();
  });
  brandSelect.addEventListener('change', function () {
    loadTypes(categorySelect.value, brandSelect.value);
    doSearch();
  });
  typeSelect.addEventListener('change', doSearch);

  selectAllChk.addEventListener('change', function () {
    resultsBox.querySelectorAll('.df-row-chk').forEach(function (chk) { chk.checked = selectAllChk.checked; });
    updateBulkBar();
  });

  addSelectedBtn.addEventListener('click', function () {
    var checked = resultsBox.querySelectorAll('.df-row-chk:checked');
    if (!checked.length) return;
    var items = [];
    checked.forEach(function (chk) {
      var item = lastResults[Number(chk.dataset.idx)];
      var nameInput = chk.closest('tr').querySelector('.input-modern.mini');
      var name = nameInput ? nameInput.value.trim() : item.product_name;
      if (!name) return;
      items.push({
        buyerSkuCode: item.buyer_sku_code,
        productName: name,
        category: item.category || 'Games',
        brand: item.brand || '',
        basePrice: item.price
      });
    });
    if (!items.length) { alert('Judul produk tidak boleh kosong.'); return; }

    addSelectedBtn.disabled = true;
    addSelectedBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Menambahkan...';
    fetch('/admin/digiflazz/import-batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        addSelectedBtn.innerHTML = '<i class="fa-solid fa-plus"></i> Import Terpilih';
        if (!data.ok) { alert('Gagal: ' + data.error); return; }
        alert(data.message);
        location.reload(); 
      })
      .catch(function (err) {
        addSelectedBtn.innerHTML = '<i class="fa-solid fa-plus"></i> Import Terpilih';
        alert('Gagal: ' + err.message);
      });
  });
})();

// ===== FOLDER GRUP DIGIFLAZZ & BULK UNLINK =====
(function () {
  // Toggle Accordion Folder
  document.querySelectorAll('[data-df-group-toggle]').forEach(function (header) {
    header.addEventListener('click', function (e) {
      // Cegah toggle kalau klik di dalam area actions (seperti upload)
      if(e.target.closest('.df-group-actions') || e.target.closest('input[type="checkbox"]')) return;
      var card = header.closest('[data-df-group]');
      if (card) card.classList.toggle('open');
    });
  });
})();

// Fungsi untuk memilih semua checkbox dalam 1 tabel / folder
function toggleTableUnlink(headerCheckbox) {
  var table = headerCheckbox.closest('table');
  var checkboxes = table.querySelectorAll('.df-unlink-chk');
  checkboxes.forEach(function(chk) { 
    chk.checked = headerCheckbox.checked; 
  });
  updateBulkUnlinkBtn();
}

// Memunculkan tombol "Lepas Terpilih" jika ada minimal 1 produk yang dicentang
function updateBulkUnlinkBtn() {
  var checkedCount = document.querySelectorAll('.df-unlink-chk:checked').length;
  var btn = document.getElementById('btnBulkUnlink');
  if (checkedCount > 0) {
    btn.style.display = 'inline-flex';
    btn.innerHTML = '<i class="fa-solid fa-link-slash"></i> Lepas Terpilih (' + checkedCount + ')';
  } else {
    btn.style.display = 'none';
  }
}

// Proses Bulk Unlink (melakukan request ke endpoint unlink satu per satu secara paralel)
function processBulkUnlink() {
  var checkboxes = document.querySelectorAll('.df-unlink-chk:checked');
  if (checkboxes.length === 0) return;
  
  if (!confirm('Apakah Anda yakin ingin melepas ' + checkboxes.length + ' produk terpilih dari tautan Digiflazz? (Produk akan menjadi stok manual)')) {
    return;
  }

  var btn = document.getElementById('btnBulkUnlink');
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memproses...';

  // Kumpulkan semua request dalam bentuk Array of Promises
  var promises = Array.from(checkboxes).map(function(chk) {
    return fetch('/admin/digiflazz/' + chk.value + '/unlink', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
  });

  // Eksekusi semua secara bersamaan tanpa membebani / mengedit backend
  Promise.all(promises)
    .then(function() {
      alert(checkboxes.length + ' produk berhasil dilepas!');
      location.reload();
    })
    .catch(function(err) {
      alert('Terjadi kesalahan saat memproses sebagian data. Halaman akan dimuat ulang.');
      location.reload();
    });
}
</script>
</body>
</html>

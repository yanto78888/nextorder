<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'digiflazz' }) %>

  <div class="main no-bottom-nav">
    <div class="topbar"><h2>Produk Digiflazz</h2></div>

    <% if (success) { %><div class="alert success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><%= error %></div><% } %>

    <% const df = config.digiflazz || {}; %>
    <% if (!df.enabled || !df.username || !df.apiKey) { %>
      <div class="alert error">
        Digiflazz belum aktif/lengkap. Isi Username &amp; API Key lalu centang "Aktifkan" di
        <a href="/admin/settings" style="color:#fff; text-decoration:underline;">Pengaturan</a> dulu sebelum import produk.
      </div>
    <% } %>

    <div class="grid grid-2">
      <div class="card">
        <h3>Margin Default</h3>
        <p class="helper-text">Margin ini otomatis dipakai untuk semua produk Digiflazz yang tidak punya margin sendiri (override). Rumus: Harga Jual = Harga Modal + Margin, dibulatkan ke atas kelipatan Rp100.</p>
        <form method="POST" action="/admin/digiflazz/margin">
          <div class="grid grid-2 form-mini-grid">
            <div>
              <label>Tipe Margin</label>
              <select name="marginType">
                <option value="percent" <%= (df.marginType || 'percent') === 'percent' ? 'selected' : '' %>>Persentase (%)</option>
                <option value="fixed" <%= df.marginType === 'fixed' ? 'selected' : '' %>>Nominal Tetap (Rp)</option>
              </select>
            </div>
            <div>
              <label>Nilai Margin</label>
              <input type="number" step="0.01" name="marginValue" value="<%= (typeof df.marginValue !== 'undefined' && df.marginValue !== null) ? df.marginValue : 10 %>">
            </div>
          </div>
          <button class="btn solid mt-16" type="submit">Simpan Margin Default</button>
        </form>
      </div>

      <div class="card">
        <h3>Ringkasan</h3>
        <div class="detail-stats-row" style="margin:0;">
          <div class="detail-stat">
            <div class="detail-stat-val"><%= digiflazzProducts.length %></div>
            <div class="detail-stat-label">Produk Terhubung</div>
          </div>
        </div>
        <form method="POST" action="/admin/digiflazz/sync-all" class="mt-16">
          <button class="btn ghost" type="submit" style="width:100%;"><i class="fa-solid fa-rotate"></i> Sinkron Semua Harga dari Digiflazz</button>
        </form>
        <div class="helper-text mt-16">Sinkron akan ambil harga modal terbaru dari Digiflazz untuk semua produk yang sudah diimport, lalu hitung ulang harga jual pakai margin masing-masing (atau margin default kalau tidak ada override).</div>
      </div>
    </div>

    <div class="card mt-24">
      <h3>Cari &amp; Import Produk dari Digiflazz</h3>
      <div class="helper-text">Pilih Kategori → Brand/Judul → Tipe biar hasil makin fokus (tiap dropdown aktif setelah yang sebelumnya dipilih), atau langsung ketik nama produk/SKU. Centang hasil yang mau ditambah — judul tiap produk bisa diedit dulu di kolom "Produk" kalau mau pakai judul sendiri, lalu klik "Tambah Produk Terpilih".</div>

      <div class="df-filter-row">
        <select id="dfCategorySelect">
          <option value="">Semua Kategori</option>
        </select>
        <select id="dfBrandSelect" disabled>
          <option value="">Semua Brand/Judul</option>
        </select>
        <select id="dfTypeSelect" style="display:none;">
          <option value="">Semua Tipe</option>
        </select>
        <input type="text" id="dfSearchInput" placeholder="Cari nama produk / SKU...">
        <button type="button" class="btn solid" id="dfSearchBtn">Cari</button>
      </div>

      <div id="dfBulkBar" class="df-bulk-bar" style="display:none;">
        <label class="df-select-all"><input type="checkbox" id="dfSelectAllChk"> Pilih semua</label>
        <span id="dfSelectedCount" class="helper-text">0 dipilih</span>
        <button type="button" class="btn ghost small" id="dfAddSelectedBtn" disabled><i class="fa-solid fa-plus"></i> Tambah Produk Terpilih</button>
      </div>

      <div id="dfSearchResults" style="margin-top:14px;"></div>
    </div>

    <div class="card mt-24">
      <div class="flex" style="justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
        <h3 style="margin:0;">Produk Digiflazz Terhubung (<%= digiflazzProducts.length %>)</h3>
        <a href="/admin/produk" class="btn small ghost"><i class="fa-solid fa-screwdriver-wrench"></i> Produk Stok Manual</a>
      </div>
      <div class="helper-text">Produk dengan Grup Varian yang sama (mis. "Mobile Legends") dikumpulkan jadi 1 folder — klik buat buka/tutup isi nominalnya. Upload 1 foto per folder, otomatis kepakai juga sebagai foto grup itu di katalog customer. Produk tanpa Grup Varian tampil langsung di tabel biasa di bawahnya.</div>
      <% if (digiflazzProducts.length === 0) { %>
        <div class="empty-state mt-16">Belum ada produk yang diimport dari Digiflazz.</div>
      <% } else { %>
        <% const dfCatOrder = []; const dfCatGroups = {}; %>
        <% digiflazzProducts.forEach(p => { const cat = p.category || 'Umum'; if (!dfCatGroups[cat]) { dfCatGroups[cat] = []; dfCatOrder.push(cat); } dfCatGroups[cat].push(p); }) %>
        <% dfCatOrder.sort().forEach(cat => { %>
          <% const catProducts = dfCatGroups[cat]; %>
          <% const folderOrder = []; const folders = {}; const singles = []; %>
          <% catProducts.forEach(p => {
               if (p.variantGroup) {
                 if (!folders[p.variantGroup]) { folders[p.variantGroup] = []; folderOrder.push(p.variantGroup); }
                 folders[p.variantGroup].push(p);
               } else {
                 singles.push(p);
               }
             }); %>

          <div class="section-title"><h3><%= cat %></h3><span class="helper-text"><%= catProducts.length %> produk</span><div class="line"></div></div>

          <% folderOrder.forEach(groupName => { %>
            <% const groupProducts = folders[groupName]; %>
            <% const thumb = groupThumbnails[groupName] || ''; %>
            <div class="df-group-card" data-df-group>
              <div class="df-group-header" data-df-group-toggle>
                <% if (thumb) { %>
                  <img class="df-group-thumb" src="<%= thumb %>" alt="<%= groupName %>">
                <% } else { %>
                  <span class="df-group-thumb-placeholder"><%= groupName.charAt(0).toUpperCase() %></span>
                <% } %>
                <div class="df-group-info">
                  <div class="df-group-name"><%= groupName %></div>
                  <div class="df-group-count"><%= groupProducts.length %> pilihan nominal</div>
                </div>
                <i class="fa-solid fa-chevron-down df-group-caret"></i>
              </div>

              <form method="POST" action="/admin/digiflazz/group/<%= encodeURIComponent(groupName) %>/thumbnail" enctype="multipart/form-data" class="df-group-upload" onclick="event.stopPropagation()">
                <input type="file" name="groupThumbnailFile" accept="image/png,image/jpeg,image/webp,image/gif">
                <button type="submit" class="btn small ghost"><i class="fa-solid fa-image"></i> <%= thumb ? 'Ganti' : 'Upload' %> Foto Folder</button>
              </form>

              <div class="df-group-body">
                <table>
                  <thead><tr><th>Nama</th><th>SKU</th><th>Modal</th><th>Margin</th><th>Harga Jual</th><th>Aksi</th></tr></thead>
                  <tbody>
                    <% groupProducts.slice().sort((a, b) => a.price - b.price).forEach(p => { %>
                    <tr>
                      <td><%= p.name %></td>
                      <td class="mono"><%= p.digiflazzSku %></td>
                      <td class="mono">Rp <%= (p.digiflazzBasePrice || 0).toLocaleString('id-ID') %></td>
                      <td>
                        <form method="POST" action="/admin/digiflazz/<%= p.id %>/margin" class="flex" style="gap:4px; flex-wrap:nowrap;">
                          <select name="marginType" style="width:90px; font-size:12px;">
                            <option value="" <%= !p.marginType ? 'selected' : '' %>>Default</option>
                            <option value="percent" <%= p.marginType === 'percent' ? 'selected' : '' %>>%</option>
                            <option value="fixed" <%= p.marginType === 'fixed' ? 'selected' : '' %>>Rp</option>
                          </select>
                          <input type="number" step="0.01" name="marginValue" value="<%= p.marginValue !== null ? p.marginValue : '' %>" placeholder="-" style="width:70px; font-size:12px;">
                          <button type="submit" class="btn small ghost">Set</button>
                        </form>
                      </td>
                      <td class="mono">Rp <%= p.price.toLocaleString('id-ID') %></td>
                      <td>
                        <div class="flex" style="gap:6px; flex-wrap:wrap;">
                          <form method="POST" action="/admin/digiflazz/<%= p.id %>/resync">
                            <button class="btn small ghost" type="submit" title="Ambil ulang harga modal terbaru"><i class="fa-solid fa-rotate"></i></button>
                          </form>
                          <a href="/admin/produk/<%= p.id %>/edit" class="btn small ghost">Edit</a>
                          <form method="POST" action="/admin/digiflazz/<%= p.id %>/unlink" onsubmit="return confirm('Lepas produk ini dari Digiflazz? Produk akan jadi stok manual biasa.')">
                            <button class="btn small danger" type="submit">Lepas</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% }) %>

          <% if (singles.length > 0) { %>
            <table>
              <thead><tr><th>Nama</th><th>SKU</th><th>Modal</th><th>Margin</th><th>Harga Jual</th><th>Aksi</th></tr></thead>
              <tbody>
                <% singles.slice().sort((a, b) => a.price - b.price).forEach(p => { %>
                <tr>
                  <td><%= p.name %></td>
                  <td class="mono"><%= p.digiflazzSku %></td>
                  <td class="mono">Rp <%= (p.digiflazzBasePrice || 0).toLocaleString('id-ID') %></td>
                  <td>
                    <form method="POST" action="/admin/digiflazz/<%= p.id %>/margin" class="flex" style="gap:4px; flex-wrap:nowrap;">
                      <select name="marginType" style="width:90px; font-size:12px;">
                        <option value="" <%= !p.marginType ? 'selected' : '' %>>Default</option>
                        <option value="percent" <%= p.marginType === 'percent' ? 'selected' : '' %>>%</option>
                        <option value="fixed" <%= p.marginType === 'fixed' ? 'selected' : '' %>>Rp</option>
                      </select>
                      <input type="number" step="0.01" name="marginValue" value="<%= p.marginValue !== null ? p.marginValue : '' %>" placeholder="-" style="width:70px; font-size:12px;">
                      <button type="submit" class="btn small ghost">Set</button>
                    </form>
                  </td>
                  <td class="mono">Rp <%= p.price.toLocaleString('id-ID') %></td>
                  <td>
                    <div class="flex" style="gap:6px; flex-wrap:wrap;">
                      <form method="POST" action="/admin/digiflazz/<%= p.id %>/resync">
                        <button class="btn small ghost" type="submit" title="Ambil ulang harga modal terbaru"><i class="fa-solid fa-rotate"></i></button>
                      </form>
                      <a href="/admin/produk/<%= p.id %>/edit" class="btn small ghost">Edit</a>
                      <form method="POST" action="/admin/digiflazz/<%= p.id %>/unlink" onsubmit="return confirm('Lepas produk ini dari Digiflazz? Produk akan jadi stok manual biasa.')">
                        <button class="btn small danger" type="submit">Lepas</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<script>
(function () {
  var searchBtn = document.getElementById('dfSearchBtn');
  var searchInput = document.getElementById('dfSearchInput');
  var categorySelect = document.getElementById('dfCategorySelect');
  var brandSelect = document.getElementById('dfBrandSelect');
  var typeSelect = document.getElementById('dfTypeSelect');
  var resultsBox = document.getElementById('dfSearchResults');
  var bulkBar = document.getElementById('dfBulkBar');
  var selectAllChk = document.getElementById('dfSelectAllChk');
  var selectedCountEl = document.getElementById('dfSelectedCount');
  var addSelectedBtn = document.getElementById('dfAddSelectedBtn');
  if (!searchBtn) return;

  var lastResults = []; // hasil pencarian terakhir, diindex sesuai urutan baris tabel

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function resetSelect(sel, placeholder) {
    sel.innerHTML = '';
    var opt = document.createElement('option');
    opt.value = ''; opt.textContent = placeholder;
    sel.appendChild(opt);
  }

  // Isi dropdown kategori dari Digiflazz sekali di awal (Games, Pulsa, Data, PLN, dst).
  fetch('/admin/digiflazz/categories')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.ok || !categorySelect) return;
      data.categories.forEach(function (cat) {
        var opt = document.createElement('option');
        opt.value = cat; opt.textContent = cat;
        categorySelect.appendChild(opt);
      });
    })
    .catch(function () {});

  // Level ke-2: Brand/Judul, cuma aktif setelah Kategori dipilih -- biar daftarnya gak nyampur
  // ratusan brand dari semua kategori sekaligus (itu yang bikin "makan tempat" di versi lama).
  function loadBrands(category) {
    resetSelect(brandSelect, 'Semua Brand/Judul');
    hideTypeSelect();
    if (!category) { brandSelect.disabled = true; return; }
    brandSelect.disabled = true;
    fetch('/admin/digiflazz/brands?category=' + encodeURIComponent(category))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) return;
        data.brands.forEach(function (b) {
          var opt = document.createElement('option');
          opt.value = b; opt.textContent = b;
          brandSelect.appendChild(opt);
        });
        brandSelect.disabled = false;
      })
      .catch(function () {});
  }

  function hideTypeSelect() {
    resetSelect(typeSelect, 'Semua Tipe');
    typeSelect.style.display = 'none';
  }

  // Level ke-3: Tipe, dipisah 2 grup (Tipe: Umum/Membership, Negara/Lainnya: Malaysia/Global/dst).
  // Dropdown ini disembunyikan total kalau brand-nya cuma punya 1 (atau 0) pilihan tipe -- gak ada
  // gunanya nampilin dropdown yang isinya cuma 1 opsi, cuma makan tempat doang.
  function loadTypes(category, brand) {
    hideTypeSelect();
    if (!brand) return;
    fetch('/admin/digiflazz/types?category=' + encodeURIComponent(category) + '&brand=' + encodeURIComponent(brand))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) return;
        var total = (data.modes || []).length + (data.regions || []).length;
        if (total <= 1) return; // gak perlu dropdown, biarin ke-skip (search tetap jalan tanpa filter tipe)

        if (data.modes && data.modes.length) {
          var g1 = document.createElement('optgroup');
          g1.label = 'Tipe';
          data.modes.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = t; opt.textContent = t;
            g1.appendChild(opt);
          });
          typeSelect.appendChild(g1);
        }
        if (data.regions && data.regions.length) {
          var g2 = document.createElement('optgroup');
          g2.label = 'Negara / Lainnya';
          data.regions.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = t; opt.textContent = t;
            g2.appendChild(opt);
          });
          typeSelect.appendChild(g2);
        }
        typeSelect.style.display = '';
      })
      .catch(function () {});
  }

  function doSearch() {
    var q = searchInput.value.trim();
    var category = categorySelect ? categorySelect.value : '';
    var brand = brandSelect ? brandSelect.value : '';
    var type = typeSelect ? typeSelect.value : '';
    resultsBox.innerHTML = '<div class="helper-text">Mencari...</div>';
    bulkBar.style.display = 'none';

    var qs = '?q=' + encodeURIComponent(q) + '&category=' + encodeURIComponent(category) +
      '&brand=' + encodeURIComponent(brand) + '&type=' + encodeURIComponent(type);

    fetch('/admin/digiflazz/search' + qs)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) { resultsBox.innerHTML = '<div class="helper-text">Gagal: ' + esc(data.error) + '</div>'; return; }
        if (!data.results.length) { resultsBox.innerHTML = '<div class="helper-text">Tidak ada hasil.</div>'; return; }

        lastResults = data.results;
        renderResultsTable();
      })
      .catch(function (err) { resultsBox.innerHTML = '<div class="helper-text">Gagal: ' + esc(err.message) + '</div>'; });
  }

  function updateBulkBar() {
    var boxes = resultsBox.querySelectorAll('.df-row-chk');
    var checked = resultsBox.querySelectorAll('.df-row-chk:checked');
    var anySelectable = boxes.length > 0;
    bulkBar.style.display = anySelectable ? '' : 'none';
    selectedCountEl.textContent = checked.length + ' dipilih';
    addSelectedBtn.disabled = checked.length === 0;
    if (selectAllChk) selectAllChk.checked = boxes.length > 0 && checked.length === boxes.length;
  }

  function renderResultsTable() {
    var table = document.createElement('table');
    table.innerHTML = '<thead><tr><th style="width:28px;"></th><th>Produk</th><th>Kategori</th><th>SKU</th><th>Modal</th><th>Preview Jual</th><th>Aksi</th></tr></thead>';
    var tbody = document.createElement('tbody');

    lastResults.forEach(function (item, idx) {
      var tr = document.createElement('tr');
      var priceStr = 'Rp ' + Number(item.price || 0).toLocaleString('id-ID');
      var sellStr = 'Rp ' + Number(item.sellPricePreview || 0).toLocaleString('id-ID');

      var chkTd = document.createElement('td');
      if (!item.alreadyImported) {
        var chk = document.createElement('input');
        chk.type = 'checkbox';
        chk.className = 'df-row-chk';
        chk.dataset.idx = idx;
        chk.addEventListener('change', updateBulkBar);
        chkTd.appendChild(chk);
      }
      tr.appendChild(chkTd);

      var nameTd = document.createElement('td');
      var nameInput = document.createElement('input');
      nameInput.type = 'text';
      nameInput.className = 'df-row-name';
      nameInput.value = item.product_name;
      nameInput.disabled = !!item.alreadyImported;
      nameInput.style.marginBottom = '4px';
      nameTd.appendChild(nameInput);
      var brandHint = document.createElement('div');
      brandHint.className = 'helper-text';
      brandHint.textContent = (item.brand || '') + (item.type ? ' · ' + item.type : '');
      nameTd.appendChild(brandHint);
      tr.appendChild(nameTd);

      var catTd = document.createElement('td');
      catTd.innerHTML = '<span class="helper-text">' + esc(item.category || '-') + '</span>';
      tr.appendChild(catTd);

      var skuTd = document.createElement('td');
      skuTd.className = 'mono';
      skuTd.textContent = item.buyer_sku_code;
      tr.appendChild(skuTd);

      var modalTd = document.createElement('td');
      modalTd.className = 'mono';
      modalTd.textContent = priceStr;
      tr.appendChild(modalTd);

      var sellTd = document.createElement('td');
      sellTd.className = 'mono';
      sellTd.style.color = 'var(--cyan)';
      sellTd.textContent = sellStr;
      tr.appendChild(sellTd);

      var actionTd = document.createElement('td');
      if (item.alreadyImported) {
        var span = document.createElement('span');
        span.className = 'badge completed';
        span.textContent = 'Sudah diimport';
        actionTd.appendChild(span);
      } else {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'btn small solid';
        btn.textContent = 'Import';
        btn.addEventListener('click', function () { importSingle(item, nameInput.value.trim(), btn); });
        actionTd.appendChild(btn);
      }
      tr.appendChild(actionTd);

      tbody.appendChild(tr);
    });

    table.appendChild(tbody);
    resultsBox.innerHTML = '';
    resultsBox.appendChild(table);
    updateBulkBar();
  }

  function importSingle(item, productName, btn) {
    if (!productName) { alert('Judul produk tidak boleh kosong.'); return; }
    btn.disabled = true;
    btn.textContent = '...';
    fetch('/admin/digiflazz/import', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        buyerSkuCode: item.buyer_sku_code,
        productName: productName,
        category: item.category || 'Games',
        brand: item.brand || '',
        basePrice: item.price
      })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.ok) { alert('Gagal: ' + data.error); btn.disabled = false; btn.textContent = 'Import'; return; }
        item.alreadyImported = true;
        renderResultsTable();
      })
      .catch(function (err) { alert('Gagal: ' + err.message); btn.disabled = false; btn.textContent = 'Import'; });
  }

  searchBtn.addEventListener('click', doSearch);
  searchInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
  });
  categorySelect.addEventListener('change', function () {
    loadBrands(categorySelect.value);
    doSearch();
  });
  brandSelect.addEventListener('change', function () {
    loadTypes(categorySelect.value, brandSelect.value);
    doSearch();
  });
  typeSelect.addEventListener('change', doSearch);

  selectAllChk.addEventListener('change', function () {
    resultsBox.querySelectorAll('.df-row-chk').forEach(function (chk) { chk.checked = selectAllChk.checked; });
    updateBulkBar();
  });

  addSelectedBtn.addEventListener('click', function () {
    var checked = resultsBox.querySelectorAll('.df-row-chk:checked');
    if (!checked.length) return;
    var items = [];
    checked.forEach(function (chk) {
      var item = lastResults[Number(chk.dataset.idx)];
      var nameInput = chk.closest('tr').querySelector('.df-row-name');
      var name = nameInput ? nameInput.value.trim() : item.product_name;
      if (!name) return;
      items.push({
        buyerSkuCode: item.buyer_sku_code,
        productName: name,
        category: item.category || 'Games',
        brand: item.brand || '',
        basePrice: item.price
      });
    });
    if (!items.length) { alert('Judul produk tidak boleh kosong.'); return; }

    addSelectedBtn.disabled = true;
    addSelectedBtn.textContent = 'Menambahkan...';
    fetch('/admin/digiflazz/import-batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        addSelectedBtn.textContent = 'Tambah Produk Terpilih';
        if (!data.ok) { alert('Gagal: ' + data.error); return; }
        alert(data.message);
        location.reload(); // refresh biar badge "Sudah diimport" & daftar "Produk Digiflazz Terhubung" di bawah keupdate
      })
      .catch(function (err) {
        addSelectedBtn.textContent = 'Tambah Produk Terpilih';
        alert('Gagal: ' + err.message);
      });
  });
})();

// ===== FOLDER GRUP DIGIFLAZZ: klik header buat buka/tutup isi nominal =====
(function () {
  document.querySelectorAll('[data-df-group-toggle]').forEach(function (header) {
    header.addEventListener('click', function () {
      var card = header.closest('[data-df-group]');
      if (card) card.classList.toggle('open');
    });
  });
})();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'settings' }) %>

  <div class="main no-bottom-nav">
    
    <div class="admin-header-modern">
      <h2><i class="fa-solid fa-gear" style="color: var(--primary-color);"></i> Pengaturan Sistem</h2>
    </div>

    <% if (success) { %><div class="alert success"><i class="fa-solid fa-circle-check"></i> <%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div><% } %>

    <form method="POST" action="/admin/settings/update" enctype="multipart/form-data">
      
      <!-- Tombol Save Floating di Atas (Mobile Friendly) -->
      <div class="card card-modern mb-24" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; background: rgba(0, 123, 255, 0.05); border: 1px dashed var(--primary-color);">
        <div>
          <h3 style="margin: 0; font-size: 15px; color: var(--text-dark);">Simpan Perubahan</h3>
          <p class="helper-text-modern" style="margin: 4px 0 0 0; font-size: 12px;">Pastikan semua API Key sudah benar sebelum menyimpan.</p>
        </div>
        <button type="submit" class="btn-modern solid"><i class="fa-solid fa-floppy-disk"></i> Simpan Semua</button>
      </div>

      <div class="grid grid-2">
        
        <!-- Informasi Website -->
        <div class="card card-modern">
          <h3 class="card-title-modern"><i class="fa-solid fa-globe"></i> Informasi Website</h3>
          <div class="line mb-16"></div>
          
          <div class="form-group-modern">
            <label>Nama Website</label>
            <input type="text" name="webName" class="input-modern" value="<%= settings.webName || '' %>" placeholder="Contoh: StoreKu" required>
          </div>

          <div class="form-group-modern">
            <label>Deskripsi Singkat (SEO)</label>
            <textarea name="webDescription" class="input-modern" rows="3" placeholder="Deskripsi untuk meta tag SEO..."><%= settings.webDescription || '' %></textarea>
          </div>

          <div class="form-group-modern">
            <label>Keyword (SEO)</label>
            <input type="text" name="webKeywords" class="input-modern" value="<%= settings.webKeywords || '' %>" placeholder="topup game, smm panel, murah">
          </div>

          <div class="form-group-modern">
            <label>Logo Website (Opsional)</label>
            <input type="file" name="danimaru" class="input-modern danimaru-upload" style="padding: 7px 14px;" accept="image/png,image/jpeg,image/webp">
            <div class="helper-text-modern mt-1">Biarkan kosong jika tidak ingin mengubah logo saat ini.</div>
          </div>
        </div>

        <!-- Pengaturan Kontak & Sosial -->
        <div class="card card-modern">
          <h3 class="card-title-modern"><i class="fa-solid fa-headset"></i> Kontak & Bantuan</h3>
          <div class="line mb-16"></div>
          
          <div class="form-group-modern">
            <label>Nomor WhatsApp (Admin)</label>
            <input type="text" name="waAdmin" class="input-modern" value="<%= settings.waAdmin || '' %>" placeholder="Contoh: 628123456789">
            <div class="helper-text-modern mt-1">Gunakan awalan 62. Digunakan untuk tombol bantuan WA.</div>
          </div>

          <div class="form-group-modern">
            <label>Link Instagram</label>
            <input type="url" name="igLink" class="input-modern" value="<%= settings.igLink || '' %>" placeholder="https://instagram.com/...">
          </div>
          
          <div class="form-group-modern">
            <label>Link Syarat & Ketentuan (TOS)</label>
            <input type="url" name="tosLink" class="input-modern" value="<%= settings.tosLink || '' %>" placeholder="Link halaman ketentuan...">
          </div>
        </div>

        <!-- Payment Gateway (Tripay) -->
        <div class="card card-modern">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <h3 class="card-title-modern mb-0"><i class="fa-solid fa-credit-card"></i> Payment Gateway (Tripay)</h3>
            <label class="check-row-modern small">
              <input type="checkbox" name="tripayEnabled" <%= config.tripay && config.tripay.enabled ? 'checked' : '' %>> Aktif
            </label>
          </div>
          <div class="line mb-16"></div>
          
          <div class="form-group-modern">
            <label>API Key</label>
            <input type="password" name="tripayApiKey" class="input-modern" value="<%= config.tripay ? config.tripay.apiKey : '' %>" placeholder="Masukkan API Key Tripay">
          </div>

          <div class="form-group-modern">
            <label>Private Key</label>
            <input type="password" name="tripayPrivateKey" class="input-modern" value="<%= config.tripay ? config.tripay.privateKey : '' %>" placeholder="Masukkan Private Key Tripay">
          </div>

          <div class="form-group-modern">
            <label>Merchant Code</label>
            <input type="text" name="tripayMerchant" class="input-modern" value="<%= config.tripay ? config.tripay.merchantCode : '' %>" placeholder="Contoh: T12345">
          </div>
        </div>

        <!-- Koneksi Digiflazz -->
        <div class="card card-modern">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <h3 class="card-title-modern mb-0" style="color: #ea580c;"><i class="fa-solid fa-bolt"></i> API Digiflazz (Games)</h3>
            <label class="check-row-modern small">
              <input type="checkbox" name="digiEnabled" <%= config.digiflazz && config.digiflazz.enabled ? 'checked' : '' %>> Aktif
            </label>
          </div>
          <div class="line mb-16"></div>
          
          <div class="form-group-modern">
            <label>Username Digiflazz</label>
            <input type="text" name="digiUsername" class="input-modern" value="<%= config.digiflazz ? config.digiflazz.username : '' %>" placeholder="Username akun Digiflazz">
          </div>

          <div class="form-group-modern">
            <label>API Key (Production / Dev)</label>
            <input type="password" name="digiApiKey" class="input-modern" value="<%= config.digiflazz ? config.digiflazz.apiKey : '' %>" placeholder="Masukkan API Key Digiflazz">
          </div>
        </div>

        <!-- Koneksi IndoSMM -->
        <div class="card card-modern">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <h3 class="card-title-modern mb-0" style="color: #7c3aed;"><i class="fa-solid fa-share-nodes"></i> API IndoSMM (Sosmed)</h3>
            <label class="check-row-modern small">
              <input type="checkbox" name="smmEnabled" <%= config.indosmm && config.indosmm.enabled ? 'checked' : '' %>> Aktif
            </label>
          </div>
          <div class="line mb-16"></div>
          
          <div class="form-group-modern">
            <label>API Key IndoSMM</label>
            <input type="password" name="smmApiKey" class="input-modern" value="<%= config.indosmm ? config.indosmm.apiKey : '' %>" placeholder="Masukkan API Key IndoSMM">
            <div class="helper-text-modern mt-1">Dapatkan API Key di panel IndoSMM bagian dokumentasi API.</div>
          </div>
        </div>

        <!-- Pengaturan Tambahan (Membership/Profit) -->
        <div class="card card-modern">
          <h3 class="card-title-modern"><i class="fa-solid fa-percent"></i> Diskon Membership</h3>
          <div class="line mb-16"></div>
          <p class="helper-text-modern mb-16">Persentase potongan harga otomatis untuk member premium (berlaku pada produk manual/otomatis yang tidak memiliki harga khusus).</p>

          <div class="form-mini-grid">
            <div class="form-group-modern">
              <label>Diskon Member Gold (%)</label>
              <input type="number" step="0.1" name="discountGold" class="input-modern" value="<%= settings.discountGold || 0 %>" placeholder="Contoh: 2.5">
            </div>
            <div class="form-group-modern">
              <label>Diskon Member Platinum (%)</label>
              <input type="number" step="0.1" name="discountPlatinum" class="input-modern" value="<%= settings.discountPlatinum || 0 %>" placeholder="Contoh: 5.0">
            </div>
          </div>
        </div>

      </div>
    </form>
  </div>
</div>

<style>
  /* ADMIN SETTINGS MODERN CSS STYLES */
  .admin-header-modern { margin-bottom: 24px; }
  .admin-header-modern h2 { font-size: 24px; font-weight: 800; color: var(--text-dark); display: flex; align-items: center; gap: 12px; margin: 0; }
  
  .card-modern { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: 24px; box-shadow: var(--shadow-sm); }
  .card-title-modern { font-size: 16px; font-weight: 700; color: var(--text-dark); display: flex; align-items: center; gap: 10px; margin: 0; }
  .card-title-modern i { opacity: 0.8; }
  
  .helper-text-modern { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
  .mt-1 { margin-top: 4px; }
  .mb-16 { margin-bottom: 16px; }
  .mb-24 { margin-bottom: 24px; }
  .line { height: 1px; background: var(--border-color); width: 100%; margin-top: 12px; }
  
  /* PERBAIKAN GRID UNTUK DESKTOP */
  .grid { display: grid; gap: 24px; }
  .grid-2 { grid-template-columns: repeat(2, 1fr); }
  .form-mini-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

  .form-group-modern { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .form-group-modern:last-child { margin-bottom: 0; }
  .form-group-modern label { font-size: 13px; font-weight: 600; color: var(--text-dark); }
  
  .input-modern { padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 14px; background: var(--bg-color); color: var(--text-dark); transition: 0.2s; outline: none; width: 100%; box-sizing: border-box; }
  .input-modern:focus { border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(0,123,255,0.1); background: var(--card-bg); }
  textarea.input-modern { resize: vertical; }
  
  .btn-modern { padding: 12px 24px; font-size: 14px; font-weight: 600; border-radius: 8px; cursor: pointer; transition: 0.2s; border: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Inter', sans-serif; }
  .btn-modern.solid { background: var(--primary-color); color: #fff; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
  .btn-modern.solid:hover { background: var(--primary-hover); transform: translateY(-1px); }
  
  .check-row-modern { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; font-weight: 600; color: var(--text-dark); background: var(--bg-color); padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border-color); }
  .check-row-modern input { width: 16px; height: 16px; accent-color: var(--primary-color); cursor: pointer; margin: 0; }
  .check-row-modern.small { font-size: 12px; padding: 4px 10px; }
  
  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr; }
    .form-mini-grid { grid-template-columns: 1fr; }
  }
</style>
</body>
</html>

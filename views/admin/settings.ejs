<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'settings' }) %>

  <div class="main">
    <div class="topbar">
      <h2>Pengaturan</h2>
      <div class="user-chip"><span class="dot"></span> Admin: <%= (typeof adminUser !== 'undefined' && adminUser) ? adminUser.username : 'admin' %></div>
    </div>

    <% if (typeof success !== 'undefined' && success) { %><div class="alert success"><%= success %></div><% } %>
    <% if (typeof accountError !== 'undefined' && accountError) { %><div class="alert error"><%= accountError %></div><% } %>

    <%
      const qris = config.qris || {};
      const telegram = config.telegram || {};
      const digiflazz = config.digiflazz || {};
      const currentAdmin = (typeof adminUser !== 'undefined' && adminUser) ? adminUser : {};
    %>

    <div class="grid grid-2 settings-grid">
      <div class="card">
        <h3>Identitas Website</h3>
        <form method="POST" action="/admin/settings">
          <label>Nama Website</label>
          <input type="text" name="siteName" required value="<%= config.siteName || '' %>">

          <label>Tagline</label>
          <input type="text" name="siteTagline" value="<%= config.siteTagline || '' %>">

          <label>Nomor WhatsApp Owner</label>
          <input type="text" name="ownerWhatsapp" placeholder="628xxxxxxxxxx" value="<%= config.ownerWhatsapp || '' %>">
          <div class="helper-text">Dipakai untuk tombol bantuan/kontak owner kalau ada di template.</div>

          <div class="section-title"><h3>Katalog</h3><div class="line"></div></div>

          <label>Kategori yang Ditampilkan di Katalog</label>
          <input type="text" name="catalogCategories" placeholder="Games" value="<%= (config.catalog && config.catalog.categories) ? config.catalog.categories.join(', ') : 'Games' %>">
          <div class="helper-text">Pisahkan dengan koma kalau lebih dari satu, misal: <code>Games, E-Money</code>. Kategori di luar daftar ini tidak akan tampil di halaman katalog user. Kosongkan untuk menampilkan Games saja (default).</div>

          <div class="section-title"><h3>QRIS</h3><div class="line"></div></div>

          <label>QR String Statis</label>
          <textarea name="qrString" placeholder="Tempel QR string merchant di sini"><%= qris.qrString || '' %></textarea>

          <label>Merchant Code</label>
          <input type="text" name="merchantCode" value="<%= qris.merchantCode || '' %>">

          <label>API Key Mutasi</label>
          <input type="text" name="apiKey" value="<%= qris.apiKey || '' %>">

          <div class="grid grid-3 form-mini-grid">
            <div>
              <label>Fee (%)</label>
              <input type="number" step="0.01" name="feePercent" value="<%= (typeof qris.feePercent !== 'undefined' && qris.feePercent !== null) ? qris.feePercent : 0.7 %>">
            </div>
            <div>
              <label>Minimal Deposit</label>
              <input type="number" name="depositMin" value="<%= qris.depositMin || 1000 %>">
            </div>
            <div>
              <label>Expired (menit)</label>
              <input type="number" name="expiredMinutes" value="<%= qris.expiredMinutes || 10 %>">
            </div>
          </div>

          <div class="section-title"><h3>Digiflazz (Auto Top Up Game)</h3><div class="line"></div></div>

          <label class="check-row"><input type="checkbox" name="digiflazzEnabled" <%= digiflazz.enabled ? 'checked' : '' %>> Aktifkan Auto Top Up via Digiflazz</label>

          <label>Username Digiflazz</label>
          <input type="text" name="digiflazzUsername" value="<%= digiflazz.username || '' %>">

          <label>API Key / Production Key</label>
          <input type="password" name="digiflazzApiKey" value="<%= digiflazz.apiKey || '' %>" autocomplete="new-password">
          <div class="helper-text">Ambil di dashboard Digiflazz (member.digiflazz.com) &rarr; menu Akun. Setelah diisi dan disimpan, atur produk game ke sumber "Auto Top Up via Digiflazz" di halaman Kelola Produk.</div>

          <div class="flex" style="align-items:center; gap:12px; margin-top:8px;">
            <button type="button" class="btn small ghost" id="cekSaldoDigiflazzBtn">Cek Saldo Digiflazz</button>
            <span id="saldoDigiflazzResult" class="helper-text"></span>
          </div>

          <div class="section-title"><h3>Banner Iklan & Teks Berjalan</h3><div class="line"></div></div>

          <%# MARQUEE %>
          <label class="check-row mt-16"><input type="checkbox" name="marqueeEnabled" <%= (config.marquee && config.marquee.enabled !== false) ? 'checked' : '' %>> Aktifkan teks berjalan (notifikasi / promo)</label>
          <label>Teks Berjalan</label>
          <textarea name="marqueeText" rows="2" placeholder="🔥 Promo Flash Sale! | ⚡ Stok terbaru sudah masuk"><%= (config.marquee && config.marquee.text) ? config.marquee.text : '' %></textarea>
          <div class="helper-text mt-16">Gunakan | (pipe) untuk memisah segmen teks.</div>

          <%# BANNER LIST %>
          <div class="section-title" style="margin-top:20px;"><h4>Daftar Banner</h4></div>
          <% const banners = config.banners || []; %>
          <% if (banners.length === 0) { %>
            <p style="color:var(--text-dim); font-size:13px;">Belum ada banner. Tambah banner di bawah.</p>
          <% } else { %>
            <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:12px;">
              <% banners.forEach((b, i) => { %>
                <div class="card" style="display:flex; align-items:center; gap:12px; padding:12px;">
                  <% if (b.image) { %>
                    <img src="<%= b.image %>" style="width:80px; height:44px; object-fit:cover; border-radius:6px; border:1px solid var(--border-glow);">
                  <% } else { %>
                    <div style="width:80px; height:44px; background:var(--bg-panel-2); border-radius:6px; display:flex; align-items:center; justify-content:center; color:var(--text-dim); font-size:11px;">No img</div>
                  <% } %>
                  <div style="flex:1; min-width:0;">
                    <div style="font-size:12px; font-weight:700;"><%= b.title || '(tanpa judul)' %></div>
                    <div style="font-size:11px; color:var(--text-dim); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= b.link || '(tanpa link)' %></div>
                  </div>
                  <form method="POST" action="/admin/settings/banner/delete/<%= b.id %>">
                    <button type="submit" class="btn small danger" onclick="return confirm('Hapus banner ini?')">Hapus</button>
                  </form>
                  <input type="hidden" name="bannerId[]" value="<%= b.id %>">
                  <input type="hidden" name="bannerLink[]" value="<%= b.link %>">
                  <input type="hidden" name="bannerTitle[]" value="<%= b.title %>">
                </div>
              <% }) %>
            </div>
          <% } %>

          <%# TAMBAH BANNER BARU %>
          <div class="card" style="padding:14px; margin-bottom:10px;">
            <div style="font-size:12px; font-weight:700; margin-bottom:10px; text-transform:uppercase; letter-spacing:.5px; color:var(--text-dim);">+ Tambah Banner Baru</div>
            <form method="POST" action="/admin/settings/banner/add" enctype="multipart/form-data" style="display:flex; flex-direction:column; gap:8px;">
              <label>Gambar Banner <span style="color:var(--text-dim); font-weight:400;">(JPG/PNG, max 3MB, rasio 2:1 direkomendasikan)</span></label>
              <input type="file" name="bannerImage" accept="image/*" required>
              <label>Link (URL tujuan saat banner diklik)</label>
              <input type="text" name="bannerLinkNew" placeholder="https://... atau /produk/id-produk">
              <label>Judul Banner</label>
              <input type="text" name="bannerTitleNew" placeholder="Promo Spesial">
              <button type="submit" class="btn small solid">Upload Banner</button>
            </form>
          </div>

          <div class="section-title"><h3>Popup Notifikasi Grup</h3><div class="line"></div></div>
          <div class="helper-text mt-16" style="margin-top:0;">Popup ini muncul sekali saat pengunjung pertama kali membuka aplikasi, mengajak mereka join grup. Pengguna bisa mencentang "Jangan tampilkan lagi" supaya tidak muncul terus.</div>

          <% const community = config.community || {}; %>
          <label class="check-row mt-16"><input type="checkbox" name="groupEnabled" <%= community.groupEnabled !== false ? 'checked' : '' %>> Aktifkan popup notifikasi grup</label>

          <label>Judul Popup</label>
          <input type="text" name="groupTitle" placeholder="Gabung Komunitas Kita!" value="<%= community.groupTitle || '' %>">

          <label>Pesan Popup</label>
          <textarea name="groupMessage" placeholder="Dapatkan info promo, update stok, dan bantuan tercepat lewat grup resmi kami."><%= community.groupMessage || '' %></textarea>

          <label>Link Grup (WhatsApp / Telegram)</label>
          <input type="text" name="groupLink" placeholder="https://chat.whatsapp.com/xxxxx" value="<%= community.groupLink || '' %>">

          <label>Teks Tombol</label>
          <input type="text" name="groupButtonText" placeholder="Gabung Sekarang" value="<%= community.groupButtonText || '' %>">

          <div class="section-title"><h3>Telegram</h3><div class="line"></div></div>

          <label>Bot Token</label>
          <input type="text" name="botToken" value="<%= telegram.botToken || '' %>">

          <label>Chat ID</label>
          <input type="text" name="chatId" value="<%= telegram.chatId || '' %>">

          <div class="toggle-list mt-16">
            <label class="check-row"><input type="checkbox" name="notifyOnDeposit" <%= telegram.notifyOnDeposit ? 'checked' : '' %>> Notifikasi deposit sukses</label>
            <label class="check-row"><input type="checkbox" name="notifyOnOrder" <%= telegram.notifyOnOrder ? 'checked' : '' %>> Notifikasi order masuk</label>
            <label class="check-row"><input type="checkbox" name="notifyOnRegister" <%= telegram.notifyOnRegister ? 'checked' : '' %>> Notifikasi user daftar</label>
          </div>

          <button class="btn solid mt-24" type="submit" style="width:100%;">Simpan Pengaturan</button>
        </form>

        <div class="section-title" style="margin-top:24px;"><h3>Backup Otomatis</h3><div class="line"></div></div>
        <div class="helper-text" style="margin-top:0;">Data (produk, order, user, config, dll) di-zip dan dikirim ke chat Telegram di atas setiap <b>5 jam sekali</b>. File zip di server otomatis dihapus setelah terkirim supaya tidak menumpuk.</div>
        <form method="POST" action="/admin/settings/backup/now" class="mt-16">
          <button type="submit" class="btn ghost" style="width:100%;"><i class="fa-solid fa-box-archive"></i> Backup Sekarang (Manual)</button>
        </form>
      </div>

      <div class="card account-card">
        <h3>Akun Admin</h3>
        <p class="helper-text">Ubah username dan password admin langsung dari panel ini. Masukkan password admin saat ini untuk konfirmasi.</p>

        <form method="POST" action="/admin/settings/account" autocomplete="off">
          <label>Username Admin Sekarang</label>
          <input type="text" value="<%= currentAdmin.username || '' %>" disabled>

          <label>Username Baru</label>
          <input type="text" name="newUsername" placeholder="Kosongkan jika tidak diganti" value="<%= currentAdmin.username || '' %>" autocomplete="new-password">
          <div class="helper-text">Boleh huruf, angka, titik, strip, dan underscore. Minimal 3 karakter.</div>

          <label>Password Admin Saat Ini</label>
          <input type="password" name="currentPassword" required placeholder="Wajib diisi untuk validasi" autocomplete="current-password">

          <label>Password Baru</label>
          <input type="password" name="newPassword" placeholder="Kosongkan jika tidak diganti" autocomplete="new-password">

          <label>Ulangi Password Baru</label>
          <input type="password" name="newPassword2" placeholder="Ulangi password baru" autocomplete="new-password">

          <button class="btn magenta mt-24" type="submit" style="width:100%;">Update Akun Admin</button>
        </form>

        <div class="alert success mt-24 account-note">
          Tips: setelah username/password berhasil diubah, login berikutnya pakai data baru.
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  (function () {
    var btn = document.getElementById('cekSaldoDigiflazzBtn');
    var result = document.getElementById('saldoDigiflazzResult');
    if (!btn || !result) return;
    btn.addEventListener('click', function () {
      result.textContent = 'Mengecek...';
      fetch('/admin/settings/digiflazz/saldo')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) { result.textContent = 'Gagal: ' + data.error; return; }
          result.textContent = 'Saldo: Rp ' + Number(data.deposit || 0).toLocaleString('id-ID');
        })
        .catch(function (err) { result.textContent = 'Gagal: ' + err.message; });
    });
  })();
</script>
</body>
</html>

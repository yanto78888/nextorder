<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'users' }) %>

  <div class="main no-bottom-nav">
    <div class="topbar"><h2>Kelola User</h2></div>

    <% if (typeof error !== 'undefined' && error) { %><div class="alert error"><%= error %></div><% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert" style="background:rgba(46,204,113,0.1); border:1px solid rgba(46,204,113,0.35); color:var(--success);"><%= success %></div>
    <% } %>

    <div class="card" style="margin-bottom:14px;">
      <input type="text" id="userSearchInput" placeholder="Cari username atau email..." style="width:100%;">
    </div>
    <div id="userSearchEmpty" class="card empty-state" style="display:none;">User "<span id="userSearchEmptyTerm"></span>" tidak ditemukan.</div>

    <div class="card">
      <table>
        <thead><tr><th>Username</th><th>Email</th><th>Saldo</th><th>Role</th><th>Member</th><th>Status</th><th>Aksi</th></tr></thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr data-user-row data-username="<%= u.username.toLowerCase() %>" data-email="<%= (u.email || '').toLowerCase() %>">
            <td><%= u.username %></td>
            <td><%= u.email || '-' %></td>
            <td class="mono">Rp <%= u.saldo.toLocaleString('id-ID') %></td>
            <td><span class="badge <%= u.role %>"><%= u.role %></span></td>
            <td><span class="badge member-<%= u.membership || 'reguler' %>"><%= (u.membership || 'reguler') %></span></td>
            <td><span class="badge <%= u.status === 'active' ? 'active' : 'cancelled' %>"><%= u.status %></span></td>
            <td>
              <div class="flex" style="flex-wrap:wrap;">
                <form method="POST" action="/admin/users/<%= u.id %>/saldo" class="flex">
                  <input type="number" name="amount" placeholder="+/- saldo" style="width:110px;">
                  <button class="btn small solid" type="submit">Set</button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/status">
                  <input type="hidden" name="status" value="<%= u.status === 'active' ? 'banned' : 'active' %>">
                  <button class="btn small <%= u.status === 'active' ? 'danger' : 'ghost' %>" type="submit">
                    <%= u.status === 'active' ? 'Blokir' : 'Aktifkan' %>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/role">
                  <input type="hidden" name="role" value="<%= u.role === 'admin' ? 'user' : 'admin' %>">
                  <button class="btn small ghost" type="submit">
                    Jadikan <%= u.role === 'admin' ? 'User' : 'Admin' %>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/membership" class="flex">
                  <select name="membership" style="width:110px;">
                    <% membershipList.forEach(t => { %>
                      <option value="<%= t.key %>" <%= (u.membership || 'reguler') === t.key ? 'selected' : '' %>><%= t.label %></option>
                    <% }) %>
                  </select>
                  <button class="btn small magenta" type="submit">Set Member</button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/password" class="flex" style="gap:4px;"
                      onsubmit="return confirm('Ganti password <%= u.username %>?');">
                  <input type="password" name="newPassword" placeholder="Password baru" minlength="6" style="width:100px;" required>
                  <input type="password" name="newPassword2" placeholder="Ulangi" minlength="6" style="width:90px;" required>
                  <button class="btn small ghost" type="submit">Ganti Password</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
(function () {
  var input = document.getElementById('userSearchInput');
  if (!input) return;
  var rows = document.querySelectorAll('[data-user-row]');
  var emptyBox = document.getElementById('userSearchEmpty');
  var emptyTerm = document.getElementById('userSearchEmptyTerm');

  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var visible = 0;
    rows.forEach(function (row) {
      var match = !q || row.dataset.username.includes(q) || row.dataset.email.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (emptyBox) {
      emptyBox.style.display = (q && visible === 0) ? '' : 'none';
      if (emptyTerm) emptyTerm.textContent = input.value.trim();
    }
  });
})();
</script>
</body>
</html>

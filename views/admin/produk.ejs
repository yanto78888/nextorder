<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/admin-sidebar', { active: 'produk' }) %>

  <div class="main no-bottom-nav">
    
    <div class="admin-header-modern">
      <h2><i class="fa-solid fa-boxes-stacked" style="color: var(--primary-color);"></i> Kelola Produk</h2>
    </div>

    <% if (success) { %><div class="alert success"><i class="fa-solid fa-circle-check"></i> <%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div><% } %>

    <!-- Form Tambah Produk Manual -->
    <div class="card card-modern mb-24">
      <h3 class="card-title-modern"><i class="fa-solid fa-circle-plus"></i> Tambah Produk Manual</h3>
      <p class="helper-text-modern mb-16">Produk otomatis (Digiflazz/IndoSMM) sebaiknya ditambahkan melalui menu integrasi masing-masing di sidebar.</p>
      
      <form method="POST" action="/admin/produk" enctype="multipart/form-data" class="mt-16">
        <div class="grid grid-2">
          
          <!-- Kolom Kiri: Info Dasar -->
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div class="form-group-modern">
              <label>Kategori (Games / Layanan)</label>
              <input type="text" name="category" class="input-modern" placeholder="Contoh: Mobile Legends" required list="categoryList">
              <datalist id="categoryList">
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>">
                <% }) %>
              </datalist>
            </div>
            
            <div class="form-group-modern">
              <label>Nama Produk / Layanan</label>
              <input type="text" name="name" class="input-modern" placeholder="Contoh: 86 Diamonds" required>
            </div>

            <div class="form-group-modern">
              <label>Stok Awal</label>
              <input type="number" name="stockCount" class="input-modern" min="0" value="100" required>
            </div>

            <div class="form-group-modern">
              <label>Foto / Ikon Produk (Opsional)</label>
              <input type="file" name="thumbnailFile" class="input-modern" style="padding: 7px 14px;" accept="image/png,image/jpeg,image/webp,image/gif">
            </div>
          </div>

          <!-- Kolom Kanan: Harga & Provider -->
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div class="grid grid-2 form-mini-grid">
              <div class="form-group-modern">
                <label>Harga Reguler (Rp)</label>
                <input type="number" name="price" class="input-modern" min="0" placeholder="0" required>
              </div>
              <div class="form-group-modern">
                <label>Harga Gold (Rp)</label>
                <input type="number" name="priceGold" class="input-modern" min="0" placeholder="0">
              </div>
            </div>

            <div class="form-group-modern">
              <label>Harga Platinum (Rp)</label>
              <input type="number" name="pricePlatinum" class="input-modern" min="0" placeholder="0">
            </div>

            <div class="form-group-modern">
              <label>Tipe Target / Form</label>
              <select name="targetType" class="input-modern">
                <option value="id">User ID & Zone ID (Standard Games)</option>
                <option value="link">Link / URL (Sosmed / Voucher)</option>
                <option value="custom">Data Custom (Notes)</option>
              </select>
            </div>

            <div class="form-group-modern">
              <label>Tipe Provider</label>
              <select name="provider" class="input-modern bg-gray" style="pointer-events: none;">
                <option value="manual" selected>Manual (Diproses Sendiri)</option>
              </select>
              <div class="helper-text-modern mt-1" style="font-size: 11px;">Tambahan provider otomatis via menu integrasi.</div>
            </div>
          </div>
        </div>

        <button class="btn-modern solid mt-24" type="submit" style="width: 100%;"><i class="fa-solid fa-floppy-disk"></i> Simpan Produk Manual</button>
      </form>
    </div>

    <!-- Tabel Semua Produk -->
    <div class="card card-modern">
      <div class="flex-between-modern mb-16">
        <h3 class="card-title-modern mb-0"><i class="fa-solid fa-list-ol"></i> Daftar Semua Produk (<%= products.length %>)</h3>
        
        <!-- Toolbar Filter -->
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <select id="filterCategory" class="input-modern mini" onchange="filterProducts()">
            <option value="">Semua Kategori</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
          <div class="search-input-wrapper">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="searchProduct" class="input-modern mini" placeholder="Cari nama produk..." onkeyup="filterProducts()">
          </div>
        </div>
      </div>

      <% if (products.length === 0) { %>
        <div class="empty-state-modern">
          <i class="fa-solid fa-box-open empty-icon"></i>
          <div>Belum ada produk satupun. Tambahkan di atas atau via integrasi.</div>
        </div>
      <% } else { %>
        <div class="table-responsive-modern">
          <table class="table-modern" id="productsTable">
            <thead>
              <tr>
                <th style="width: 50px;">Img</th>
                <th>Nama Produk & Kategori</th>
                <th>Tipe & Target</th>
                <th>Harga Jual (Reg)</th>
                <th>Stok</th>
                <th class="text-right">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(p => { %>
              <tr class="product-row" data-category="<%= p.category %>" data-name="<%= p.name.toLowerCase() %>">
                <td>
                  <div class="table-thumb">
                    <% if (p.thumbnail) { %>
                      <img src="<%= p.thumbnail %>" alt="Img" loading="lazy">
                    <% } else { %>
                      <div class="placeholder"><%= (p.name.charAt(0) || '?').toUpperCase() %></div>
                    <% } %>
                  </div>
                </td>
                <td>
                  <div class="font-medium"><%= p.name %></div>
                  <div class="helper-text-modern" style="font-size: 11px;"><i class="fa-solid fa-tag"></i> <%= p.category %></div>
                </td>
                <td>
                  <% if (p.provider === 'digiflazz') { %>
                    <span class="badge-modern df">Digiflazz</span>
                  <% } else if (p.provider === 'indosmm') { %>
                    <span class="badge-modern is">IndoSMM</span>
                  <% } else { %>
                    <span class="badge-modern neutral">Manual</span>
                  <% } %>
                  <div class="helper-text-modern mt-1" style="font-size: 11px;">Target: <%= p.targetType || 'id' %></div>
                </td>
                <td class="font-mono text-primary font-bold">Rp <%= p.price.toLocaleString('id-ID') %></td>
                <td>
                  <% if (p.provider === 'manual') { %>
                    <span class="badge-modern <%= p.stockCount > 0 ? 'completed' : 'danger' %>"><%= p.stockCount %> pcs</span>
                  <% } else { %>
                    <span class="badge-modern auto"><i class="fa-solid fa-bolt"></i> Auto</span>
                  <% } %>
                </td>
                <td class="text-right">
                  <div class="action-buttons-modern">
                    <a href="/admin/produk/<%= p.id %>/edit" class="btn-modern outline small">Edit</a>
                    <form method="POST" action="/admin/produk/<%= p.id %>/hapus" onsubmit="return confirm('Hapus produk ini secara permanen?')">
                      <button class="btn-modern danger small icon-only" type="submit" title="Hapus Produk"><i class="fa-solid fa-trash-can"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
  /* ADMIN PRODUK MODERN CSS STYLES */
  .admin-header-modern { margin-bottom: 24px; }
  .admin-header-modern h2 { font-size: 24px; font-weight: 800; color: var(--text-dark); display: flex; align-items: center; gap: 12px; margin: 0; }
  
  .card-modern { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: 24px; box-shadow: var(--shadow-sm); }
  .card-title-modern { font-size: 16px; font-weight: 700; color: var(--text-dark); display: flex; align-items: center; gap: 10px; margin: 0 0 8px 0; }
  
  .helper-text-modern { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
  .mt-1 { margin-top: 4px; }
  .mt-16 { margin-top: 16px; }
  .mt-24 { margin-top: 24px; }
  .mb-16 { margin-bottom: 16px; }
  .mb-24 { margin-bottom: 24px; }
  
  .form-group-modern { display: flex; flex-direction: column; gap: 6px; }
  .form-group-modern label { font-size: 13px; font-weight: 600; color: var(--text-dark); }
  
  .input-modern { padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 14px; background: var(--bg-color); color: var(--text-dark); transition: 0.2s; outline: none; width: 100%; box-sizing: border-box; }
  .input-modern:focus { border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(0,123,255,0.1); background: var(--card-bg); }
  .input-modern.mini { padding: 6px 12px; font-size: 13px; border-radius: 6px; }
  .bg-gray { background-color: #f1f5f9; color: #64748b; }
  
  .search-input-wrapper { position: relative; }
  .search-input-wrapper i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 12px; }
  .search-input-wrapper input { padding-left: 32px !important; }
  
  .btn-modern { padding: 10px 20px; font-size: 14px; font-weight: 600; border-radius: 8px; cursor: pointer; transition: 0.2s; border: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Inter', sans-serif; text-decoration: none; }
  .btn-modern.small { padding: 6px 12px; font-size: 12px; border-radius: 6px; }
  .btn-modern.solid { background: var(--primary-color); color: #fff; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
  .btn-modern.solid:hover { background: var(--primary-hover); transform: translateY(-1px); }
  .btn-modern.outline { background: transparent; color: var(--primary-color); border: 1px solid var(--primary-color); }
  .btn-modern.outline:hover { background: rgba(0,123,255,0.05); }
  .btn-modern.danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  .btn-modern.danger:hover { background: #ef4444; color: #fff; }
  .btn-modern.icon-only { padding: 6px; width: 30px; height: 30px; border-radius: 6px; }
  
  .table-responsive-modern { overflow-x: auto; width: 100%; border-radius: 12px; border: 1px solid var(--border-color); }
  .table-modern { width: 100%; border-collapse: collapse; text-align: left; background: var(--card-bg); font-size: 13px; }
  .table-modern th { background: var(--bg-color); padding: 14px 16px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-size: 11px; border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  .table-modern td { padding: 12px 16px; border-bottom: 1px solid var(--border-color); vertical-align: middle; }
  .table-modern tr:last-child td { border-bottom: none; }
  .table-modern tr:hover { background: rgba(0,0,0,0.01); }
  
  .table-thumb { width: 40px; height: 40px; border-radius: 8px; overflow: hidden; background: #fff; border: 1px solid var(--border-color); flex-shrink: 0; }
  .table-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .table-thumb .placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 800; color: #fff; background: var(--primary-color); }
  
  .font-mono { font-family: monospace; }
  .font-medium { font-weight: 600; color: var(--text-dark); }
  .font-bold { font-weight: 700; }
  .text-primary { color: var(--primary-color); }
  .text-right { text-align: right !important; }
  
  .badge-modern { padding: 4px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; line-height: 1; display: inline-flex; align-items: center; gap: 4px; white-space: nowrap; }
  .badge-modern.neutral { background: var(--bg-color); color: var(--text-muted); border: 1px solid var(--border-color); }
  .badge-modern.completed { background: rgba(34, 197, 94, 0.1); color: #16a34a; }
  .badge-modern.danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  .badge-modern.auto { background: rgba(14, 165, 233, 0.1); color: #0284c7; }
  .badge-modern.df { background: rgba(249, 115, 22, 0.1); color: #ea580c; border: 1px dashed rgba(249, 115, 22, 0.3); }
  .badge-modern.is { background: rgba(139, 92, 246, 0.1); color: #7c3aed; border: 1px dashed rgba(139, 92, 246, 0.3); }
  
  .action-buttons-modern { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }
  .flex-between-modern { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  
  .empty-state-modern { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 14px; background: var(--bg-color); border-radius: 12px; border: 1px dashed var(--border-color); }
  .empty-icon { font-size: 40px; margin-bottom: 16px; color: #cbd5e1; }
  
  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Filter ringan di sisi klien (Client-side filtering)
  function filterProducts() {
    const category = document.getElementById('filterCategory').value.toLowerCase();
    const search = document.getElementById('searchProduct').value.toLowerCase();
    const rows = document.querySelectorAll('.product-row');

    rows.forEach(row => {
      const rowCat = row.getAttribute('data-category').toLowerCase();
      const rowName = row.getAttribute('data-name');
      
      const matchCategory = category === "" || rowCat === category;
      const matchSearch = search === "" || rowName.includes(search);

      if (matchCategory && matchSearch) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }
</script>
</body>
</html>

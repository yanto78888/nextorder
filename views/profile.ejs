<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'profile' }) %>

  <div class="main">
    <div class="topbar"><h2>Profil Saya</h2></div>

    <% if (error) { %><div class="alert error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert success"><%= success %></div><% } %>

    <div class="card avatar-card">
      <div class="avatar-card-preview">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.username %>">
        <% } else { %>
          <span class="avatar-initial"><%= (user.username || '?').charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div class="avatar-card-form">
        <h3 style="margin-bottom:2px;">Foto Profil</h3>
        <div class="helper-text" style="margin-top:0;">JPG, PNG, WEBP, atau GIF, maksimal 2MB. Foto ini tampil bulat di pojok kanan atas.</div>
        <form method="POST" action="/profile/avatar" enctype="multipart/form-data" class="avatar-form">
          <input type="file" name="avatarFile" accept="image/jpeg,image/png,image/webp,image/gif" required>
          <button class="btn small solid mt-16" type="submit">Ganti Foto</button>
        </form>
      </div>
    </div>

    <div class="grid grid-3">
      <div class="card stat-card">
        <div class="label">Saldo Aktif</div>
        <div class="value">Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        <a href="/topup" class="btn small solid" style="align-self:flex-start;">+ Top Up</a>
      </div>
      <div class="card stat-card magenta">
        <div class="label">Total Order</div>
        <div class="value"><%= totalOrder %></div>
      </div>
      <div class="card stat-card success">
        <div class="label">Total Pembelanjaan</div>
        <div class="value">Rp <%= totalSpent.toLocaleString('id-ID') %></div>
      </div>
    </div>

    <div class="section-title"><h3>Order Terbaru</h3><div class="line"></div></div>
    <div class="card">
      <% if (recentOrders.length === 0) { %>
        <div class="empty-state">Belum ada order. <a href="/produk" style="color:var(--cyan)">Mulai belanja →</a></div>
      <% } else { %>
      <table>
        <thead><tr><th>ID</th><th>Produk</th><th>Total</th><th>Status</th><th>Tanggal</th></tr></thead>
        <tbody>
          <% recentOrders.forEach(o => { %>
          <tr>
            <td class="mono"><%= o.id %></td>
            <td><%= o.productName %></td>
            <td class="mono">Rp <%= o.total.toLocaleString('id-ID') %></td>
            <td><span class="badge <%= o.status %>"><%= o.status %></span></td>
            <td><%= new Date(o.createdAt).toLocaleString('id-ID') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <div class="section-title"><h3>Akun</h3><div class="line"></div></div>
    <div class="grid grid-2">
      <div class="card">
        <h3>Informasi Akun</h3>
        <form method="POST" action="/profile">
          <label>Username</label>
          <input type="text" value="<%= user.username %>" disabled>
          <label>Email</label>
          <input type="email" name="email" value="<%= user.email || '' %>">
          <label>Saldo</label>
          <input type="text" value="Rp <%= user.saldo.toLocaleString('id-ID') %>" disabled class="mono">
          <label>Status Member</label>
          <input type="text" value="<%= currentTier.icon %> <%= currentTier.label %>" disabled>
          <button class="btn solid mt-24" type="submit">Simpan Perubahan</button>
        </form>
      </div>

      <div class="card">
        <h3>Ganti Password</h3>
        <form method="POST" action="/profile/password">
          <label>Password Lama</label>
          <input type="password" name="oldPassword" required>
          <label>Password Baru</label>
          <input type="password" name="newPassword" required minlength="6">
          <label>Konfirmasi Password Baru</label>
          <input type="password" name="newPassword2" required minlength="6">
          <button class="btn magenta mt-24" type="submit">Update Password</button>
        </form>
      </div>
    </div>

    <div class="section-title"><h3>Membership</h3><div class="line"></div></div>
    <div class="grid grid-3">
      <% membershipList.filter(t => t.key !== 'reguler').forEach(t => { %>
        <div class="card member-card member-<%= t.key %>">
          <div class="member-card-icon"><%= t.icon %></div>
          <div class="member-card-title"><%= t.label %></div>
          <div class="member-card-price">Rp <%= t.price.toLocaleString('id-ID') %></div>
          <div class="member-card-benefit">Potongan <%= t.discountPercent %>% di setiap pembelian produk</div>

          <% if (currentTier.key === t.key) { %>
            <button class="btn small solid mt-16" type="button" disabled style="width:100%;">Member Aktif</button>
          <% } else if (currentTier.order > t.order) { %>
            <button class="btn small ghost mt-16" type="button" disabled style="width:100%;">Sudah Terlewati</button>
          <% } else { %>
            <form method="POST" action="/membership/upgrade">
              <input type="hidden" name="tier" value="<%= t.key %>">
              <button class="btn small magenta mt-16" type="submit" style="width:100%;">Upgrade Sekarang</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</div>
</body>
</html>

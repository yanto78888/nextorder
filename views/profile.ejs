<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    /* Style yang spesifik HANYA untuk layout profil */
    .avatar-card-preview { width: 80px; height: 80px; border-radius: 50%; background: var(--primary-color); color: white; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: bold; overflow: hidden; margin-right: 20px; flex-shrink: 0; }
    .avatar-card-preview img { width: 100%; height: 100%; object-fit: cover; }
    .profile-input { width: 100%; padding: 14px; border: 2px solid var(--border-color); border-radius: 8px; margin-bottom: 15px; box-sizing: border-box; transition: 0.3s; background: #fff; }
    .profile-input:focus { border-color: var(--primary-color); outline: none; box-shadow: 0 0 0 3px rgba(0,123,255,0.1); }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 24px; }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'profile' }) %>

  <div class="main no-bottom-nav">
    <div class="detail-section-title"><i class="fa-solid fa-user-gear"></i> Profil Saya</div>

    <% if (error) { %><div class="alert error" style="margin-bottom: 20px;"><%= error %></div><% } %>
    <% if (success) { %><div style="background:#f0fdf4; color:#059669; padding:15px; border-radius:8px; border: 1px solid #a7f3d0; margin-bottom: 20px;"><i class="fa-solid fa-circle-check"></i> <%= success %></div><% } %>

    <div class="card" style="display: flex; align-items: center;">
      <div class="avatar-card-preview">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.username %>">
        <% } else { %>
          <%= (user.username || '?').charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div style="flex: 1;">
        <h3 style="margin:0 0 5px 0; color: var(--text-dark);">Foto Profil</h3>
        <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 12px;">Format didukung: JPG, PNG, WEBP, atau GIF (Maks. 2MB).</div>
        <form method="POST" action="/profile/avatar" enctype="multipart/form-data" style="display: flex; gap: 10px; align-items: center;">
          <input type="file" name="danimaru" accept="image/jpeg,image/png,image/webp,image/gif" required style="font-size: 14px;">
          <button class="buy-main-btn" type="submit" style="padding: 10px 20px; width: auto; font-size: 14px;"><i class="fa-solid fa-upload"></i> Upload</button>
        </form>
      </div>
    </div>

    <div class="stat-grid">
      <div class="card" style="margin-bottom: 0; text-align: center;">
        <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: bold;">Saldo Aktif</div>
        <div style="font-size: 24px; font-weight: 900; color: var(--primary-color); margin: 8px 0;">Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        <a href="/topup" class="buy-main-btn" style="padding: 8px; font-size: 13px; display: inline-block; text-align: center; text-decoration: none;"><i class="fa-solid fa-plus"></i> Top Up Saldo</a>
      </div>
      <div class="card" style="margin-bottom: 0; text-align: center;">
        <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: bold;">Total Order</div>
        <div style="font-size: 24px; font-weight: 900; color: var(--text-dark); margin-top: 8px;"><%= totalOrder %></div>
      </div>
    </div>

    <div class="detail-section-title"><i class="fa-solid fa-shield-halved"></i> Pengaturan Akun</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 40px;">
      <div class="card" style="margin-bottom: 0;">
        <h3 style="margin-top: 0; color: var(--text-dark);">Informasi Pribadi</h3>
        <form method="POST" action="/profile">
          <label style="font-size:13px; font-weight:600; color:var(--text-muted); display:block; margin-bottom:6px;">Username</label>
          <input type="text" class="profile-input" value="<%= user.username %>" disabled>
          
          <label style="font-size:13px; font-weight:600; color:var(--text-muted); display:block; margin-bottom:6px;">Email</label>
          <input type="email" name="email" class="profile-input" value="<%= user.email || '' %>">
          
          <label style="font-size:13px; font-weight:600; color:var(--text-muted); display:block; margin-bottom:6px;">Status Member</label>
          <input type="text" class="profile-input" value="<%= currentTier.icon %> <%= currentTier.label %>" disabled>
          
          <button class="buy-main-btn" type="submit" style="padding: 12px; font-size: 15px;"><i class="fa-solid fa-floppy-disk"></i> Simpan</button>
        </form>
      </div>

      <div class="card" style="margin-bottom: 0;">
        <h3 style="margin-top: 0; color: var(--text-dark);"><%= user.password ? 'Keamanan' : 'Buat Password' %></h3>
        <form method="POST" action="/profile/password">
          <% if (user.password) { %>
          <label style="font-size:13px; font-weight:600; color:var(--text-muted); display:block; margin-bottom:6px;">Password Lama</label>
          <input type="password" name="oldPassword" class="profile-input" required>
          <% } %>
          
          <label style="font-size:13px; font-weight:600; color:var(--text-muted); display:block; margin-bottom:6px;">Password Baru</label>
          <input type="password" name="newPassword" class="profile-input" required minlength="6">
          
          <button class="buy-main-btn" type="submit" style="padding: 12px; font-size: 15px; background: var(--text-dark);"><i class="fa-solid fa-lock"></i> <%= user.password ? 'Update Password' : 'Buat Password' %></button>
        </form>
      </div>
    </div>

    <%- include('partials/footer') %>
  </div>
</div>
</body>
</html>

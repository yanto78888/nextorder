<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    :root {
      --adm-bg: #0f172a;
      --adm-card-bg: #1e293b;
      --adm-border: #334155;
      --adm-text: #f8fafc;
      --adm-muted: #94a3b8;
      --adm-primary: #3b82f6;
    }
    body {
      background-color: var(--adm-bg);
      color: var(--adm-text);
      font-family: 'Inter', sans-serif;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .auth-wrap {
      width: 100%;
      max-width: 420px;
      padding: 20px;
    }
    .auth-card {
      background: var(--adm-card-bg);
      border: 1px solid var(--adm-border);
      border-radius: 20px;
      padding: 32px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }
    .auth-title {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--adm-text);
    }
    .auth-title i { color: var(--adm-primary); }
    .auth-sub {
      font-size: 13px;
      color: var(--adm-muted);
      margin-bottom: 24px;
    }
    .alert.error {
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #fca5a5;
      padding: 12px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 16px;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--adm-muted);
      margin-bottom: 6px;
      margin-top: 14px;
    }
    input[type="text"], input[type="email"], input[type="password"] {
      width: 100%;
      padding: 12px 16px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--adm-border);
      border-radius: 10px;
      color: var(--adm-text);
      font-size: 14px;
      box-sizing: border-box;
      transition: 0.2s;
    }
    input:focus {
      outline: none;
      border-color: var(--adm-primary);
      background: rgba(255,255,255,0.05);
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 20px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: 0.2s;
    }
    .btn.solid {
      background: var(--adm-primary);
      color: #fff;
    }
    .btn.solid:hover { opacity: 0.9; }
    .google-btn {
      background: #fff;
      color: #1e293b;
      width: 100%;
      box-sizing: border-box;
    }
    .google-btn:hover { background: #f1f5f9; }
    .auth-divider {
      display: flex;
      align-items: center;
      text-align: center;
      margin: 20px 0;
      color: var(--adm-muted);
      font-size: 12px;
    }
    .auth-divider::before, .auth-divider::after {
      content: '';
      flex: 1;
      border-bottom: 1px solid var(--adm-border);
    }
    .auth-divider span { padding: 0 10px; }
    .mt-24 { margin-top: 24px; }
    .auth-footer {
      text-align: center;
      margin-top: 24px;
      font-size: 13px;
      color: var(--adm-muted);
    }
    .auth-footer a {
      color: var(--adm-primary);
      text-decoration: none;
      font-weight: 600;
    }
    .auth-footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <h1 class="auth-title"><i class="fa-solid fa-bolt"></i> Daftar Akun</h1>
      <div class="auth-sub"><%= config.siteName %></div>

      <% if (error) { %><div class="alert error"><%= error %></div><% } %>

      <% const googleLoginReady = !!(config.google && config.google.enabled && config.google.clientId && config.google.clientSecret); %>
      <% if (googleLoginReady) { %>
      <a href="/auth/google" class="btn google-btn"><i class="fa-brands fa-google"></i> Daftar dengan Google</a>
      <div class="auth-divider"><span>atau</span></div>
      <% } %>

      <form method="POST" action="/register">
        <label>Username</label>
        <input type="text" name="username" required autofocus>
        <label>Email (opsional)</label>
        <input type="email" name="email">
        <label>Password</label>
        <input type="password" name="password" required minlength="6">
        <label>Konfirmasi Password</label>
        <input type="password" name="password2" required minlength="6">
        <button class="btn solid mt-24" type="submit" style="width:100%;">Buat Akun</button>
      </form>

      <div class="auth-footer">Sudah punya akun? <a href="/login">Masuk di sini</a></div>
    </div>
  </div>
</body>
</html>

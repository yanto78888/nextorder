<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'jasa-sosmed', user, config }) %>

  <div class="main produk-main no-bottom-nav">

    <div class="topbar" style="margin-bottom: 12px;">
      <h2 style="margin:0;"><i class="fa-solid fa-share-nodes"></i> Jasa Sosmed</h2>
      <div class="flex" style="gap:8px; margin-left:auto;">
        <% if (user) { %>
          <div class="user-chip"><span class="dot"></span> Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        <% } else { %>
          <a href="/login" class="user-chip guest-chip"><span class="dot guest"></span> Masuk / Daftar</a>
        <% } %>
      </div>
    </div>

    <div class="helper-text" style="margin-bottom:14px;">Followers, likes, views, dan layanan sosial media lainnya. Isi link postingan/profil dan jumlah yang diinginkan, proses otomatis oleh sistem.</div>

    <% if (rows.length > 0) { %>
    <div class="cat-tabs" id="catTabs">
      <button type="button" class="cat-tab active" data-cat="all"><i class="fa-solid fa-table-cells-large"></i> Semua</button>
      <% rows.forEach(row => { %>
        <button type="button" class="cat-tab" data-cat="<%= row.category %>"><i class="fa-solid fa-share-nodes"></i> <%= row.category %></button>
      <% }) %>
    </div>

    <div class="catalog-search-bar">
      <input type="text" id="produkSearchInput" placeholder="Cari layanan...">
      <button type="button" class="catalog-search-btn" id="catalogSearchBtn" aria-label="Cari layanan"><i class="fa-solid fa-magnifying-glass"></i></button>
    </div>
    <div id="produkSearchEmpty" class="card empty-state" style="display:none;">Layanan "<span id="produkSearchEmptyTerm"></span>" tidak ditemukan.</div>
    <% } %>

    <% if (!user) { %>
      <div class="alert guest-alert"><i class="fa-solid fa-hand"></i> Kamu sedang menjelajah sebagai <b>Tamu</b>. Silakan <a href="/login" style="color:var(--cyan); text-decoration:underline;">masuk</a> atau <a href="/register" style="color:var(--cyan); text-decoration:underline;">daftar</a> untuk melakukan pemesanan.</div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert error"><%= error %></div><% } %>

    <% if (products.length === 0) { %>
      <div class="card empty-state">Belum ada layanan tersedia saat ini.</div>
    <% } else { %>
      <% rows.forEach(row => { %>
        <div class="nf-row" data-row data-category="<%= row.category %>">
          <div class="nf-row-title"><i class="fa-solid fa-share-nodes"></i> <%= row.category %></div>
          <div class="nf-row-track">
            <% row.products.forEach((p, idx) => { %>
              <a href="/jasa-sosmed/<%= p.id %>" class="nf-card nf-card-link game-card <%= idx >= 9 ? 'nf-card-extra' : '' %>" data-name="<%= p.name.toLowerCase() %>">
                <div class="nf-card-thumb">
                  <span class="nf-noimg"><i class="fa-solid fa-share-nodes"></i></span>
                  <span class="nf-stock-tag ok"><i class="fa-solid fa-bolt"></i></span>
                </div>
                <div class="nf-card-body">
                  <div class="nf-card-name"><%= p.name %></div>
                  <div class="nf-rating">
                    <span class="helper-text" style="margin:0;">Min <%= (p.indosmmMin||0).toLocaleString('id-ID') %> - Maks <%= (p.indosmmMax||0).toLocaleString('id-ID') %></span>
                    <% if (p.totalSold) { %><span class="nf-sold"><%= p.totalSold.toLocaleString('id-ID') %> terjual</span><% } %>
                  </div>
                  <div class="nf-card-price">
                    <span class="nf-price-now">Rp <%= p.finalPrice.toLocaleString('id-ID') %> <span style="font-size:11px; font-weight:400; color:var(--text-dim);">/1000</span></span>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
          <% if (row.products.length > 9) { %>
            <button type="button" class="nf-row-more" data-total="<%= row.products.length %>">
              <span class="nf-row-more-text">Lihat Semua (<%= row.products.length %>)</span>
              <i class="fa-solid fa-chevron-down nf-row-more-icon"></i>
            </button>
          <% } %>
        </div>
      <% }) %>
    <% } %>

    <%- include('partials/footer') %>
  </div>
</div>

<script>
// ===== TAB KATEGORI (filter tanpa reload) =====
(function () {
  var tabs = document.querySelectorAll('.cat-tab');
  var rows = document.querySelectorAll('[data-row]');
  var searchInput = document.getElementById('produkSearchInput');
  if (!tabs.length) return;

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) { t.classList.remove('active'); });
      tab.classList.add('active');
      if (searchInput) searchInput.value = '';
      var emptyBox = document.getElementById('produkSearchEmpty');
      if (emptyBox) emptyBox.style.display = 'none';

      var cat = tab.dataset.cat;
      rows.forEach(function (row) {
        row.style.display = (cat === 'all' || row.dataset.category === cat) ? '' : 'none';
        row.querySelectorAll('.nf-card').forEach(function (card) { card.style.display = ''; });
        row.classList.remove('expanded');
        var moreBtn = row.querySelector('.nf-row-more');
        if (moreBtn) {
          moreBtn.style.display = '';
          var textEl = moreBtn.querySelector('.nf-row-more-text');
          if (textEl) textEl.textContent = 'Lihat Semua (' + moreBtn.dataset.total + ')';
        }
      });
    });
  });
})();

// ===== SEARCH LAYANAN (live filter) =====
(function () {
  var input = document.getElementById('produkSearchInput');
  if (!input) return;
  var rows = document.querySelectorAll('[data-row]');
  var emptyBox = document.getElementById('produkSearchEmpty');
  var emptyTerm = document.getElementById('produkSearchEmptyTerm');
  var tabs = document.querySelectorAll('.cat-tab');
  var searchBtn = document.getElementById('catalogSearchBtn');
  if (searchBtn) searchBtn.addEventListener('click', function () { input.focus(); });

  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var totalVisible = 0;
    if (q && tabs.length) {
      tabs.forEach(function (t) { t.classList.toggle('active', t.dataset.cat === 'all'); });
    }
    rows.forEach(function (row) {
      var cards = row.querySelectorAll('.nf-card');
      var visibleInRow = 0;
      cards.forEach(function (card) {
        var match = !q || (card.dataset.name || '').includes(q);
        card.style.display = match ? '' : 'none';
        if (match) { visibleInRow++; totalVisible++; }
      });
      row.style.display = visibleInRow > 0 ? '' : 'none';
      row.classList.toggle('expanded', !!q);
      var moreBtn = row.querySelector('.nf-row-more');
      if (moreBtn) {
        moreBtn.style.display = q ? 'none' : '';
        if (!q) {
          var textEl = moreBtn.querySelector('.nf-row-more-text');
          if (textEl) textEl.textContent = 'Lihat Semua (' + moreBtn.dataset.total + ')';
        }
      }
    });
    if (emptyBox) {
      emptyBox.style.display = (q && totalVisible === 0) ? '' : 'none';
      if (emptyTerm) emptyTerm.textContent = input.value.trim();
    }
  });
})();

// ===== LIPAT / TAMPILKAN SEMUA per kategori =====
(function () {
  var moreButtons = document.querySelectorAll('.nf-row-more');
  moreButtons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var row = btn.closest('.nf-row');
      if (!row) return;
      var expanded = row.classList.toggle('expanded');
      var textEl = btn.querySelector('.nf-row-more-text');
      if (textEl) textEl.textContent = expanded ? 'Tampilkan Lebih Sedikit' : ('Lihat Semua (' + btn.dataset.total + ')');
      if (!expanded) row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
})();
</script>
</body>
</html>

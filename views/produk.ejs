<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk', user, config }) %>

  <div class="main produk-main no-bottom-nav">

    <!-- Topbar info baris atas: badge member + saldo/tamu -->
    <div class="topbar" style="margin-bottom: 12px;">
      <div class="flex" style="gap:8px; margin-left:auto;">
        <% if (user && (user.membership || 'reguler') !== 'reguler') { %>
          <span class="badge member-<%= user.membership %>"><%- user.membership === 'platinum' ? '<i class="fa-solid fa-gem"></i> Platinum' : '<i class="fa-solid fa-medal"></i> Gold' %></span>
        <% } %>
        <% if (user) { %>
          <div class="user-chip"><span class="dot"></span> Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        <% } else { %>
          <a href="/login" class="user-chip guest-chip"><span class="dot guest"></span> Masuk / Daftar</a>
        <% } %>
      </div>
    </div>

    <!-- ====== TAB KATEGORI (filter produk per kategori, tanpa reload) ====== -->
    <div class="cat-tabs" id="catTabs">
      <button type="button" class="cat-tab active" data-cat="all"><i class="fa-solid fa-table-cells-large"></i> Semua</button>
      <% rows.forEach(row => { %>
        <button type="button" class="cat-tab" data-cat="<%= row.category %>"><i class="fa-solid fa-gamepad"></i> <%= row.category %></button>
      <% }) %>
    </div>

    <!-- ====== SEARCH PRODUK (pill + tombol bulat) ====== -->
    <div class="catalog-search-bar">
      <input type="text" id="produkSearchInput" placeholder="Cari produk atau game...">
      <button type="button" class="catalog-search-btn" id="catalogSearchBtn" aria-label="Cari produk"><i class="fa-solid fa-magnifying-glass"></i></button>
    </div>

    <div id="produkSearchEmpty" class="card empty-state" style="display:none;">Produk "<span id="produkSearchEmptyTerm"></span>" tidak ditemukan.</div>

    <!-- ====== TEKS BERJALAN (MARQUEE) ====== -->
    <% if (marquee && marquee.enabled !== false && marquee.text) { %>
    <div class="marquee-wrap">
      <div class="marquee-label"><i class="fa-solid fa-bullhorn"></i></div>
      <div class="marquee-track">
        <div class="marquee-content" id="marqueeContent">
          <%= marquee.text %>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<%= marquee.text %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- ====== BANNER SLIDER ====== -->
    <% if (banners && banners.length > 0) { %>
    <div class="banner-slider" id="bannerSlider">
      <div class="banner-track" id="bannerTrack">
        <% banners.forEach((b, i) => { %>
          <% if (b.link) { %>
            <a href="<%= b.link %>" class="banner-slide" target="<%= b.link.startsWith('http') ? '_blank' : '_self' %>" rel="noopener">
              <img src="<%= b.image %>" alt="<%= b.title || 'Banner' %>" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
              <% if (b.title) { %><div class="banner-caption"><%= b.title %></div><% } %>
            </a>
          <% } else { %>
            <div class="banner-slide">
              <img src="<%= b.image %>" alt="<%= b.title || 'Banner' %>" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
              <% if (b.title) { %><div class="banner-caption"><%= b.title %></div><% } %>
            </div>
          <% } %>
        <% }) %>
      </div>
      <% if (banners.length > 1) { %>
        <button class="banner-prev" id="bannerPrev" aria-label="Sebelumnya">‹</button>
        <button class="banner-next" id="bannerNext" aria-label="Berikutnya">›</button>
        <div class="banner-dots" id="bannerDots">
          <% banners.forEach((b, i) => { %>
            <span class="banner-dot <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"></span>
          <% }) %>
        </div>
      <% } %>
    </div>
    <% } %>

    <!-- Quick actions: Deposit & Riwayat -->
    <div class="quick-actions">
      <% if (user) { %>
        <a href="/topup" class="quick-action-btn qa-deposit">
          <span class="qa-icon"><i class="fa-solid fa-credit-card"></i></span>
          <span class="qa-label">Deposit</span>
        </a>
        <a href="/riwayat" class="quick-action-btn qa-riwayat">
          <span class="qa-icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
          <span class="qa-label">Riwayat</span>
        </a>
        <a href="/profile" class="quick-action-btn qa-profile">
          <span class="qa-icon"><i class="fa-solid fa-user"></i></span>
          <span class="qa-label">Profil</span>
        </a>
      <% } else { %>
        <a href="/login" class="quick-action-btn qa-deposit">
          <span class="qa-icon"><i class="fa-solid fa-credit-card"></i></span><span class="qa-label">Deposit</span>
        </a>
        <a href="/login" class="quick-action-btn qa-riwayat">
          <span class="qa-icon"><i class="fa-solid fa-clock-rotate-left"></i></span><span class="qa-label">Riwayat</span>
        </a>
        <a href="/login" class="quick-action-btn qa-profile">
          <span class="qa-icon"><i class="fa-solid fa-key"></i></span><span class="qa-label">Masuk</span>
        </a>
      <% } %>
    </div>

    <% if (!user) { %>
      <div class="alert guest-alert"><i class="fa-solid fa-hand"></i> Kamu sedang menjelajah sebagai <b>Tamu</b>. Silakan <a href="/login" style="color:var(--cyan); text-decoration:underline;">masuk</a> atau <a href="/register" style="color:var(--cyan); text-decoration:underline;">daftar</a> untuk melakukan pemesanan.</div>
    <% } %>

    <% if (memberDiscount > 0) { %>
      <div class="alert member-alert">
        <i class="fa-solid <%= user.membership === 'platinum' ? 'fa-gem' : 'fa-medal' %>"></i> Kamu member <b><%= user.membership %></b>, potongan <b><%= memberDiscount %>%</b> di setiap pembelian
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %><div class="alert error"><%= error %></div><% } %>

    <!-- Katalog produk per kategori -->
    <% if (products.length === 0) { %>
      <div class="card empty-state">Belum ada produk tersedia saat ini.</div>
    <% } else { %>
      <% rows.forEach(row => { %>
        <div class="nf-row" data-row data-category="<%= row.category %>">
          <div class="nf-row-title"><i class="fa-solid fa-gamepad"></i> <%= row.category %></div>
          <div class="nf-row-track">
            <% row.products.forEach(p => { %>
              <a href="/produk/<%= p.id %>" class="nf-card nf-card-link game-card" data-name="<%= p.name.toLowerCase() %>">
                <div class="nf-card-thumb">
                  <% if (p.thumbnail) { %><img src="<%= p.thumbnail %>" alt="<%= p.name %>"><% } else { %><span class="nf-noimg"><%= p.name.slice(0,1) %></span><% } %>
                  <% if (p.isVariantGroup) { %>
                    <span class="nf-stock-tag ok"><%= p.variantCount %> pilihan</span>
                  <% } else { %>
                    <% /* Produk Digiflazz dikirim otomatis oleh sistem, jadi selalu dianggap tersedia — gak ngandelin stockItems manual yang memang sengaja kosong. */ %>
                    <% const isAuto = p.provider === 'digiflazz'; %>
                    <% const stockCount = p.stockItems ? p.stockItems.length : 0; %>
                    <% const available = isAuto || stockCount > 0; %>
                    <span class="nf-stock-tag <%= available ? 'ok' : 'warn' %>"><%- available ? '<i class="fa-solid fa-bolt"></i>' : '<i class="fa-solid fa-screwdriver-wrench"></i>' %></span>
                  <% } %>
                  <% if (p.gamePreset && p.gamePreset !== 'none') { %><span class="game-icon-badge"><i class="fa-solid <%= p.icon %>"></i></span><% } %>
                </div>
                <div class="nf-card-body">
                  <div class="nf-card-name"><%= p.name %></div>
                  <div class="nf-rating">
                    <% const r = Math.round(p.rating || 0); for(let i=1;i<=5;i++){ %><span class="nf-star <%= i<=r?'on':'' %>">★</span><% } %>
                    <span class="nf-rating-num"><%= (p.rating||0).toFixed(1) %></span>
                    <% if (p.totalSold) { %><span class="nf-sold"><%= p.totalSold %> terjual</span><% } %>
                  </div>
                  <div class="nf-card-price">
                    <% if (p.isVariantGroup) { %>
                      <span class="nf-price-now">Mulai Rp <%= p.finalPrice.toLocaleString('id-ID') %></span>
                    <% } else { %>
                      <% if (p.finalPrice < p.price) { %>
                        <span class="nf-price-old">Rp <%= p.price.toLocaleString('id-ID') %></span>
                      <% } %>
                      <span class="nf-price-now">Rp <%= p.finalPrice.toLocaleString('id-ID') %></span>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } %>

  </div>
</div>

<script>
// ===== BANNER SLIDER =====
(function () {
  var track = document.getElementById('bannerTrack');
  var prevBtn = document.getElementById('bannerPrev');
  var nextBtn = document.getElementById('bannerNext');
  var dots = document.querySelectorAll('.banner-dot');
  if (!track) return;

  var slides = track.querySelectorAll('.banner-slide');
  var total = slides.length;
  if (total <= 1) return;

  var current = 0;
  var autoTimer;

  function goTo(idx) {
    current = (idx + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) { d.classList.toggle('active', i === current); });
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(next, 4500);
  }

  if (prevBtn) prevBtn.addEventListener('click', function () { prev(); resetAuto(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { next(); resetAuto(); });
  dots.forEach(function (d) {
    d.addEventListener('click', function () { goTo(parseInt(d.dataset.idx)); resetAuto(); });
  });

  // Touch swipe
  var startX = 0;
  track.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { diff > 0 ? next() : prev(); resetAuto(); }
  }, { passive: true });

  resetAuto();
})();

// ===== TAB KATEGORI (filter produk per kategori, tanpa reload) =====
(function () {
  var tabs = document.querySelectorAll('.cat-tab');
  var rows = document.querySelectorAll('[data-row]');
  var searchInput = document.getElementById('produkSearchInput');
  if (!tabs.length) return;

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) { t.classList.remove('active'); });
      tab.classList.add('active');

      // Pindah tab = mulai dari tampilan bersih, biar gak ketimpa sisa filter search sebelumnya
      if (searchInput) searchInput.value = '';
      var emptyBox = document.getElementById('produkSearchEmpty');
      if (emptyBox) emptyBox.style.display = 'none';

      var cat = tab.dataset.cat;
      rows.forEach(function (row) {
        row.style.display = (cat === 'all' || row.dataset.category === cat) ? '' : 'none';
        row.querySelectorAll('.nf-card').forEach(function (card) { card.style.display = ''; });
      });
    });
  });
})();

// ===== SEARCH PRODUK (live filter, tanpa reload) =====
(function () {
  var input = document.getElementById('produkSearchInput');
  if (!input) return;
  var rows = document.querySelectorAll('[data-row]');
  var emptyBox = document.getElementById('produkSearchEmpty');
  var emptyTerm = document.getElementById('produkSearchEmptyTerm');
  var tabs = document.querySelectorAll('.cat-tab');

  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var totalVisible = 0;

    // Lagi ngetik cari = jelajah lintas kategori, jadi tab balik ke "Semua"
    if (q && tabs.length) {
      tabs.forEach(function (t) { t.classList.toggle('active', t.dataset.cat === 'all'); });
    }

    rows.forEach(function (row) {
      var cards = row.querySelectorAll('.nf-card');
      var visibleInRow = 0;
      cards.forEach(function (card) {
        var match = !q || (card.dataset.name || '').includes(q);
        card.style.display = match ? '' : 'none';
        if (match) { visibleInRow++; totalVisible++; }
      });
      row.style.display = visibleInRow > 0 ? '' : 'none';
    });

    if (emptyBox) {
      emptyBox.style.display = (q && totalVisible === 0) ? '' : 'none';
      if (emptyTerm) emptyTerm.textContent = input.value.trim();
    }
  });
})();
</script>
</body>
</html>

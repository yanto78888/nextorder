<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk' }) %>

  <div class="main">
    <div class="topbar">
      <h2>Katalog Produk</h2>
      <div class="flex" style="gap:8px;">
        <% if ((user.membership || 'reguler') !== 'reguler') { %>
          <span class="badge member-<%= user.membership %>"><%= user.membership === 'platinum' ? '💎 Platinum' : '🥇 Gold' %></span>
        <% } %>
        <div class="user-chip"><span class="dot"></span> Rp <%= user.saldo.toLocaleString('id-ID') %></div>
      </div>
    </div>

    <% if (memberDiscount > 0) { %>
      <div class="alert member-alert">
        <%= user.membership === 'platinum' ? '💎' : '🥇' %> Kamu member <b><%= user.membership %></b>, setiap produk dapat potongan <b>Rp <%= memberDiscount.toLocaleString('id-ID') %></b>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %><div class="alert error"><%= error %></div><% } %>

    <% if (products.length === 0) { %>
      <div class="card empty-state">Belum ada produk tersedia saat ini.</div>
    <% } else { %>

      <% rows.forEach(row => { %>
        <div class="nf-row">
          <div class="nf-row-title"><%= row.category %></div>
          <div class="nf-row-track">
            <% row.products.forEach(p => { %>
              <div class="nf-card">
                <div class="nf-card-thumb">
                  <% if (p.thumbnail) { %><img src="<%= p.thumbnail %>" alt="<%= p.name %>"><% } else { %><span class="nf-noimg"><%= p.name.slice(0,1) %></span><% } %>
                  <% const stockCount = p.stockItems ? p.stockItems.length : 0; %>
                  <span class="nf-stock-tag <%= stockCount > 0 ? 'ok' : 'warn' %>"><%= stockCount > 0 ? '⚡ Auto' : '🛠 Manual' %></span>
                </div>
                <div class="nf-card-body">
                  <div class="nf-card-name"><%= p.name %></div>
                  <div class="nf-card-desc"><%= p.description %></div>
                  <div class="nf-card-price">
                    <% if (p.finalPrice < p.price) { %>
                      <span class="nf-price-old">Rp <%= p.price.toLocaleString('id-ID') %></span>
                    <% } %>
                    <span class="nf-price-now">Rp <%= p.finalPrice.toLocaleString('id-ID') %></span>
                  </div>
                  <form method="POST" action="/order" class="flex" style="margin-top:8px;">
                    <input type="hidden" name="productId" value="<%= p.id %>">
                    <input type="number" name="qty" value="1" min="1" style="width:60px;">
                    <button type="submit" class="btn small solid" style="flex:1;">Beli</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>

    <% } %>
  </div>
</div>
</body>
</html>

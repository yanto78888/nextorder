<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <!-- ==========================================
       UI OVERHAUL: STYLING MODERN (ALA CODASHOP)
       ========================================== -->
  <style>
    /* Reset & Base Variables */
    :root {
      --primary-color: #007bff;
      --primary-hover: #0056b3;
      --secondary-color: #10b981;
      --bg-color: #f4f7fa;
      --card-bg: #ffffff;
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --border-color: #e2e8f0;
      --shadow-sm: 0 2px 10px rgba(0,0,0,0.03);
      --shadow-md: 0 8px 25px rgba(0,0,0,0.06);
      --border-radius: 16px;
    }

    body { background-color: var(--bg-color); color: var(--text-dark); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    
    /* Layout Container */
    .detail-main { max-width: 1000px; margin: 0 auto; padding-bottom: 80px; }
    
    /* Hero Section */
    .detail-hero { position: relative; height: 260px; border-radius: 0 0 30px 30px; overflow: hidden; box-shadow: var(--shadow-md); margin-bottom: 30px; background: #000; }
    .detail-thumb { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; filter: blur(2px); transition: 0.3s; }
    .detail-hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); }
    .detail-back-btn { position: absolute; top: 20px; left: 20px; color: #fff; text-decoration: none; font-weight: 600; background: rgba(0,0,0,0.4); padding: 8px 16px; border-radius: 20px; backdrop-filter: blur(5px); transition: 0.2s; z-index: 10; }
    .detail-back-btn:hover { background: var(--primary-color); }
    
    /* Bodi Halaman */
    .detail-body { padding: 0 20px; margin-top: -80px; position: relative; z-index: 5; }

    /* Header Produk (Judul & Meta) */
    .detail-title { font-size: 28px; font-weight: 800; color: #fff; margin: 0 0 10px 0; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
    .detail-meta-row { margin-bottom: 8px; }
    .nf-stock-tag { padding: 4px 10px; border-radius: 8px; font-size: 12px; font-weight: bold; display: inline-flex; align-items: center; gap: 5px; }
    .nf-stock-tag.ok { background: #10b981; color: #fff; }
    .nf-stock-tag.warn { background: #f59e0b; color: #fff; }
    .detail-category { background: rgba(255,255,255,0.2); color: #fff; padding: 4px 10px; border-radius: 8px; font-size: 12px; backdrop-filter: blur(4px); margin-left: 5px; }

    /* Rating Bintang */
    .rating-row { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
    .star { color: #d1d5db; font-size: 18px; }
    .star.filled { color: #fbbf24; }
    .rating-score { color: #fff; font-weight: 700; font-size: 16px; }
    .rating-count { color: #cbd5e1; font-size: 14px; }

    /* Stats Grid */
    .detail-stats-row { display: flex; justify-content: space-between; background: var(--card-bg); padding: 20px; border-radius: var(--border-radius); box-shadow: var(--shadow-sm); margin-bottom: 24px; text-align: center; }
    .detail-stat { flex: 1; }
    .detail-stat-val { font-size: 18px; font-weight: 700; color: var(--text-dark); margin-bottom: 4px; }
    .detail-stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
    .detail-stat-divider { width: 1px; background: var(--border-color); }

    /* Kartu Section Umum (Panduan, Beli, Ulasan) */
    .detail-section, .detail-buy-box, .reviews-section { background: var(--card-bg); padding: 25px; border-radius: var(--border-radius); box-shadow: var(--shadow-sm); margin-bottom: 24px; }
    .detail-section-title, .detail-method-title { font-size: 18px; font-weight: 700; margin-bottom: 16px; border-bottom: 2px solid var(--bg-color); padding-bottom: 10px; color: var(--text-dark); display: flex; align-items: center; gap: 8px; }

    /* Panduan Pembelian */
    .buy-guide-list { padding: 0; list-style: none; margin: 0; display: flex; flex-direction: column; gap: 12px; }
    .buy-guide-item { display: flex; gap: 12px; align-items: flex-start; }
    .buy-guide-num { background: var(--primary-color); color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 13px; font-weight: bold; flex-shrink: 0; }
    .buy-guide-text { font-size: 14px; color: #475569; line-height: 1.5; }

    /* Input Fields (User ID, Zone ID) */
    .target-fields-box { background: var(--bg-color); padding: 20px; border-radius: 12px; margin-bottom: 24px; border: 1px solid var(--border-color); }
    .target-fields-box label { display: block; margin-top: 10px; margin-bottom: 5px; font-size: 13px; font-weight: 600; color: var(--text-muted); }
    .target-field-input { width: 100%; padding: 14px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 15px; outline: none; transition: 0.3s; background: #fff; box-sizing: border-box; }
    .target-field-input:focus { border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(0,123,255,0.1); }
    .helper-text { font-size: 12px; color: #ef4444; margin-top: 10px; font-style: italic; }

    /* Grid Variant Nominal */
    .variant-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .variant-card { display: flex; flex-direction: column; justify-content: center; align-items: center; background: #fff; border: 2px solid var(--border-color); border-radius: 12px; padding: 16px 10px; text-align: center; cursor: pointer; transition: 0.2s; outline: none; text-decoration: none; min-height: 80px; }
    .variant-card:hover { border-color: #cbd5e1; transform: translateY(-2px); }
    .variant-card-name { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; }
    .variant-card-price { font-size: 14px; color: var(--primary-color); font-weight: 800; }
    .variant-card-warn { font-size: 11px; color: #ef4444; background: #fef2f2; padding: 2px 6px; border-radius: 4px; margin-top: 5px; }
    
    /* Efek Variabel Aktif */
    .variant-card.selected { border-color: var(--primary-color); background: #f0f7ff; box-shadow: 0 4px 12px rgba(0,123,255,0.15); transform: translateY(-2px); }

    /* Harga & Stepper (Qty) */
    .detail-price-main { text-align: right; margin-bottom: 15px; background: var(--bg-color); padding: 15px; border-radius: 12px; }
    .detail-price-old { text-decoration: line-through; color: var(--text-muted); font-size: 14px; margin-right: 8px; }
    .detail-price-now { font-size: 24px; font-weight: 900; color: var(--primary-color); }
    
    .detail-qty-row { display: flex; justify-content: space-between; align-items: center; background: var(--bg-color); padding: 15px; border-radius: 12px; margin-bottom: 24px; }
    .detail-qty-row label { font-weight: 600; color: var(--text-dark); }
    .qty-stepper { display: flex; align-items: center; background: #fff; border-radius: 8px; border: 1px solid var(--border-color); overflow: hidden; }
    .qty-btn { background: #f8f9fa; border: none; padding: 8px 15px; cursor: pointer; font-size: 16px; font-weight: bold; color: var(--text-dark); transition: 0.2s; }
    .qty-btn:hover { background: #e2e8f0; }
    .qty-stepper input { width: 50px; text-align: center; border: none; outline: none; font-weight: bold; font-size: 16px; -moz-appearance: textfield; border-left: 1px solid var(--border-color); border-right: 1px solid var(--border-color); padding: 8px 0; }
    .total-preview { font-size: 18px; color: var(--text-dark); }

    /* Metode Pembayaran Tab */
    .payment-method-tabs { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .method-tab input { display: none; }
    .method-card { display: flex; align-items: center; padding: 16px; border: 2px solid var(--border-color); border-radius: 12px; cursor: pointer; transition: 0.2s; background: #fff; }
    .method-icon { font-size: 24px; width: 40px; color: var(--text-muted); }
    .method-info { flex: 1; }
    .method-name { font-weight: 700; font-size: 15px; color: var(--text-dark); }
    .method-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .method-check { color: transparent; font-size: 18px; transition: 0.2s; }
    
    /* Efek Metode Dipilih */
    .method-tab input:checked + .method-card { border-color: var(--secondary-color); background: #f0fdf4; box-shadow: 0 4px 12px rgba(16,185,129,0.1); }
    .method-tab input:checked + .method-card .method-icon { color: var(--secondary-color); }
    .method-tab input:checked + .method-card .method-check { color: var(--secondary-color); }

    /* Tombol Beli Utama */
    .buy-main-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); color: white; border: none; border-radius: 12px; font-size: 18px; font-weight: 800; cursor: pointer; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 6px 15px rgba(0,123,255,0.3); }
    .buy-main-btn:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,123,255,0.4); }

    /* Reviews Styling */
    .reviews-header { display: flex; justify-content: space-between; align-items: center; }
    .reviews-count { font-size: 14px; background: var(--bg-color); padding: 4px 10px; border-radius: 20px; font-weight: 600; color: var(--text-muted); }
    .review-form-card { background: var(--bg-color); padding: 20px; border-radius: 12px; margin-bottom: 24px; border: 1px solid var(--border-color); }
    .review-stars-input { font-size: 30px; margin-bottom: 10px; cursor: pointer; display: flex; justify-content: center; gap: 5px; }
    .rev-star-btn { color: #d1d5db; transition: 0.2s; }
    .rev-star-btn.sel, .rev-star-btn.hov { color: #fbbf24; transform: scale(1.1); }
    .review-textarea { width: 100%; padding: 15px; border-radius: 8px; border: 1px solid var(--border-color); outline: none; resize: vertical; box-sizing: border-box; font-family: inherit; margin-bottom: 15px; }
    .review-submit-btn { width: 100%; padding: 12px; background: var(--text-dark); color: white; border-radius: 8px; font-weight: bold; cursor: pointer; border: none; }
    
    .review-card { padding: 20px 0; border-bottom: 1px solid var(--border-color); }
    .review-card:last-child { border-bottom: none; }
    .review-card-top { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .review-avatar { width: 40px; height: 40px; background: var(--primary-color); color: white; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: bold; font-size: 18px; }
    .review-card-meta { flex: 1; }
    .review-username { font-weight: 700; font-size: 15px; color: var(--text-dark); }
    .review-date { font-size: 12px; color: var(--text-muted); }
    .review-stars-display { font-size: 14px; }
    .rstar-on { color: #fbbf24; }
    .rstar-off { color: #e2e8f0; }
    .review-comment { font-size: 14px; color: #475569; line-height: 1.6; background: var(--bg-color); padding: 12px; border-radius: 8px; border-left: 3px solid var(--primary-color); }

    /* Alert / Warning */
    .alert.error { background: #fef2f2; border: 1px solid #f87171; color: #dc2626; padding: 10px 15px; border-radius: 8px; font-weight: 600; text-align: center; }
    
    /* Responsive */
    @media (max-width: 600px) {
      .detail-stats-row { flex-direction: column; gap: 10px; }
      .detail-stat-divider { width: 100%; height: 1px; }
      .detail-title { font-size: 22px; }
      .variant-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk', user, config }) %>
  <div class="main detail-main no-bottom-nav">

    <% const displayName = product.variantGroup || product.name; %>

    <!-- Hero Image (Banner) -->
    <div class="detail-hero">
      <% if (displayThumbnail) { %>
        <img class="detail-thumb" src="<%= displayThumbnail %>" alt="<%= displayName %>">
      <% } else { %>
        <div class="detail-thumb detail-thumb-placeholder" style="background:var(--primary-color); display:flex; align-items:center; justify-content:center; font-size:80px; color:#fff;"><%= displayName.charAt(0).toUpperCase() %></div>
      <% } %>
      <div class="detail-hero-overlay"></div>
      <a href="/produk" class="detail-back-btn"><i class="fa-solid fa-arrow-left"></i> Kembali</a>
    </div>

    <div class="detail-body">

      <!-- Header & Rating Info Menempel di Bawah Banner -->
      <div class="detail-meta-row">
        <% const isAuto = product.provider === 'digiflazz'; %>
        <% const stockCount = product.stockItems ? product.stockItems.length : 0; %>
        <span class="nf-stock-tag <%= (isAuto || stockCount > 0) ? 'ok' : 'warn' %>"><%- (isAuto || stockCount > 0) ? '<i class="fa-solid fa-bolt"></i> Auto' : '<i class="fa-solid fa-screwdriver-wrench"></i> Manual' %></span>
        <span class="detail-category"><%= product.category || 'Umum' %></span>
      </div>

      <h1 class="detail-title"><%= displayName %></h1>

      <div class="rating-row">
        <div class="stars-display">
          <% const avgR = product.rating || 0; for(let i=1;i<=5;i++){%><span class="star <%= i<=Math.round(avgR)?'filled':'' %>">★</span><%}%>
        </div>
        <span class="rating-score"><%= avgR.toFixed(1) %></span>
        <span class="rating-count">(<%= product.ratingCount || 0 %> ulasan)</span>
      </div>

      <!-- Stats Box -->
      <div class="detail-stats-row">
        <div class="detail-stat">
          <div class="detail-stat-val"><%= product.totalSold || 0 %></div>
          <div class="detail-stat-label">Terjual</div>
        </div>
        <div class="detail-stat-divider"></div>
        <% if (isAuto) { %>
        <div class="detail-stat">
          <div class="detail-stat-val" style="color:var(--secondary-color);"><i class="fa-solid fa-bolt"></i> Instan</div>
          <div class="detail-stat-label">Pengiriman</div>
        </div>
        <% } else { %>
        <div class="detail-stat">
          <div class="detail-stat-val"><%= stockCount %></div>
          <div class="detail-stat-label">Stok</div>
        </div>
        <% } %>
        <div class="detail-stat-divider"></div>
        <div class="detail-stat">
          <div class="detail-stat-val" style="color:var(--primary-color);">Rp <%= finalPrice.toLocaleString('id-ID') %></div>
          <div class="detail-stat-label">Harga Awal</div>
        </div>
      </div>

      <!-- Panduan Membeli -->
      <% if (isAuto) { %>
        <% let guideStep = 1; %>
        <div class="detail-section">
          <div class="detail-section-title"><i class="fa-solid fa-book-open"></i> Cara Membeli</div>
          <ol class="buy-guide-list">
            <% if (variants && variants.length > 1) { %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Pilih <b>nominal</b> yang kamu butuhkan di daftar pilihan.</span>
            </li>
            <% } %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Atur <b>jumlah (qty)</b> yang mau dibeli, lalu cek total harganya.</span>
            </li>
            <% if (product.targetFields && product.targetFields.length > 0) { %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Isi <b><%= product.targetFields.map(f => f.label).join(' & ') %></b> dengan benar. Data yang salah bisa bikin pesanan gagal.</span>
            </li>
            <% } %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Pilih <b>metode pembayaran</b> (Saldo akun / QRIS) dan klik <b>Beli Sekarang</b>.</span>
            </li>
          </ol>
        </div>
      <% } else if (product.description) { %>
        <div class="detail-section">
          <div class="detail-section-title"><i class="fa-solid fa-circle-info"></i> Deskripsi Produk</div>
          <div class="detail-desc" style="color:var(--text-muted); line-height: 1.6;"><%= product.description %></div>
        </div>
      <% } %>

      <!-- SECTION: KOTAK PEMBELIAN UTAMA -->
      <div class="detail-buy-box">
        <%
          const numberSteps = !!(variants && variants.length > 1);
          const hasTargetFields = !!(product.targetFields && product.targetFields.length > 0);
          const targetFieldsLabel = (numberSteps && hasTargetFields) ? '1. ' : '';
          const variantLabel = numberSteps ? (hasTargetFields ? '2. ' : '1. ') : '';
          const qtyLabel = numberSteps ? (hasTargetFields ? '3. ' : '2. ') : '';
        %>

        <% if (user) { %>
        <div id="targetFieldsWrap">
        <% if (hasTargetFields) { %>
        <div class="target-fields-box">
          <div class="detail-method-title"><span class="buy-guide-num"><%= targetFieldsLabel.replace('.','') || 1 %></span> Isi Data Tujuan</div>
          <% product.targetFields.forEach(f => { %>
            <label><%= f.label %><% if (f.required) { %> <span style="color:#ef4444;">*</span><% } %></label>
            <% if (f.type === 'select') { %>
              <select class="target-field-input" data-key="<%= f.key %>" <%= f.required ? 'required' : '' %>>
                <option value="">Pilih <%= f.label %></option>
                <% (f.options || []).forEach(opt => { %>
                  <option value="<%= opt.value %>"><%= opt.label %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" class="target-field-input" data-key="<%= f.key %>" placeholder="<%= f.placeholder || '' %>" <%= f.required ? 'required' : '' %>>
            <% } %>
          <% }) %>
          <div class="helper-text">Pastikan data di atas benar. Kesalahan <%= product.targetFields.some(f => /zone/i.test(f.key)) ? 'ID/Zone' : 'data' %> bisa membuat pesanan gagal terkirim.</div>
        </div>
        <% } %>
        </div>
        <% } %>

        <% if (variants && variants.length > 1) { %>
        <div class="detail-method-title" <%= (user && hasTargetFields) ? '' : 'style="margin-top:0;"' %>><span class="buy-guide-num"><%= variantLabel.replace('.','') || 1 %></span> Pilih Nominal</div>
        <% if (user) { %>
        <div class="variant-grid" id="variantGrid">
          <% variants.forEach(v => { %>
            <button type="button" class="variant-card <%= v.id === product.id ? 'selected' : '' %>" data-variant-id="<%= v.id %>">
              <span class="variant-card-name"><%= v.name %></span>
              <span class="variant-card-price">Rp <%= v.finalPrice.toLocaleString('id-ID') %></span>
              <% if (v.provider !== 'digiflazz' && v.stockCount === 0) { %><span class="variant-card-warn">Stok habis</span><% } %>
            </button>
          <% }) %>
        </div>
        <% } else { %>
        <div class="variant-grid">
          <% variants.forEach(v => { %>
            <a href="/produk/<%= v.id %>" class="variant-card <%= v.id === product.id ? 'selected' : '' %>">
              <span class="variant-card-name"><%= v.name %></span>
              <span class="variant-card-price">Rp <%= v.finalPrice.toLocaleString('id-ID') %></span>
              <% if (v.provider !== 'digiflazz' && v.stockCount === 0) { %><span class="variant-card-warn">Stok habis</span><% } %>
            </a>
          <% }) %>
        </div>
        <% } %>
        <% } %>

        <!-- Display Harga Saat Ini -->
        <div class="detail-price-main">
          <% if (finalPrice < product.price) { %>
            <span class="detail-price-old" id="priceOld">Rp <%= product.price.toLocaleString('id-ID') %></span>
          <% } %>
          <span class="detail-price-now" id="priceNow">Rp <%= finalPrice.toLocaleString('id-ID') %></span>
        </div>

        <% if (user) { %>
          <div class="detail-qty-row">
            <label>Jumlah Beli:</label>
            <div class="qty-stepper">
              <button type="button" class="qty-btn" id="qtyMinus">−</button>
              <input type="number" id="qtyInput" value="1" min="1" max="<%= (!isAuto && stockCount > 0) ? stockCount : (isAuto ? 10 : 99) %>">
              <button type="button" class="qty-btn" id="qtyPlus">+</button>
            </div>
            <span class="total-preview">= <b id="totalPreview">Rp <%= finalPrice.toLocaleString('id-ID') %></b></span>
          </div>

          <div class="detail-method-title"><i class="fa-solid fa-wallet"></i> Metode Pembayaran</div>
          <div class="payment-method-tabs">
            <label class="method-tab">
              <input type="radio" name="payMethod" value="saldo" checked>
              <div class="method-card">
                <div class="method-icon"><i class="fa-solid fa-credit-card"></i></div>
                <div class="method-info">
                  <div class="method-name">Saldo Akun</div>
                  <div class="method-sub">Sisa Saldo: <b>Rp <%= user.saldo.toLocaleString('id-ID') %></b></div>
                </div>
                <div class="method-check"><i class="fa-solid fa-circle-check"></i></div>
              </div>
            </label>
            <label class="method-tab">
              <input type="radio" name="payMethod" value="qris">
              <div class="method-card">
                <div class="method-icon"><i class="fa-solid fa-qrcode"></i></div>
                <div class="method-info">
                  <div class="method-name">QRIS</div>
                  <div class="method-sub">Bayar otomatis via e-Wallet/Bank</div>
                </div>
                <div class="method-check"><i class="fa-solid fa-circle-check"></i></div>
              </div>
            </label>
          </div>

          <!-- Formulir Tersembunyi -->
          <form method="POST" action="/order" id="buyFormSaldo">
            <input type="hidden" name="productId" id="productIdSaldo" value="<%= product.id %>">
            <input type="hidden" name="qty" id="buyQtySaldo" value="1">
          </form>
          <form method="POST" action="/order/qris-init" id="buyFormQris">
            <input type="hidden" name="productId" id="productIdQris" value="<%= product.id %>">
            <input type="hidden" name="qty" id="buyQtyQris" value="1">
          </form>

          <button type="button" class="buy-main-btn" id="buyMainBtn"><i class="fa-solid fa-cart-shopping"></i> Beli Sekarang</button>
          <div class="alert error" id="saldoWarning" style="margin-top:12px; <%= user.saldo < finalPrice ? '' : 'display:none;' %>"><i class="fa-solid fa-triangle-exclamation"></i> Saldo tidak cukup — Silakan gunakan QRIS atau Topup Saldo.</div>
        <% } else { %>
          <div class="guest-buy-box">
            <a href="/login" class="buy-main-btn" style="display:block; text-align:center; text-decoration:none;"><i class="fa-solid fa-key"></i> Login untuk Membeli</a>
            <div style="text-align:center; margin-top:15px; font-size:14px; color:var(--text-muted);">Belum punya akun? <a href="/register" style="color:var(--primary-color); font-weight:bold;">Daftar gratis</a></div>
          </div>
        <% } %>
      </div>

      <!-- ====== ULASAN ====== -->
      <div class="reviews-section">
        <div class="reviews-header">
          <div class="detail-section-title" style="border:none; margin:0;"><i class="fa-solid fa-star"></i> Ulasan Pembeli</div>
          <span class="reviews-count"><%= reviews.length %> ulasan</span>
        </div>
        <hr style="border:none; border-top: 1px solid var(--border-color); margin: 15px 0 25px 0;">

        <% if (user && !hasReviewed) { %>
          <div class="review-form-card">
            <div style="font-weight:700; margin-bottom:10px; text-align:center;">Tulis Ulasanmu</div>
            <form method="POST" action="/produk/<%= product.id %>/review" class="review-form">
              <div class="review-stars-input" id="reviewStarsInput">
                <% for(let i=1;i<=5;i++){%><span class="rev-star-btn" data-val="<%= i %>">★</span><%}%>
              </div>
              <input type="hidden" name="rating" id="reviewRatingVal" value="">
              <p style="text-align:center; font-size:13px; color:var(--text-muted); margin-bottom:15px;" id="revStarHint">Ketuk bintang untuk memberi nilai</p>
              <textarea name="comment" class="review-textarea" placeholder="Ceritakan pengalamanmu... (opsional)" maxlength="500" rows="3"></textarea>
              <button type="submit" class="review-submit-btn" id="reviewSubmitBtn" disabled>Kirim Ulasan</button>
            </form>
          </div>
        <% } else if (user && hasReviewed) { %>
          <div style="background:#f0fdf4; color:#059669; padding:15px; border-radius:8px; text-align:center; border:1px solid #a7f3d0; margin-bottom: 20px;"><i class="fa-solid fa-circle-check"></i> Kamu sudah memberikan ulasan.</div>
        <% } else { %>
          <div style="text-align:center; padding:15px; background:var(--bg-color); border-radius:8px; margin-bottom:20px;"><a href="/login" style="color:var(--primary-color); font-weight:bold;">Login</a> untuk menulis ulasan.</div>
        <% } %>

        <% if (reviews.length === 0) { %>
          <div style="text-align:center; padding:30px; color:var(--text-muted);">Belum ada ulasan. Jadilah yang pertama! <i class="fa-solid fa-star" style="color:#fbbf24;"></i></div>
        <% } else { %>
          <div class="review-list">
            <% reviews.forEach(r => { %>
            <div class="review-card">
              <div class="review-card-top">
                <div class="review-avatar"><%= r.username.charAt(0).toUpperCase() %></div>
                <div class="review-card-meta">
                  <div class="review-username"><%= r.username %></div>
                  <div class="review-date"><%= new Date(r.createdAt).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) %></div>
                </div>
                <div class="review-stars-display">
                  <% for(let i=1;i<=5;i++){%><span class="<%= i<=r.rating?'rstar-on':'rstar-off' %>">★</span><%}%>
                </div>
              </div>
              <% if (r.comment) { %>
                <div class="review-comment"><%= r.comment %></div>
              <% } %>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div><!-- /detail-body -->
    <%- include('partials/footer') %>
  </div><!-- /main -->
</div><!-- /app-shell -->

<!-- SCRIPT JAVASCRIPT LAMA (DIPERTAHANKAN 100% UNTUK LOGIKA BACKEND) -->
<script>
(function(){
  var VARIANTS = <%- JSON.stringify((variants || []).reduce(function(acc, v){ acc[v.id] = v; return acc; }, {})) %>;
  var userSaldo = <%= user ? user.saldo : 0 %>;
  var currentProductId = '<%= product.id %>';
  var numberSteps = <%- numberSteps ? 'true' : 'false' %>;

  var unitPrice=<%= finalPrice %>;
  var qEl=document.getElementById('qtyInput');
  var tEl=document.getElementById('totalPreview');
  function fmt(n){return 'Rp '+n.toLocaleString('id-ID');}
  function upd(){var q=Math.max(1,parseInt(qEl.value)||1);qEl.value=q;
    var qs=document.getElementById('buyQtySaldo');var qq=document.getElementById('buyQtyQris');
    if(qs)qs.value=q;if(qq)qq.value=q;if(tEl)tEl.textContent=fmt(unitPrice*q);
    updSaldoWarning(q);}
  function updSaldoWarning(q){
    var warn=document.getElementById('saldoWarning');
    if(!warn) return;
    warn.style.display = (userSaldo < unitPrice*q) ? '' : 'none';
  }
  if(qEl){qEl.addEventListener('input',upd);
    var m=document.getElementById('qtyMinus');var p=document.getElementById('qtyPlus');
    if(m)m.addEventListener('click',function(){qEl.value=Math.max(1,(parseInt(qEl.value)||1)-1);upd();});
    if(p)p.addEventListener('click',function(){qEl.value=(parseInt(qEl.value)||1)+1;upd();});}

  function renderTargetFields(fields){
    var wrap=document.getElementById('targetFieldsWrap');
    if(!wrap) return;
    if(!fields || fields.length===0){ wrap.innerHTML=''; return; }
    var label = numberSteps ? '<span class="buy-guide-num">1</span> ' : '';
    var html='<div class="target-fields-box"><div class="detail-method-title">'+label+'Isi Data Tujuan</div>';
    fields.forEach(function(f){
      html+='<label>'+f.label+(f.required?' <span style="color:#ef4444;">*</span>':'')+'</label>';
      if(f.type==='select'){
        html+='<select class="target-field-input" data-key="'+f.key+'" '+(f.required?'required':'')+'>';
        html+='<option value="">Pilih '+f.label+'</option>';
        (f.options||[]).forEach(function(opt){
          html+='<option value="'+opt.value+'">'+opt.label+'</option>';
        });
        html+='</select>';
      } else {
        html+='<input type="text" class="target-field-input" data-key="'+f.key+'" placeholder="'+(f.placeholder||'')+'" '+(f.required?'required':'')+'>';
      }
    });
    var hasZoneField = fields.some(function(f){ return /zone/i.test(f.key); });
    html+='<div class="helper-text">Pastikan data di atas benar. Kesalahan '+(hasZoneField?'ID/Zone':'data')+' bisa membuat pesanan gagal terkirim.</div></div>';
    wrap.innerHTML=html;
  }

  var variantGrid=document.getElementById('variantGrid');
  if(variantGrid){
    variantGrid.addEventListener('click',function(e){
      var card=e.target.closest('.variant-card');
      if(!card) return;
      var vid=card.dataset.variantId;
      var v=VARIANTS[vid];
      if(!v) return;

      currentProductId=vid;
      unitPrice=v.finalPrice;

      variantGrid.querySelectorAll('.variant-card').forEach(function(c){c.classList.remove('selected');});
      card.classList.add('selected');

      var priceOld=document.getElementById('priceOld');
      var priceNow=document.getElementById('priceNow');
      if(v.finalPrice < v.price){
        if(!priceOld){
          priceOld=document.createElement('span');
          priceOld.className='detail-price-old';
          priceOld.id='priceOld';
          priceNow.parentNode.insertBefore(priceOld, priceNow);
        }
        priceOld.textContent=fmt(v.price);
        priceOld.style.display='';
      } else if(priceOld){
        priceOld.style.display='none';
      }
      if(priceNow) priceNow.textContent=fmt(v.finalPrice);

      var idSaldo=document.getElementById('productIdSaldo');
      var idQris=document.getElementById('productIdQris');
      if(idSaldo)idSaldo.value=vid;
      if(idQris)idQris.value=vid;

      if(qEl){ qEl.value=1; qEl.max = (v.provider !== 'digiflazz' && v.stockCount>0) ? v.stockCount : 99; }
      upd();
      renderTargetFields(v.targetFields);
    });
  }

  var radios=document.querySelectorAll('input[name="payMethod"]');
  radios.forEach(function(r){r.addEventListener('change',function(){
    document.querySelectorAll('.method-card').forEach(function(c){c.classList.remove('selected');});
    r.closest('.method-tab').querySelector('.method-card').classList.add('selected');
  });});
  var def=document.querySelector('input[name="payMethod"]:checked');
  if(def)def.closest('.method-tab').querySelector('.method-card').classList.add('selected');

  var buyBtn=document.getElementById('buyMainBtn');
  function injectTargetFields(form){
    if(!form) return true;
    form.querySelectorAll('input[data-target-hidden]').forEach(function(el){el.remove();});
    var inputs=document.querySelectorAll('.target-field-input');
    var ok=true;
    inputs.forEach(function(el){
      var val=el.value.trim();
      if(el.hasAttribute('required') && !val){ el.style.borderColor='#ef4444'; ok=false; }
      else { el.style.borderColor=''; }
      var hidden=document.createElement('input');
      hidden.type='hidden';
      hidden.name='target_'+el.dataset.key;
      hidden.value=val;
      hidden.setAttribute('data-target-hidden','1');
      form.appendChild(hidden);
    });
    return ok;
  }
  if(buyBtn)buyBtn.addEventListener('click',function(){
    var m='saldo';radios.forEach(function(r){if(r.checked)m=r.value;});
    var f=m==='qris'?document.getElementById('buyFormQris'):document.getElementById('buyFormSaldo');
    if(!injectTargetFields(f)){ alert('Mohon lengkapi data tujuan (User ID/Game ID) terlebih dahulu!'); return; }
    if(f)f.submit();
  });

  var stars=document.querySelectorAll('.rev-star-btn');
  var ratingInput=document.getElementById('reviewRatingVal');
  var hint=document.getElementById('revStarHint');
  var submitBtn=document.getElementById('reviewSubmitBtn');
  var labels=['Sangat Buruk','Kurang Baik','Cukup','Bagus Sekali','Luar Biasa!'];
  stars.forEach(function(s){
    s.addEventListener('mouseenter',function(){
      var v=parseInt(s.dataset.val);
      stars.forEach(function(x){x.classList.toggle('hov',parseInt(x.dataset.val)<=v);});
      if(hint)hint.textContent=labels[v-1];
    });
    s.addEventListener('mouseleave',function(){
      stars.forEach(function(x){x.classList.remove('hov');});
      if(hint&&!ratingInput.value)hint.textContent='Ketuk bintang untuk memberi nilai';
    });
    s.addEventListener('click',function(){
      var v=parseInt(s.dataset.val);
      if(ratingInput)ratingInput.value=v;
      stars.forEach(function(x){x.classList.toggle('sel',parseInt(x.dataset.val)<=v);x.classList.remove('hov');});
      if(hint)hint.textContent=labels[v-1];
      if(submitBtn)submitBtn.disabled=false;
    });
  });
})();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk', user, config }) %>
  <div class="main detail-main no-bottom-nav">

    <% /* Produk yang tergabung dalam Grup Varian (mis. semua nominal "Mobile Legends") harus tetap
       menampilkan nama grupnya di sini, BUKAN nama SKU spesifik yang kebetulan jadi link (varian
       termurah) dari kartu katalog. Kalau tidak, judul halaman "loncat" jadi nama nominal tertentu
       (mis. "MOBILELEGEND - 3 Diamond") padahal di beranda kartunya cuma tertulis "Mobile Legends". */ %>
    <% const displayName = product.variantGroup || product.name; %>

    <!-- Hero Image -->
    <div class="detail-hero">
      <% if (displayThumbnail) { %>
        <img class="detail-thumb" src="<%= displayThumbnail %>" alt="<%= displayName %>">
      <% } else { %>
        <div class="detail-thumb detail-thumb-placeholder"><%= displayName.charAt(0).toUpperCase() %></div>
      <% } %>
      <div class="detail-hero-overlay"></div>
      <a href="/produk" class="detail-back-btn"><i class="fa-solid fa-arrow-left"></i> Kembali</a>
    </div>

    <div class="detail-body">

      <div class="detail-meta-row">
        <% /* Digiflazz = auto top up sistem, jadi statusnya selalu "Auto" walau tidak ada stockItems manual. */ %>
        <% const isAuto = product.provider === 'digiflazz'; %>
        <% const stockCount = product.stockItems ? product.stockItems.length : 0; %>
        <span class="nf-stock-tag <%= (isAuto || stockCount > 0) ? 'ok' : 'warn' %>"><%- (isAuto || stockCount > 0) ? '<i class="fa-solid fa-bolt"></i> Auto' : '<i class="fa-solid fa-screwdriver-wrench"></i> Manual' %></span>
        <span class="detail-category"><%= product.category || 'Umum' %></span>
      </div>

      <h1 class="detail-title"><%= displayName %></h1>

      <!-- Rating display -->
      <div class="rating-row">
        <div class="stars-display">
          <% const avgR = product.rating || 0; for(let i=1;i<=5;i++){%><span class="star <%= i<=Math.round(avgR)?'filled':'' %>">★</span><%}%>
        </div>
        <span class="rating-score"><%= avgR.toFixed(1) %></span>
        <span class="rating-count">(<%= product.ratingCount || 0 %> ulasan)</span>
      </div>

      <!-- Stats -->
      <div class="detail-stats-row">
        <div class="detail-stat">
          <div class="detail-stat-val"><%= product.totalSold || 0 %></div>
          <div class="detail-stat-label">Terjual</div>
        </div>
        <div class="detail-stat-divider"></div>
        <% if (isAuto) { %>
        <div class="detail-stat">
          <div class="detail-stat-val" style="color:var(--success);"><i class="fa-solid fa-bolt"></i> Instan</div>
          <div class="detail-stat-label">Pengiriman</div>
        </div>
        <% } else { %>
        <div class="detail-stat">
          <div class="detail-stat-val"><%= stockCount %></div>
          <div class="detail-stat-label">Stok</div>
        </div>
        <% } %>
        <div class="detail-stat-divider"></div>
        <div class="detail-stat">
          <div class="detail-stat-val" style="color:var(--cyan);">Rp <%= finalPrice.toLocaleString('id-ID') %></div>
          <div class="detail-stat-label">Harga</div>
        </div>
      </div>

      <!-- Deskripsi / Panduan cara membeli -->
      <% if (isAuto) { %>
        <% /* Produk auto top up (Digiflazz) gak pakai deskripsi manual, tapi panduan langkah beli yang sama buat semua produk auto. */ %>
        <% let guideStep = 1; %>
        <div class="detail-section">
          <div class="detail-section-title">Cara Membeli</div>
          <ol class="buy-guide-list">
            <% if (variants && variants.length > 1) { %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Pilih <b>nominal</b> yang kamu butuhkan di daftar pilihan.</span>
            </li>
            <% } %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Atur <b>jumlah (qty)</b> yang mau dibeli, lalu cek total harganya.</span>
            </li>
            <% if (product.targetFields && product.targetFields.length > 0) { %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Isi <b><%= product.targetFields.map(f => f.label).join(' & ') %></b> dengan benar. Data yang salah bisa bikin pesanan gagal terkirim.</span>
            </li>
            <% } %>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Pilih <b>metode pembayaran</b>: Saldo akun atau QRIS.</span>
            </li>
            <li class="buy-guide-item">
              <span class="buy-guide-num"><%= guideStep++ %></span>
              <span class="buy-guide-text">Klik <b>Beli Sekarang</b>. Setelah pembayaran berhasil, produk terkirim <b>otomatis & instan</b>.</span>
            </li>
          </ol>
        </div>
      <% } else if (product.description) { %>
        <div class="detail-section">
          <div class="detail-section-title">Deskripsi Produk</div>
          <div class="detail-desc"><%= product.description %></div>
        </div>
      <% } %>

      <!-- Buy Box: grid nominal & harga tampil buat SEMUA ORANG (termasuk tamu belum login).
           Cuma kontrol pembelian (qty, data tujuan, metode bayar, tombol beli) yang wajib login. -->
      <div class="detail-buy-box">

        <%
          // Nomor urutan langkah beli dihitung dinamis. "Isi Data Tujuan" (ID game / Server-Zone ID)
          // sekarang ditaruh PALING ATAS, sebelum pilih nominal -- user isi ID/Server dulu baru
          // milih nominal & bayar, urutannya lebih natural buat top up game. Nomor cuma dimunculin
          // kalau produk ini punya >1 varian nominal buat dipilih (sama kayak aturan sebelumnya).
        %>
        <% const numberSteps = !!(variants && variants.length > 1); %>
        <% const hasTargetFields = !!(product.targetFields && product.targetFields.length > 0); %>
        <% const targetFieldsLabel = (numberSteps && hasTargetFields) ? '1. ' : ''; %>
        <% const variantLabel = numberSteps ? (hasTargetFields ? '2. ' : '1. ') : ''; %>
        <% const qtyLabel = numberSteps ? (hasTargetFields ? '3. ' : '2. ') : ''; %>

        <% if (user) { %>
        <div id="targetFieldsWrap">
        <% if (hasTargetFields) { %>
        <div class="target-fields-box">
          <div class="detail-method-title"><%= targetFieldsLabel %>Isi Data Tujuan</div>
          <% product.targetFields.forEach(f => { %>
            <label><%= f.label %><% if (f.required) { %> <span style="color:var(--cyan);">*</span><% } %></label>
            <% if (f.type === 'select') { %>
              <select class="target-field-input" data-key="<%= f.key %>" <%= f.required ? 'required' : '' %>>
                <option value="">Pilih <%= f.label %></option>
                <% (f.options || []).forEach(opt => { %>
                  <option value="<%= opt.value %>"><%= opt.label %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" class="target-field-input" data-key="<%= f.key %>" placeholder="<%= f.placeholder || '' %>" <%= f.required ? 'required' : '' %>>
            <% } %>
          <% }) %>
          <div class="helper-text">Pastikan data di atas benar. Kesalahan <%= product.targetFields.some(f => /zone/i.test(f.key)) ? 'ID/Zone' : 'data' %> bisa membuat pesanan gagal terkirim.</div>
        </div>
        <% } %>
        </div>
        <% } %>

        <% if (variants && variants.length > 1) { %>
        <div class="detail-method-title" <%= (user && hasTargetFields) ? '' : 'style="margin-top:0;"' %>><%= variantLabel %>Pilih Nominal</div>
        <% if (user) { %>
        <div class="variant-grid" id="variantGrid">
          <% variants.forEach(v => { %>
            <button type="button" class="variant-card <%= v.id === product.id ? 'selected' : '' %>" data-variant-id="<%= v.id %>">
              <span class="variant-card-name"><%= v.name %></span>
              <span class="variant-card-price">Rp <%= v.finalPrice.toLocaleString('id-ID') %></span>
              <% if (v.provider !== 'digiflazz' && v.stockCount === 0) { %><span class="variant-card-warn">Stok habis</span><% } %>
            </button>
          <% }) %>
        </div>
        <% } else { %>
        <!-- Tamu: kartu varian jadi tautan biasa ke halaman produknya masing-masing, biar semua
             harga tetap kelihatan tanpa perlu JS pemilih varian yang cuma jalan buat user login. -->
        <div class="variant-grid">
          <% variants.forEach(v => { %>
            <a href="/produk/<%= v.id %>" class="variant-card <%= v.id === product.id ? 'selected' : '' %>">
              <span class="variant-card-name"><%= v.name %></span>
              <span class="variant-card-price">Rp <%= v.finalPrice.toLocaleString('id-ID') %></span>
              <% if (v.provider !== 'digiflazz' && v.stockCount === 0) { %><span class="variant-card-warn">Stok habis</span><% } %>
            </a>
          <% }) %>
        </div>
        <% } %>
        <% } %>

        <div class="detail-price-main">
          <% if (finalPrice < product.price) { %>
            <span class="detail-price-old" id="priceOld">Rp <%= product.price.toLocaleString('id-ID') %></span>
          <% } %>
          <span class="detail-price-now" id="priceNow">Rp <%= finalPrice.toLocaleString('id-ID') %></span>
        </div>

        <% if (user) { %>
          <div class="detail-qty-row">
            <label><%= qtyLabel %>Jumlah:</label>
            <div class="qty-stepper">
              <button type="button" class="qty-btn" id="qtyMinus">−</button>
              <input type="number" id="qtyInput" value="1" min="1" max="<%= (!isAuto && stockCount > 0) ? stockCount : (isAuto ? 10 : 99) %>">
              <button type="button" class="qty-btn" id="qtyPlus">+</button>
            </div>
            <span class="total-preview">= <b id="totalPreview">Rp <%= finalPrice.toLocaleString('id-ID') %></b></span>
          </div>

          <div class="detail-method-title">Metode Pembayaran</div>
          <div class="payment-method-tabs">
            <label class="method-tab">
              <input type="radio" name="payMethod" value="saldo" checked>
              <div class="method-card">
                <div class="method-icon"><i class="fa-solid fa-credit-card"></i></div>
                <div class="method-info">
                  <div class="method-name">Saldo</div>
                  <div class="method-sub">Saldo kamu: <b>Rp <%= user.saldo.toLocaleString('id-ID') %></b></div>
                </div>
                <div class="method-check"><i class="fa-solid fa-check"></i></div>
              </div>
            </label>
            <label class="method-tab">
              <input type="radio" name="payMethod" value="qris">
              <div class="method-card">
                <div class="method-icon"><i class="fa-solid fa-qrcode"></i></div>
                <div class="method-info">
                  <div class="method-name">QRIS</div>
                  <div class="method-sub">Bayar via scan QR</div>
                </div>
                <div class="method-check"><i class="fa-solid fa-check"></i></div>
              </div>
            </label>
          </div>

          <form method="POST" action="/order" id="buyFormSaldo">
            <input type="hidden" name="productId" id="productIdSaldo" value="<%= product.id %>">
            <input type="hidden" name="qty" id="buyQtySaldo" value="1">
          </form>
          <form method="POST" action="/order/qris-init" id="buyFormQris">
            <input type="hidden" name="productId" id="productIdQris" value="<%= product.id %>">
            <input type="hidden" name="qty" id="buyQtyQris" value="1">
          </form>

          <button type="button" class="btn solid buy-main-btn" id="buyMainBtn"><i class="fa-solid fa-cart-shopping"></i> Beli Sekarang</button>
          <div class="alert error" id="saldoWarning" style="margin-top:8px; font-size:12px; <%= user.saldo < finalPrice ? '' : 'display:none;' %>">Saldo tidak cukup — gunakan QRIS.</div>
        <% } else { %>
          <div class="guest-buy-box">
            <a href="/login" class="btn solid" style="width:100%;"><i class="fa-solid fa-key"></i> Login untuk Beli</a>
            <div style="text-align:center; margin-top:10px; font-size:12px; color:var(--text-dim);">Belum punya akun? <a href="/register" style="color:var(--cyan);">Daftar gratis</a></div>
          </div>
        <% } %>
      </div>

      <!-- ====== ULASAN / KOMENTAR ====== -->
      <div class="reviews-section">
        <div class="reviews-header">
          <div class="detail-section-title">Ulasan Pembeli</div>
          <span class="reviews-count"><%= reviews.length %> ulasan</span>
        </div>

        <!-- Form ulasan (hanya user login & belum review) -->
        <% if (user && !hasReviewed) { %>
          <div class="review-form-card">
            <div class="review-form-title">Tulis Ulasanmu</div>
            <form method="POST" action="/produk/<%= product.id %>/review" class="review-form">
              <div class="review-stars-input" id="reviewStarsInput">
                <% for(let i=1;i<=5;i++){%><span class="rev-star-btn" data-val="<%= i %>">★</span><%}%>
              </div>
              <input type="hidden" name="rating" id="reviewRatingVal" value="">
              <p class="rev-star-hint" id="revStarHint">Ketuk bintang untuk memberi nilai</p>
              <textarea name="comment" class="review-textarea" placeholder="Ceritakan pengalamanmu menggunakan produk ini... (opsional, maks 500 karakter)" maxlength="500" rows="3"></textarea>
              <button type="submit" class="btn solid review-submit-btn" id="reviewSubmitBtn" disabled>Kirim Ulasan</button>
            </form>
          </div>
        <% } else if (user && hasReviewed) { %>
          <div class="review-already"><i class="fa-solid fa-circle-check"></i> Kamu sudah memberikan ulasan untuk produk ini.</div>
        <% } else { %>
          <div class="review-login-prompt"><a href="/login" style="color:var(--cyan);">Login</a> untuk menulis ulasan.</div>
        <% } %>

        <!-- Daftar ulasan -->
        <% if (reviews.length === 0) { %>
          <div class="reviews-empty">Belum ada ulasan. Jadilah yang pertama! <i class="fa-solid fa-star"></i></div>
        <% } else { %>
          <div class="review-list">
            <% reviews.forEach(r => { %>
            <div class="review-card">
              <div class="review-card-top">
                <div class="review-avatar"><%= r.username.charAt(0).toUpperCase() %></div>
                <div class="review-card-meta">
                  <div class="review-username"><%= r.username %></div>
                  <div class="review-date"><%= new Date(r.createdAt).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) %></div>
                </div>
                <div class="review-stars-display">
                  <% for(let i=1;i<=5;i++){%><span class="<%= i<=r.rating?'rstar-on':'rstar-off' %>">★</span><%}%>
                </div>
              </div>
              <% if (r.comment) { %>
                <div class="review-comment"><%= r.comment %></div>
              <% } %>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div><!-- /detail-body -->
    <%- include('partials/footer') %>
  </div><!-- /main -->
</div><!-- /app-shell -->

<script>
(function(){
  var VARIANTS = <%- JSON.stringify((variants || []).reduce(function(acc, v){ acc[v.id] = v; return acc; }, {})) %>;
  var userSaldo = <%= user ? user.saldo : 0 %>;
  var currentProductId = '<%= product.id %>';
  // Isi Data Tujuan selalu di posisi PALING ATAS di box beli (lihat markup di atas), jadi kalau
  // nomor langkah lagi dipakai (produk ini punya >1 varian nominal), section itu selalu "1."
  // -- termasuk pas dimunculin ulang lewat JS ini waktu user ganti pilihan varian.
  var numberSteps = <%- numberSteps ? 'true' : 'false' %>;

  // Qty stepper
  var unitPrice=<%= finalPrice %>;
  var qEl=document.getElementById('qtyInput');
  var tEl=document.getElementById('totalPreview');
  function fmt(n){return 'Rp '+n.toLocaleString('id-ID');}
  function upd(){var q=Math.max(1,parseInt(qEl.value)||1);qEl.value=q;
    var qs=document.getElementById('buyQtySaldo');var qq=document.getElementById('buyQtyQris');
    if(qs)qs.value=q;if(qq)qq.value=q;if(tEl)tEl.textContent=fmt(unitPrice*q);
    updSaldoWarning(q);}
  function updSaldoWarning(q){
    var warn=document.getElementById('saldoWarning');
    if(!warn) return;
    warn.style.display = (userSaldo < unitPrice*q) ? '' : 'none';
  }
  if(qEl){qEl.addEventListener('input',upd);
    var m=document.getElementById('qtyMinus');var p=document.getElementById('qtyPlus');
    if(m)m.addEventListener('click',function(){qEl.value=Math.max(1,(parseInt(qEl.value)||1)-1);upd();});
    if(p)p.addEventListener('click',function(){qEl.value=(parseInt(qEl.value)||1)+1;upd();});}

  // Ganti varian nominal (mis. pilih 875 Diamonds vs 2010 Diamonds) tanpa reload halaman
  function renderTargetFields(fields){
    var wrap=document.getElementById('targetFieldsWrap');
    if(!wrap) return;
    if(!fields || fields.length===0){ wrap.innerHTML=''; return; }
    var label = numberSteps ? '1. ' : '';
    var html='<div class="target-fields-box"><div class="detail-method-title">'+label+'Isi Data Tujuan</div>';
    fields.forEach(function(f){
      html+='<label>'+f.label+(f.required?' <span style="color:var(--cyan);">*</span>':'')+'</label>';
      if(f.type==='select'){
        html+='<select class="target-field-input" data-key="'+f.key+'" '+(f.required?'required':'')+'>';
        html+='<option value="">Pilih '+f.label+'</option>';
        (f.options||[]).forEach(function(opt){
          html+='<option value="'+opt.value+'">'+opt.label+'</option>';
        });
        html+='</select>';
      } else {
        html+='<input type="text" class="target-field-input" data-key="'+f.key+'" placeholder="'+(f.placeholder||'')+'" '+(f.required?'required':'')+'>';
      }
    });
    var hasZoneField = fields.some(function(f){ return /zone/i.test(f.key); });
    html+='<div class="helper-text">Pastikan data di atas benar. Kesalahan '+(hasZoneField?'ID/Zone':'data')+' bisa membuat pesanan gagal terkirim.</div></div>';
    wrap.innerHTML=html;
  }

  var variantGrid=document.getElementById('variantGrid');
  if(variantGrid){
    variantGrid.addEventListener('click',function(e){
      var card=e.target.closest('.variant-card');
      if(!card) return;
      var vid=card.dataset.variantId;
      var v=VARIANTS[vid];
      if(!v) return;

      currentProductId=vid;
      unitPrice=v.finalPrice;

      variantGrid.querySelectorAll('.variant-card').forEach(function(c){c.classList.remove('selected');});
      card.classList.add('selected');

      var priceOld=document.getElementById('priceOld');
      var priceNow=document.getElementById('priceNow');
      if(v.finalPrice < v.price){
        if(!priceOld){
          priceOld=document.createElement('span');
          priceOld.className='detail-price-old';
          priceOld.id='priceOld';
          priceNow.parentNode.insertBefore(priceOld, priceNow);
        }
        priceOld.textContent=fmt(v.price);
        priceOld.style.display='';
      } else if(priceOld){
        priceOld.style.display='none';
      }
      if(priceNow) priceNow.textContent=fmt(v.finalPrice);

      var idSaldo=document.getElementById('productIdSaldo');
      var idQris=document.getElementById('productIdQris');
      if(idSaldo)idSaldo.value=vid;
      if(idQris)idQris.value=vid;

      if(qEl){ qEl.value=1; qEl.max = (v.provider !== 'digiflazz' && v.stockCount>0) ? v.stockCount : 99; }
      upd();

      renderTargetFields(v.targetFields);
    });
  }

  // Method tabs
  var radios=document.querySelectorAll('input[name="payMethod"]');
  radios.forEach(function(r){r.addEventListener('change',function(){
    document.querySelectorAll('.method-card').forEach(function(c){c.classList.remove('selected');});
    r.closest('.method-tab').querySelector('.method-card').classList.add('selected');
  });});
  var def=document.querySelector('input[name="payMethod"]:checked');
  if(def)def.closest('.method-tab').querySelector('.method-card').classList.add('selected');

  // Buy button
  var buyBtn=document.getElementById('buyMainBtn');
  function injectTargetFields(form){
    if(!form) return true;
    // Bersihkan hidden input target_ lama biar gak dobel kalau user submit lebih dari sekali
    form.querySelectorAll('input[data-target-hidden]').forEach(function(el){el.remove();});
    var inputs=document.querySelectorAll('.target-field-input');
    var ok=true;
    inputs.forEach(function(el){
      var val=el.value.trim();
      if(el.hasAttribute('required') && !val){ el.style.borderColor='var(--cyan)'; ok=false; }
      else { el.style.borderColor=''; }
      var hidden=document.createElement('input');
      hidden.type='hidden';
      hidden.name='target_'+el.dataset.key;
      hidden.value=val;
      hidden.setAttribute('data-target-hidden','1');
      form.appendChild(hidden);
    });
    return ok;
  }
  if(buyBtn)buyBtn.addEventListener('click',function(){
    var m='saldo';radios.forEach(function(r){if(r.checked)m=r.value;});
    var f=m==='qris'?document.getElementById('buyFormQris'):document.getElementById('buyFormSaldo');
    if(!injectTargetFields(f)){ alert('Lengkapi dulu data tujuan yang wajib diisi (tanda *)'); return; }
    if(f)f.submit();
  });

  // Review star input
  var stars=document.querySelectorAll('.rev-star-btn');
  var ratingInput=document.getElementById('reviewRatingVal');
  var hint=document.getElementById('revStarHint');
  var submitBtn=document.getElementById('reviewSubmitBtn');
  var labels=['Sangat Buruk','Kurang Baik','Cukup','Bagus Sekali','Luar Biasa!'];
  stars.forEach(function(s){
    s.addEventListener('mouseenter',function(){
      var v=parseInt(s.dataset.val);
      stars.forEach(function(x){x.classList.toggle('hov',parseInt(x.dataset.val)<=v);});
      if(hint)hint.textContent=labels[v-1];
    });
    s.addEventListener('mouseleave',function(){
      stars.forEach(function(x){x.classList.remove('hov');});
      if(hint&&!ratingInput.value)hint.textContent='Ketuk bintang untuk memberi nilai';
    });
    s.addEventListener('click',function(){
      var v=parseInt(s.dataset.val);
      if(ratingInput)ratingInput.value=v;
      stars.forEach(function(x){x.classList.toggle('sel',parseInt(x.dataset.val)<=v);x.classList.remove('hov');});
      if(hint)hint.textContent=labels[v-1];
      if(submitBtn)submitBtn.disabled=false;
    });
  });
})();
</script>
</body>
</html>

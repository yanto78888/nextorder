<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    /* Styling Modern Riwayat Saldo */
    .dashboard-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    .user-chip-modern { background: var(--bg-color); padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: 700; color: var(--primary-color); border: 1px solid var(--border-color); display: inline-flex; align-items: center; gap: 8px; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
    .dash-stat-card { background: var(--card-bg); padding: 25px; border-radius: var(--border-radius); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between; border: 1px solid var(--border-color); }
    .dash-stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 800; letter-spacing: 0.5px; margin-bottom: 8px; }
    .dash-stat-value { font-size: 26px; font-weight: 900; color: var(--text-dark); margin-bottom: 12px; }
    
    .modern-table-wrapper { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--shadow-sm); overflow-x: auto; margin-bottom: 24px; border: 1px solid var(--border-color); }
    .modern-table { width: 100%; border-collapse: collapse; text-align: left; }
    .modern-table th { background: var(--bg-color); padding: 16px 20px; font-size: 13px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; border-bottom: 1px solid var(--border-color); white-space: nowrap; }
    .modern-table td { padding: 16px 20px; border-bottom: 1px solid var(--border-color); font-size: 14px; color: var(--text-dark); vertical-align: middle; }
    .modern-table tr:last-child td { border-bottom: none; }
    .modern-table tr:hover td { background-color: #f8fafc; }

    .badge-modern { padding: 5px 12px; border-radius: 8px; font-size: 12px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; }
    .badge-masuk { background: #d1fae5; color: #059669; border: 1px solid #a7f3d0; }
    .badge-keluar { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }

    .amount-masuk { color: #059669; font-weight: 800; font-family: 'Courier New', Courier, monospace; font-size: 15px; white-space: nowrap; }
    .amount-keluar { color: #dc2626; font-weight: 800; font-family: 'Courier New', Courier, monospace; font-size: 15px; white-space: nowrap; }
    .amount-neutral { color: var(--text-muted); font-weight: 700; font-family: 'Courier New', Courier, monospace; font-size: 14px; white-space: nowrap; }
    
    .ref-link { color: var(--primary-color); font-weight: bold; text-decoration: none; font-size: 12px; background: rgba(0,123,255,0.1); padding: 4px 8px; border-radius: 6px; margin-top: 6px; display: inline-block; border: 1px solid rgba(0,123,255,0.2); }
    .ref-link:hover { background: var(--primary-color); color: #fff; }
    .ref-text { color: var(--text-muted); font-size: 12px; background: var(--bg-color); padding: 4px 8px; border-radius: 6px; margin-top: 6px; display: inline-block; font-family: 'Courier New', Courier, monospace; font-weight: bold; }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'riwayat-saldo', user, config }) %>

  <div class="main no-bottom-nav">
    
    <div class="dashboard-header-row">
      <div class="detail-section-title" style="margin: 0; border: none; padding: 0;"><i class="fa-solid fa-wallet"></i> Riwayat Saldo</div>
      <div class="user-chip-modern"><i class="fa-solid fa-coins"></i> Saldo: Rp <%= user.saldo.toLocaleString('id-ID') %></div>
    </div>

    <% if (success) { %>
      <div style="background:#f0fdf4; color:#059669; padding:15px; border-radius:12px; border: 1px solid #a7f3d0; margin-bottom: 24px; font-weight: 600;"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
    <% } %>
    <% if (error) { %>
      <div style="background:#fef2f2; color:#dc2626; padding:15px; border-radius:12px; border: 1px solid #fecaca; margin-bottom: 24px; font-weight: 600;"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="stat-grid">
      <div class="dash-stat-card" style="border-top: 4px solid #10b981;">
        <div>
          <div class="dash-stat-label">Total Saldo Masuk</div>
          <div class="dash-stat-value" style="color: #059669;">Rp <%= totalMasuk.toLocaleString('id-ID') %></div>
        </div>
      </div>
      <div class="dash-stat-card" style="border-top: 4px solid #ef4444;">
        <div>
          <div class="dash-stat-label">Total Saldo Keluar</div>
          <div class="dash-stat-value" style="color: #dc2626;">Rp <%= totalKeluar.toLocaleString('id-ID') %></div>
        </div>
      </div>
    </div>

    <div class="detail-section-title"><i class="fa-solid fa-list-check"></i> Mutasi Saldo</div>
    
    <% if (entries.length === 0) { %>
      <div class="card empty-state" style="text-align:center; color: var(--text-muted); padding: 50px 20px;">
        <div style="font-size: 40px; margin-bottom: 15px; opacity: 0.3;"><i class="fa-solid fa-money-bill-transfer"></i></div>
        Belum ada riwayat mutasi saldo. Yuk <a href="/topup" style="color:var(--primary-color); font-weight:bold; text-decoration:none;">top up saldo</a> pertamamu.
      </div>
    <% } else { %>
      <div class="modern-table-wrapper">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Tanggal</th>
              <th>Keterangan</th>
              <th>Jenis</th>
              <th>Jumlah</th>
              <th>Saldo Akhir</th>
            </tr>
          </thead>
          <tbody>
            <% entries.forEach(e => { %>
            <tr>
              <td style="color: var(--text-muted); font-size: 13px; white-space: nowrap;">
                <%= new Date(e.createdAt).toLocaleString('id-ID') %>
              </td>
              <td>
                <div style="font-weight: 600; color: var(--text-dark); line-height: 1.4;"><%= e.reason %></div>
                <% if (e.refType === 'order' && e.refId) { %>
                  <a href="/riwayat/<%= e.refId %>" class="ref-link"><i class="fa-solid fa-receipt"></i> <%= e.refId %></a>
                <% } else if (e.refType === 'deposit' && e.refId) { %>
                  <span class="ref-text"><i class="fa-solid fa-qrcode"></i> <%= e.refId %></span>
                <% } %>
              </td>
              <td>
                <span class="badge-modern <%= e.type === 'masuk' ? 'badge-masuk' : 'badge-keluar' %>">
                  <i class="fa-solid <%= e.type === 'masuk' ? 'fa-arrow-down' : 'fa-arrow-up' %>" style="margin-right:4px;"></i>
                  <%= e.type === 'masuk' ? 'Masuk' : 'Keluar' %>
                </span>
              </td>
              <td class="<%= e.type === 'masuk' ? 'amount-masuk' : 'amount-keluar' %>">
                <%= e.type === 'masuk' ? '+' : '-' %> Rp <%= e.amount.toLocaleString('id-ID') %>
              </td>
              <td class="amount-neutral">
                Rp <%= e.balanceAfter.toLocaleString('id-ID') %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <%- include('partials/footer') %>
  </div>
</div>
</body>
</html>

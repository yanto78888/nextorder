<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    /* Styling Modern QRIS Payment */
    .qris-wrap { max-width: 460px; margin: 0 auto; padding-bottom: 40px; }
    .qris-card { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--shadow-md); padding: 30px 25px; text-align: center; border: 1px solid var(--border-color); }
    
    .qris-header-title { font-size: 22px; font-weight: 900; color: var(--text-dark); margin-bottom: 6px; }
    .qris-header-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; line-height: 1.5; }
    
    .qris-product-info { background: var(--bg-color); border-radius: 12px; padding: 16px; margin-bottom: 24px; text-align: left; border: 1px solid var(--border-color); display: flex; flex-direction: column; gap: 4px; }
    .qris-product-info .pname { font-weight: 800; font-size: 15px; color: var(--text-dark); }
    .qris-product-info .pqty { font-size: 13px; color: var(--text-muted); font-weight: 600; }
    .qris-product-info .ptarget { font-size: 13px; color: var(--primary-color); font-weight: 700; margin-top: 4px; background: rgba(0,123,255,0.1); padding: 4px 8px; border-radius: 6px; display: inline-table; }
    
    .qris-img-wrap { padding: 15px; background: #fff; border-radius: 16px; border: 2px dashed #cbd5e1; display: inline-block; margin-bottom: 20px; box-shadow: var(--shadow-sm); }
    .qris-img { width: 220px; height: 220px; object-fit: contain; display: block; }
    
    .qris-amount-box { margin-bottom: 24px; }
    .qris-amount-label { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .qris-amount-value { font-size: 34px; font-weight: 900; color: var(--primary-color); }
    
    .qris-note { background: #fffbeb; color: #b45309; padding: 14px; border-radius: 10px; font-size: 13px; border: 1px solid #fde68a; margin-bottom: 24px; line-height: 1.5; text-align: left; display: flex; gap: 12px; align-items: flex-start; }
    .qris-note i { font-size: 18px; margin-top: 2px; }
    
    .qris-timer-wrap { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 16px; }
    .qris-timer-wrap span { font-size: 13px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; }
    .qris-timer { background: #fef2f2; color: #ef4444; font-size: 22px; font-weight: 900; padding: 6px 14px; border-radius: 8px; border: 1px solid #fecaca; font-family: 'Courier New', Courier, monospace; }
    
    .qris-status { padding: 14px; border-radius: 10px; font-size: 14px; font-weight: 700; margin-bottom: 24px; display: flex; justify-content: center; align-items: center; gap: 8px; }
    .qris-status.pending { background: #fef3c7; border: 1px solid #fde68a; color: #d97706; }
    .qris-status.paid { background: #d1fae5; border: 1px solid #a7f3d0; color: #059669; }
    .qris-status.expired { background: #fee2e2; border: 1px solid #fecaca; color: #dc2626; }
    
    .btn-cancel-modern { display: block; width: 100%; padding: 14px; background: var(--bg-color); color: var(--text-dark); border: 2px solid var(--border-color); border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; transition: 0.3s; text-align: center; text-decoration: none; box-sizing: border-box; }
    .btn-cancel-modern:hover { background: #e2e8f0; border-color: #cbd5e1; }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk', user, config }) %>

  <div class="main no-bottom-nav">
    <div class="qris-wrap">
      <div class="qris-card">
        
        <div class="qris-header-title">Bayar via QRIS</div>
        <div class="qris-header-sub">Scan QR di bawah menggunakan m-banking atau e-wallet manapun (Gopay, OVO, Dana, ShopeePay, dll).</div>

        <div class="qris-product-info">
          <div class="pname"><%= product.name %></div>
          <div class="pqty">Jumlah pesanan: <%= qty %> item</div>
          <% if (typeof targetText !== 'undefined' && targetText) { %>
            <div><span class="ptarget"><i class="fa-solid fa-crosshairs"></i> <%= targetText %></span></div>
          <% } %>
        </div>

        <div class="qris-img-wrap">
          <img class="qris-img" src="<%= deposit.imageBase64 %>" alt="QRIS">
        </div>

        <div class="qris-amount-box">
          <div class="qris-amount-label">Total Pembayaran</div>
          <div class="qris-amount-value">Rp <%= total.toLocaleString('id-ID') %></div>
        </div>

        <div class="qris-note">
          <i class="fa-solid fa-triangle-exclamation"></i> 
          <div>Bayar <b>tepat sesuai nominal</b> di atas (sudah termasuk kode unik & biaya layanan). Kesalahan nominal dapat membuat pesanan gagal diproses.</div>
        </div>

        <div class="qris-timer-wrap">
          <span>Sisa Waktu:</span>
          <div class="qris-timer" id="timerEl">--:--</div>
        </div>

        <div class="qris-status pending" id="statusEl">
          <i class="fa-solid fa-hourglass-half"></i> Menunggu pembayaran...
        </div>

        <a href="/produk/<%= product.id %>" class="btn-cancel-modern">Batal / Kembali</a>
      </div>
    </div>
  </div>
</div>
</body>
</html>

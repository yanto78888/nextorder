<!DOCTYPE html>
<html lang="id">
<head><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'topup' }) %>

  <div class="main">
    <div class="topbar">
      <h2>Top Up Saldo</h2>
      <div class="user-chip"><span class="dot"></span> Saldo: Rp <%= user.saldo.toLocaleString('id-ID') %></div>
    </div>

    <div class="grid grid-2">
      <div class="card" id="form-card">
        <h3>Isi Saldo via QRIS</h3>
        <p class="helper-text">Masukkan nominal top up. QR dinamis akan otomatis dibuat sesuai nominal + fee + kode unik.</p>
        <label>Nominal Top Up (Rp)</label>
        <input type="number" id="amount" min="<%= config.qris.depositMin %>" placeholder="Contoh: 50000">
        <button class="btn solid mt-24" id="btn-create" style="width:100%;">Generate QRIS</button>
        <div id="form-error" class="alert error" style="display:none; margin-top:14px;"></div>
      </div>

      <div class="card" id="qr-card" style="display:none;">
        <h3>Scan QRIS di Bawah</h3>
        <div class="qr-box">
          <img id="qr-image" src="" alt="QR Deposit">
          <div class="qr-timer" id="qr-timer">10:00</div>
          <div class="qr-status" id="qr-status">Menunggu pembayaran...</div>
        </div>
        <table style="margin-top:10px;">
          <tr><td>Nominal Topup</td><td class="mono" id="d-amount"></td></tr>
          <tr><td>Total Bayar</td><td class="mono" id="d-total"></td></tr>
          <tr><td>ID Transaksi</td><td class="mono" id="d-trxid"></td></tr>
        </table>
      </div>
    </div>

    <div class="section-title"><h3>Riwayat Top Up</h3><div class="line"></div></div>
    <div class="card">
      <% if (deposits.length === 0) { %>
        <div class="empty-state">Belum ada riwayat top up.</div>
      <% } else { %>
      <table>
        <thead><tr><th>ID</th><th>Nominal</th><th>Total Bayar</th><th>Status</th><th>Tanggal</th></tr></thead>
        <tbody>
          <% deposits.forEach(d => { %>
          <tr>
            <td class="mono"><%= d.trxid %></td>
            <td class="mono">Rp <%= d.amount.toLocaleString('id-ID') %></td>
            <td class="mono">Rp <%= d.total.toLocaleString('id-ID') %></td>
            <td><span class="badge <%= d.status %>"><%= d.status %></span></td>
            <td><%= new Date(d.createdAt).toLocaleString('id-ID') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<script src="/js/topup.js"></script>
</body>
</html>

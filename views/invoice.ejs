<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    /* Styling Modern Invoice */
    .inv-wrap { max-width: 500px; margin: 0 auto; padding-bottom: 40px; }
    .inv-card { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--shadow-md); overflow: hidden; border: 1px solid var(--border-color); }
    
    .inv-status-band { padding: 30px 20px; text-align: center; }
    .inv-status-band.completed { background: linear-gradient(135deg, #ecfdf5, #d1fae5); }
    .inv-status-band.processing { background: linear-gradient(135deg, #fffbeb, #fef3c7); }
    .inv-status-band.cancelled { background: linear-gradient(135deg, #fef2f2, #fee2e2); }
    
    .inv-status-icon { font-size: 50px; margin-bottom: 12px; }
    .inv-status-icon.completed { color: #10b981; }
    .inv-status-icon.processing { color: #f59e0b; }
    .inv-status-icon.cancelled { color: #ef4444; }
    
    .inv-status-title { font-size: 20px; font-weight: 900; color: var(--text-dark); margin-bottom: 5px; }
    .inv-status-sub { font-size: 13px; color: var(--text-muted); padding: 0 10px; line-height: 1.5; }
    
    .inv-body { padding: 25px; }
    .inv-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 12px 0; border-bottom: 1px dashed var(--border-color); font-size: 14px; gap: 15px; }
    .inv-row:last-child { border-bottom: none; }
    .inv-label { color: var(--text-muted); flex-shrink: 0; font-weight: 600; }
    .inv-value { text-align: right; font-weight: 700; color: var(--text-dark); word-break: break-word; }
    .inv-value.mono { font-family: 'Courier New', Courier, monospace; color: var(--text-muted); }
    
    .inv-total-row { display: flex; justify-content: space-between; align-items: center; padding: 18px 25px; background: var(--bg-color); border-top: 2px dashed var(--border-color); border-bottom: 2px dashed var(--border-color); }
    .inv-total-label { font-size: 15px; color: var(--text-dark); font-weight: 800; text-transform: uppercase; }
    .inv-total-value { font-size: 22px; font-weight: 900; color: var(--primary-color); }
    
    .inv-detail-box { margin: 20px 25px; padding: 16px; background: var(--bg-color); border-radius: 12px; border: 1px solid var(--border-color); }
    .inv-detail-title { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-dark); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .inv-detail-content { font-size: 14px; white-space: pre-wrap; word-break: break-word; font-family: 'Courier New', Courier, monospace; color: var(--text-dark); background: #fff; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; }
    
    .inv-barcode { text-align: center; padding: 0 25px 25px; color: var(--text-muted); font-size: 13px; letter-spacing: 3px; font-family: 'Courier New', Courier, monospace; opacity: 0.6; }
    
    .inv-actions { display: flex; gap: 12px; padding: 0 25px 30px; }
    .btn-ghost-modern { flex: 1; padding: 14px; background: #fff; color: var(--text-dark); border: 2px solid var(--border-color); border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; transition: 0.3s; text-align: center; text-decoration: none; }
    .btn-ghost-modern:hover { background: var(--bg-color); border-color: #cbd5e1; }
    .btn-main-modern { flex: 1; padding: 14px; background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); color: white; border: none; border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; transition: 0.3s; text-align: center; text-decoration: none; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
    .btn-main-modern:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,123,255,0.3); }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'riwayat', user, config }) %>

  <div class="main no-bottom-nav">
    <div class="inv-wrap">

      <% if (success) { %>
        <div style="background:#f0fdf4; color:#059669; padding:15px; border-radius:12px; border: 1px solid #a7f3d0; margin-bottom: 20px; text-align: center; font-weight: 600;">
          <i class="fa-solid fa-circle-check"></i> <%= success %>
        </div>
      <% } %>

      <div class="inv-card">
        <% const statusClass = order.status === 'completed' ? 'completed' : (order.status === 'cancelled' ? 'cancelled' : 'processing'); %>
        <div class="inv-status-band <%= statusClass %>">
          <div class="inv-status-icon <%= statusClass %>">
            <% if (statusClass === 'completed') { %><i class="fa-solid fa-circle-check"></i>
            <% } else if (statusClass === 'cancelled') { %><i class="fa-solid fa-circle-xmark"></i>
            <% } else { %><i class="fa-solid fa-hourglass-half"></i><% } %>
          </div>
          <div class="inv-status-title">
            <% if (statusClass === 'completed') { %>Pesanan Selesai
            <% } else if (statusClass === 'cancelled') { %>Pesanan Dibatalkan
            <% } else { %>Sedang Diproses<% } %>
          </div>
          <div class="inv-status-sub">
            <% if (statusClass === 'completed') { %>Produk sudah berhasil dikirim ke akunmu.
            <% } else if (statusClass === 'cancelled') { %><%= order.note || 'Pesanan dibatalkan, saldo dikembalikan jika ada pemotongan.' %>
            <% } else if (order.cancelRequestedAt) { %>Permintaan pembatalan terkirim, menunggu konfirmasi dari provider (halaman ini update otomatis).
            <% } else if (order.provider === 'digiflazz' || order.provider === 'indosmm') { %>Sedang diproses otomatis oleh sistem, halaman ini akan update otomatis.
            <% } else { %>Stok otomatis sedang habis, admin akan kirim manual secepatnya.<% } %>
          </div>
        </div>

        <div class="inv-body">
          <div class="inv-row">
            <span class="inv-label">No. Invoice</span>
            <span class="inv-value mono"><%= order.id %></span>
          </div>
          <div class="inv-row">
            <span class="inv-label">Produk</span>
            <span class="inv-value"><%= order.productName %></span>
          </div>
          <% if (order.targetText) { %>
          <div class="inv-row">
            <span class="inv-label">Tujuan</span>
            <span class="inv-value"><%= order.targetText %></span>
          </div>
          <% } %>
          <div class="inv-row">
            <span class="inv-label">Jumlah</span>
            <span class="inv-value"><%= order.qty %>x</span>
          </div>
          <div class="inv-row">
            <span class="inv-label">Metode Bayar</span>
            <span class="inv-value"><%= order.source === 'qris' ? 'QRIS' : 'Saldo Akun' %></span>
          </div>
          <div class="inv-row">
            <span class="inv-label">Tanggal</span>
            <span class="inv-value"><%= new Date(order.createdAt).toLocaleString('id-ID') %></span>
          </div>
        </div>

        <div class="inv-total-row">
          <span class="inv-total-label">Total Bayar</span>
          <span class="inv-total-value">Rp <%= order.total.toLocaleString('id-ID') %></span>
        </div>

        <% if (order.status === 'completed' && order.detail) { %>
          <div class="inv-detail-box">
            <div class="inv-detail-title"><i class="fa-solid fa-key" style="color: var(--primary-color);"></i> Detail Produk / Kode</div>
            <div class="inv-detail-content"><%= order.detail %></div>
          </div>
        <% } %>

        <% if (order.status === 'completed' && usageInstructions) { %>
          <div class="inv-detail-box">
            <div class="inv-detail-title"><i class="fa-solid fa-circle-info" style="color: var(--primary-color);"></i> Cara Menggunakan</div>
            <div class="inv-detail-content"><%= usageInstructions %></div>
          </div>
        <% } %>

        <div class="inv-barcode">* * * * * <%= order.id %> * * * * *</div>

        <div class="inv-actions">
          <a href="/riwayat" class="btn-ghost-modern">Riwayat Lain</a>
          <a href="/produk" class="btn-main-modern"><i class="fa-solid fa-cart-shopping"></i> Beli Lagi</a>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>

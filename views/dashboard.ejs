<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    /* Styling khusus Dashboard */
    .dashboard-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
    .dash-stat-card { background: var(--card-bg); padding: 25px; border-radius: var(--border-radius); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between; border: 1px solid var(--border-color); }
    .dash-stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 800; letter-spacing: 0.5px; margin-bottom: 8px; }
    .dash-stat-value { font-size: 26px; font-weight: 900; color: var(--text-dark); margin-bottom: 12px; }
    .dash-stat-value.primary { color: var(--primary-color); }
    .dash-stat-value.success { color: var(--secondary-color); }

    /* Modern Table untuk Riwayat Order */
    .modern-table-wrapper { background: var(--card-bg); border-radius: var(--border-radius); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 24px; border: 1px solid var(--border-color); }
    .modern-table { width: 100%; border-collapse: collapse; text-align: left; }
    .modern-table th { background: var(--bg-color); padding: 16px 20px; font-size: 13px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; border-bottom: 1px solid var(--border-color); }
    .modern-table td { padding: 16px 20px; border-bottom: 1px solid var(--border-color); font-size: 14px; color: var(--text-dark); }
    .modern-table tr:last-child td { border-bottom: none; }
    .modern-table tr:hover td { background-color: #f8fafc; }
    
    /* Status & User Badges */
    .modern-badge { padding: 5px 12px; border-radius: 8px; font-size: 12px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; }
    .modern-badge.completed { background: #d1fae5; color: #059669; }
    .modern-badge.processing { background: #fef3c7; color: #d97706; }
    .modern-badge.cancelled { background: #fee2e2; color: #dc2626; }
    .modern-badge.platinum { background: #e0e7ff; color: #4338ca; border: 1px solid #c7d2fe; box-shadow: 0 2px 8px rgba(67,56,202,0.15); }
    .modern-badge.gold { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; box-shadow: 0 2px 8px rgba(180,83,9,0.15); }
    
    .user-chip-modern { background: var(--bg-color); padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: 700; color: var(--primary-color); border: 1px solid var(--border-color); display: inline-flex; align-items: center; gap: 8px; }
    
    @media (max-width: 768px) {
      .modern-table-wrapper { overflow-x: auto; }
      .modern-table th, .modern-table td { white-space: nowrap; }
    }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'dashboard' }) %>

  <div class="main no-bottom-nav">
    
    <!-- Topbar & Profil Mini -->
    <div class="dashboard-header-row">
      <div class="detail-section-title" style="margin: 0; border: none; padding: 0;"><i class="fa-solid fa-house"></i> Dashboard</div>
      <div style="display: flex; gap: 10px; align-items: center;">
        <% if ((user.membership || 'reguler') !== 'reguler') { %>
          <span class="modern-badge <%= user.membership %>"><%= user.membership === 'platinum' ? '💎 Platinum' : '🥇 Gold' %></span>
        <% } %>
        <div class="user-chip-modern"><i class="fa-solid fa-circle-user"></i> <%= user.username %></div>
      </div>
    </div>

    <!-- Metrik Utama -->
    <div class="stat-grid">
      <div class="dash-stat-card">
        <div>
          <div class="dash-stat-label">Saldo Aktif</div>
          <div class="dash-stat-value primary">Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        </div>
        <a href="/topup" class="buy-main-btn" style="padding: 10px 15px; font-size: 14px; text-align: center; text-decoration: none; width: auto;"><i class="fa-solid fa-wallet"></i> Top Up Saldo</a>
      </div>
      <div class="dash-stat-card">
        <div>
          <div class="dash-stat-label">Total Order</div>
          <div class="dash-stat-value"><%= totalOrder %></div>
        </div>
      </div>
      <div class="dash-stat-card">
        <div>
          <div class="dash-stat-label">Total Pembelanjaan</div>
          <div class="dash-stat-value success">Rp <%= totalSpent.toLocaleString('id-ID') %></div>
        </div>
      </div>
    </div>

    <div class="detail-section-title"><i class="fa-solid fa-clock-rotate-left"></i> Order Terbaru</div>
    
    <!-- Tabel Order Terbaru -->
    <% if (recentOrders.length === 0) { %>
      <div class="card empty-state" style="text-align:center; color: var(--text-muted);">
        <div style="font-size: 40px; margin-bottom: 15px; opacity: 0.3;"><i class="fa-solid fa-box-open"></i></div>
        Belum ada order. <a href="/produk" style="color:var(--primary-color); font-weight:bold; text-decoration:none;">Mulai belanja →</a>
      </div>
    <% } else { %>
      <div class="modern-table-wrapper">
        <table class="modern-table">
          <thead>
            <tr>
              <th>ID Transaksi</th>
              <th>Produk</th>
              <th>Total</th>
              <th>Status</th>
              <th>Tanggal</th>
            </tr>
          </thead>
          <tbody>
            <% recentOrders.forEach(o => { %>
            <tr>
              <td style="font-family: 'Courier New', Courier, monospace; font-weight: 700; color: var(--text-muted);"><%= o.id %></td>
              <td style="font-weight: 700;"><%= o.productName %></td>
              <td style="font-weight: 800;">Rp <%= o.total.toLocaleString('id-ID') %></td>
              <td><span class="modern-badge <%= o.status %>"><%= o.status %></span></td>
              <td style="color: var(--text-muted); font-size: 13px;"><%= new Date(o.createdAt).toLocaleString('id-ID') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>
</div>
</body>
</html>

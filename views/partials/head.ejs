<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= typeof title !== 'undefined' ? title + ' - ' + (config.siteName || 'TOPUP SHOP') : (config.siteName || 'TOPUP SHOP') %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : (config.siteTagline || 'Layanan top up game & produk digital otomatis, aman, dan terpercaya.') %>">
<meta name="theme-color" content="#007bff"> <!-- Ganti hex color sesuai dengan --primary-color di bawah -->

<!-- Favicon -->
<link rel="icon" href="<%= (typeof config !== 'undefined' && config.favicon) ? config.favicon : '/assets/favicon.ico' %>" type="image/x-icon">
<link rel="shortcut icon" href="<%= (typeof config !== 'undefined' && config.favicon) ? config.favicon : '/assets/favicon.ico' %>" type="image/x-icon">

<!-- Google Fonts: Menggunakan 'Inter' untuk tampilan bersih, modern, dan profesional -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<!-- FontAwesome untuk Icon -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Global CSS & Variables -->
<style>
  :root {
    /* 
      TEMA WARNA UTAMA 
      Ubah --primary-color di bawah ini, maka seluruh warna tombol, border aktif, 
      dan teks utama di website akan otomatis berubah menyesuaikan!
    */
    --primary-color: #007bff;     /* Warna Utama (Biru Codashop) */
    --primary-hover: #0056b3;     /* Warna saat tombol di-hover (Biru Gelap) */
    
    /* Warna Background & Elemen */
    --bg-color: #f4f7f9;          /* Latar belakang halaman */
    --card-bg: #ffffff;           /* Latar belakang kartu/kontainer */
    
    /* Warna Teks */
    --text-dark: #1e293b;         /* Teks utama (Hitam keabu-abuan) */
    --text-muted: #64748b;        /* Teks sekunder/keterangan (Abu-abu) */
    
    /* Border & Bayangan (Shadow) */
    --border-color: #e2e8f0;      /* Garis tepi */
    --border-radius: 16px;        /* Kelengkungan sudut seragam */
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
    --shadow-md: 0 8px 24px rgba(0,0,0,0.08);
  }

  /* Reset CSS & Base Styles */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-dark);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* Scrollbar Kustom agar terlihat lebih rapi di Desktop */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg-color);
  }
  ::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  /* Container Utama untuk membatasi lebar maksimal di layar besar */
  .app-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }
</style>

<style>
  /* Styling Modern Flash Sale Carousel / Grid */
  .fs-section { background: var(--card-bg); border-radius: var(--border-radius); padding: 25px; box-shadow: var(--shadow-sm); margin-bottom: 24px; border: 1px solid var(--border-color); }
  
  .fs-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
  .fs-header-left { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .fs-title { font-size: 18px; font-weight: 900; color: var(--text-dark); display: flex; align-items: center; gap: 8px; }
  .fs-title i { color: #fbbf24; font-size: 22px; }
  
  .fs-countdown { background: #fef2f2; color: #dc2626; padding: 6px 12px; border-radius: 8px; font-size: 14px; font-weight: 800; border: 1px solid #fecaca; font-family: 'Courier New', Courier, monospace; display: flex; align-items: center; gap: 6px; }
  .fs-see-all { font-size: 13px; font-weight: 700; color: var(--primary-color); text-decoration: none; padding: 6px 12px; background: rgba(0,123,255,0.1); border-radius: 8px; transition: 0.2s; }
  .fs-see-all:hover { background: var(--primary-color); color: white; }

  /* Track layout: Slider (scroll) vs Grid */
  .fs-track { display: flex; gap: 16px; overflow-x: auto; padding-bottom: 10px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
  .fs-track::-webkit-scrollbar { height: 6px; }
  .fs-track::-webkit-scrollbar-track { background: var(--bg-color); border-radius: 4px; }
  .fs-track::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .fs-track.fs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); overflow-x: visible; }
  
  .fs-card { flex: 0 0 160px; scroll-snap-align: start; background: var(--bg-color); border: 2px solid var(--border-color); border-radius: 12px; overflow: hidden; text-decoration: none; transition: 0.3s; position: relative; display: flex; flex-direction: column; }
  .fs-track.fs-grid .fs-card { flex: auto; }
  .fs-card:hover { border-color: var(--primary-color); transform: translateY(-4px); box-shadow: 0 8px 20px rgba(0,123,255,0.15); }
  
  .fs-badge { position: absolute; top: 8px; right: 8px; background: #ef4444; color: white; font-size: 10px; font-weight: 800; padding: 4px 8px; border-radius: 6px; z-index: 2; box-shadow: 0 2px 5px rgba(239,68,68,0.4); text-transform: uppercase; letter-spacing: 0.5px; }
  
  .fs-card-thumb { width: 100%; height: 120px; background: var(--border-color); position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .fs-card-thumb img { width: 100%; height: 100%; object-fit: cover; transition: 0.3s; }
  .fs-card:hover .fs-card-thumb img { transform: scale(1.05); }
  .nf-noimg { font-size: 40px; font-weight: 900; color: #fff; text-transform: uppercase; background: var(--primary-color); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  
  .fs-card-body { padding: 12px; display: flex; flex-direction: column; flex: 1; }
  .fs-card-name { font-size: 13px; font-weight: 800; color: var(--text-dark); margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
  .fs-card-cat { font-size: 11px; color: var(--text-muted); font-weight: 600; margin-bottom: 8px; }
  
  .fs-card-price { margin-bottom: 10px; }
  .nf-price-old { font-size: 11px; text-decoration: line-through; color: var(--text-muted); display: block; margin-bottom: 2px; }
  .nf-price-now { font-size: 14px; font-weight: 900; color: var(--primary-color); }
  
  /* Modern Progress Bar */
  .fs-stock { margin-top: auto; margin-bottom: 10px; background: #fff; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0; }
  .fs-stock-label { font-size: 10px; font-weight: 800; color: var(--text-muted); display: block; margin-bottom: 5px; text-transform: uppercase; text-align: center; }
  .fs-stock-bar { width: 100%; height: 6px; background: #e2e8f0; border-radius: 4px; display: block; overflow: hidden; }
  .fs-stock-fill { height: 100%; background: linear-gradient(90deg, #ef4444, #f59e0b); display: block; border-radius: 4px; transition: width 0.5s ease; }
  
  .fs-buy-btn { display: block; width: 100%; padding: 8px 0; text-align: center; background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); color: white; font-size: 12px; font-weight: 800; border-radius: 8px; transition: 0.3s; text-transform: uppercase; }
  .fs-buy-btn.disabled { background: #cbd5e1; color: #64748b; cursor: not-allowed; }
</style>

<%
/* Partial carousel Flash Sale. Locals yang dipakai:
   - flashSaleItems  : array hasil getFlashSaleDisplayItems() (wajib, kalau kosong/undefined partial gak nampilin apa-apa)
   - flashSaleSettings : { enabled, endsAt, title } dari getFlashSaleSettings()
   - fsGrid (opsional) : true = tampil grid penuh (dipakai di /flash-sale "Lihat Semua"), default carousel geser
   - fsShowSeeAll (opsional) : false = sembunyikan link "Lihat Semua" (dipakai di halaman /flash-sale sendiri)
*/
const _items = typeof flashSaleItems !== 'undefined' ? flashSaleItems : [];
const _settings = (typeof flashSaleSettings !== 'undefined' && flashSaleSettings) ? flashSaleSettings : {};
const _isGrid = typeof fsGrid !== 'undefined' && fsGrid;
const _showSeeAll = typeof fsShowSeeAll !== 'undefined' ? fsShowSeeAll : true;
%>
<% if (_items.length > 0) { %>
<div class="fs-section" id="flashSaleSection" data-ends-at="<%= _settings.endsAt || '' %>">
  
  <div class="fs-header">
    <div class="fs-header-left">
      <div class="fs-title"><i class="fa-solid fa-bolt-lightning"></i> <%= _settings.title || 'Flash Sale' %></div>
      <% if (_settings.endsAt) { %>
        <div class="fs-countdown" id="fsCountdown"><i class="fa-solid fa-clock"></i> --:--:--</div>
      <% } %>
    </div>
    <% if (_showSeeAll) { %><a href="/flash-sale" class="fs-see-all">Lihat Semua <i class="fa-solid fa-angle-right"></i></a><% } %>
  </div>

  <div class="fs-track <%= _isGrid ? 'fs-grid' : '' %>">
    <% _items.forEach(item => { %>
      <% const soldOut = !item.isAuto && item.stockCount <= 0; %>
      <a href="/produk/<%= item.productId %>" class="fs-card">
        <% if (item.badge) { %><span class="fs-badge"><i class="fa-solid fa-fire"></i> <%= item.badge %></span><% } %>
        
        <div class="fs-card-thumb">
          <% if (item.thumbnail) { %><img src="<%= item.thumbnail %>" alt="<%= item.name %>" loading="lazy"><% } else { %><span class="nf-noimg"><%= item.name.slice(0,1) %></span><% } %>
        </div>
        
        <div class="fs-card-body">
          <div class="fs-card-name"><%= item.name %></div>
          <% if (item.category) { %><div class="fs-card-cat"><%= item.category %></div><% } %>
          
          <div class="fs-card-price">
            <% if (item.originalPrice > item.flashPrice) { %><span class="nf-price-old">Rp <%= item.originalPrice.toLocaleString('id-ID') %></span><% } %>
            <span class="nf-price-now">Rp <%= item.flashPrice.toLocaleString('id-ID') %></span>
          </div>
          
          <%
            // Logika kalkulasi stok bawaan dipertahankan 100%
            let fillPct = 100;
            let stockLabel = soldOut ? 'habis' : 'tersedia';
            if (item.quota > 0) {
              fillPct = Math.max(4, Math.min(100, Math.round((item.remaining / item.quota) * 100)));
              stockLabel = 'Sisa ' + item.remaining + '/' + item.quota;
            } else if (!item.isAuto) {
              fillPct = item.stockCount <= 0 ? 0 : Math.min(100, Math.max(8, Math.round((item.stockCount / 20) * 100)));
            }
          %>
          <div class="fs-stock">
            <span class="fs-stock-label"><%= stockLabel %></span>
            <span class="fs-stock-bar"><span class="fs-stock-fill" style="width:<%= fillPct %>%"></span></span>
          </div>
          
          <span class="fs-buy-btn <%= soldOut ? 'disabled' : '' %>"><%= soldOut ? 'Habis' : 'Beli Sekarang' %></span>
        </div>
      </a>
    <% }) %>
  </div>
</div>

<!-- SCRIPT COUNTDOWN TETAP SAMA -->
<script>
(function () {
  var section = document.getElementById('flashSaleSection');
  var countdownEl = document.getElementById('fsCountdown');
  if (!section || !countdownEl) return;
  var endsAt = section.getAttribute('data-ends-at');
  if (!endsAt) return;
  var endTime = new Date(endsAt).getTime();
  if (isNaN(endTime)) return;

  function pad(n) { return String(n).padStart(2, '0'); }
  var timer;
  function tick() {
    var diff = endTime - Date.now();
    if (diff <= 0) {
      countdownEl.innerHTML = '<i class="fa-solid fa-clock"></i> Berakhir';
      clearInterval(timer);
      return;
    }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    countdownEl.innerHTML = '<i class="fa-solid fa-clock"></i> ' + pad(h) + ':' + pad(m) + ':' + pad(s);
  }
  tick();
  timer = setInterval(tick, 1000);
})();
</script>
<% } %>

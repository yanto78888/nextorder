<style>
  /* Styling Modern SMM Rules Modal */
  .smm-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); z-index: 1000; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: 0.3s; padding: 20px; }
  .smm-modal-overlay.open { opacity: 1; visibility: visible; }
  
  .smm-modal-card { background: var(--card-bg); border-radius: 20px; padding: 25px 30px; width: 100%; max-width: 480px; box-shadow: var(--shadow-md); transform: translateY(20px); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); border: 1px solid var(--border-color); max-height: 85vh; display: flex; flex-direction: column; }
  .smm-modal-overlay.open .smm-modal-card { transform: translateY(0); }
  
  .smm-modal-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; border-bottom: 2px dashed var(--border-color); padding-bottom: 15px; }
  .smm-modal-header i { font-size: 26px; color: var(--primary-color); }
  .smm-modal-header h3 { font-size: 18px; font-weight: 900; color: var(--text-dark); margin: 0; }
  
  .smm-modal-body { overflow-y: auto; padding-right: 5px; margin-bottom: 20px; }
  .smm-modal-body::-webkit-scrollbar { width: 6px; }
  .smm-modal-body::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  
  .smm-rules-list-modern { padding: 0 0 0 20px; margin: 0; color: var(--text-muted); font-size: 13.5px; line-height: 1.6; }
  .smm-rules-list-modern li { margin-bottom: 12px; }
  .smm-rules-list-modern li b { color: var(--text-dark); font-weight: 800; }
  .smm-rules-list-modern li:last-child { margin-bottom: 0; }
  
  .btn-smm-ack { display: block; width: 100%; padding: 14px; background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); color: white; border: none; border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 10px rgba(0,123,255,0.2); text-align: center; }
  .btn-smm-ack:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,123,255,0.3); }
</style>

<%
  const waRawSmm = ((typeof config !== 'undefined' && config.ownerWhatsapp) || '').replace(/[^0-9]/g, '');
  const waNumberSmm = waRawSmm ? (waRawSmm.startsWith('0') ? '62' + waRawSmm.slice(1) : waRawSmm) : '';
  const waLinkSmm = waNumberSmm ? ('https://wa.me/' + waNumberSmm + '?text=' + encodeURIComponent('Halo, saya mau tanya soal pesanan Jasa Sosmed.')) : '';
%>

<div class="smm-modal-overlay" id="smmRulesOverlay">
  <div class="smm-modal-card">
    
    <div class="smm-modal-header">
      <i class="fa-solid fa-circle-exclamation"></i>
      <h3>Ketentuan Jasa Sosmed</h3>
    </div>
    
    <div class="smm-modal-body">
      <ol class="smm-rules-list-modern">
        <li><b>Pastikan link yang diinput sudah benar</b> sebelum checkout. Pesanan yang sudah diproses <b>tidak bisa dibatalkan</b>, dan kesalahan input dari pembeli bukan tanggung jawab kami.</li>
        <li><b>Jangan order lebih dari 1x</b> untuk link/akun yang sama dalam waktu bersamaan. Ini tidak mempercepat proses — malah bisa bikin salah satu pesanan gak kehitung, dan tidak ada pengembalian dana untuk kasus ini.</li>
        <li>Kalau akun/link diganti, di-private, atau dihapus <b>setelah</b> pesanan dibuat, pesanan otomatis dianggap selesai dan <b>tidak ada pengembalian dana</b>.</li>
        <li>Status pesanan <b>"Sebagian Terkirim"</b> atau <b>"Dibatalkan"</b> → saldo otomatis dikembalikan ke akunmu, bisa langsung order ulang.</li>
        <li><b>Jumlah maksimal</b> pada tiap layanan berlaku untuk 1 akun/link (bukan per 1x order) — kalau kapasitasnya sudah kepakai penuh, akun/link itu gak bisa ditambah lagi walau pakai layanan lain.</li>
        <li>Estimasi waktu mulai &amp; kecepatan proses di halaman produk bisa berubah tergantung kondisi server, bukan patokan pasti.</li>
        <li>Butuh refill (kalau layanannya bergaransi) atau pesanan macet lama? <% if (waLinkSmm) { %>Hubungi admin lewat <a href="<%= waLinkSmm %>" target="_blank" rel="noopener" style="color:var(--primary-color); font-weight:bold; text-decoration:none;">WhatsApp</a> dan sertakan No. Invoice.<% } else { %>Hubungi admin dan sertakan No. Invoice.<% } %></li>
      </ol>
    </div>
    
    <div class="smm-modal-footer">
      <button type="button" class="btn-smm-ack" id="smmRulesAckBtn">Saya Mengerti &amp; Setuju</button>
    </div>
    
  </div>
</div>

<script>
(function () {
  var overlay = document.getElementById('smmRulesOverlay');
  var btn = document.getElementById('smmRulesAckBtn');
  if (!overlay || !btn) return;
  
  // Selalu munculkan modal dengan delay kecil agar animasi halus saat loading
  setTimeout(function() {
    overlay.classList.add('open');
  }, 300);
  
  // Hanya menutup modal tanpa menyimpan data ke localStorage
  btn.addEventListener('click', function () {
    overlay.classList.remove('open');
  });
})();
</script>

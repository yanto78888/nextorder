<style>
  /* Styling Modern Topbar & Sidebar (User) */
  .phone-topbar { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; position: sticky; top: 0; z-index: 40; box-shadow: var(--shadow-sm); }
  .hamburger-btn { background: none; border: none; font-size: 22px; color: var(--text-dark); cursor: pointer; transition: 0.2s; }
  .hamburger-btn:hover { color: var(--primary-color); }
  
  .brand-center { font-size: 18px; font-weight: 900; color: var(--primary-color); display: flex; flex-direction: column; align-items: center; line-height: 1.2; text-decoration: none; }
  .brand-center i { font-size: 20px; margin-bottom: 2px; }
  .brand-center small { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

  .avatar-btn { width: 38px; height: 38px; border-radius: 50%; background: var(--bg-color); border: 2px solid var(--border-color); display: flex; align-items: center; justify-content: center; overflow: hidden; text-decoration: none; color: var(--text-muted); font-weight: bold; transition: 0.3s; }
  .avatar-btn:hover { border-color: var(--primary-color); color: var(--primary-color); }
  .avatar-btn img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-guest { background: #f0f7ff; color: var(--primary-color); border-color: rgba(0,123,255,0.2); }

  /* Drawer / Sidebar Panel */
  .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(3px); z-index: 50; opacity: 0; visibility: hidden; transition: 0.3s ease; }
  .drawer-overlay.show { opacity: 1; visibility: visible; }
  
  .drawer { position: fixed; top: 0; left: -300px; width: 280px; height: 100%; background: var(--card-bg); z-index: 60; box-shadow: var(--shadow-md); transition: 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); display: flex; flex-direction: column; overflow-y: auto; }
  .drawer.show { left: 0; }

  .drawer-head { padding: 25px 20px; background: linear-gradient(135deg, var(--bg-color), #fff); border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: flex-start; }
  .drawer-user { display: flex; align-items: center; gap: 15px; }
  .drawer-avatar { width: 50px; height: 50px; border-radius: 50%; background: var(--primary-color); color: white; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; overflow: hidden; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
  .drawer-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .drawer-username { font-size: 16px; font-weight: 800; color: var(--text-dark); margin-bottom: 4px; }
  .drawer-saldo { font-size: 13px; font-weight: 700; color: var(--secondary-color); font-family: 'Courier New', Courier, monospace; }
  
  #drawerCloseBtn { background: #fef2f2; border: none; width: 32px; height: 32px; border-radius: 50%; color: #dc2626; cursor: pointer; font-size: 16px; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
  #drawerCloseBtn:hover { background: #fee2e2; transform: scale(1.1); }

  .drawer-nav { padding: 20px 15px; flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .drawer-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 10px; color: var(--text-dark); text-decoration: none; font-size: 14px; font-weight: 600; transition: 0.2s; }
  .drawer-link:hover { background: var(--bg-color); color: var(--primary-color); transform: translateX(4px); }
  .drawer-link.active { background: rgba(0,123,255,0.1); color: var(--primary-color); border-left: 4px solid var(--primary-color); border-radius: 0 10px 10px 0; }
  .nav-icon { width: 20px; text-align: center; font-size: 16px; opacity: 0.7; }
  .drawer-link:hover .nav-icon, .drawer-link.active .nav-icon { opacity: 1; }
  
  .drawer-link-group { background: #eff6ff; color: #1d4ed8; margin-top: 10px; border: 1px dashed #bfdbfe; }
  .drawer-link-group:hover { background: #dbeafe; border-color: #93c5fd; }

  .drawer-logout { padding: 20px; border-top: 1px solid var(--border-color); }
  .btn-logout { display: block; width: 100%; padding: 12px; background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; border-radius: 10px; font-size: 14px; font-weight: 800; cursor: pointer; transition: 0.3s; text-align: center; text-decoration: none; }
  .btn-logout:hover { background: #fee2e2; }

  /* Modal Grup Komunitas Modern */
  .group-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: 0.3s; padding: 20px; }
  .group-modal-overlay.show { opacity: 1; visibility: visible; }
  .group-modal { background: var(--card-bg); border-radius: 20px; padding: 30px; width: 100%; max-width: 380px; text-align: center; box-shadow: var(--shadow-md); transform: translateY(20px); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
  .group-modal-overlay.show .group-modal { transform: translateY(0); }
  .group-modal-icon { width: 70px; height: 70px; background: rgba(0,123,255,0.1); color: var(--primary-color); border-radius: 50%; font-size: 32px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
  .group-modal-title { font-size: 20px; font-weight: 900; color: var(--text-dark); margin-bottom: 10px; }
  .group-modal-msg { font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 24px; }
  .btn-group-cta { display: block; width: 100%; padding: 14px; background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); color: white; border: none; border-radius: 12px; font-size: 15px; font-weight: 800; cursor: pointer; transition: 0.3s; text-decoration: none; margin-bottom: 10px; box-shadow: 0 4px 10px rgba(0,123,255,0.2); }
  .btn-group-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,123,255,0.3); }
  .btn-group-later { display: block; width: 100%; padding: 12px; background: var(--bg-color); color: var(--text-dark); border: none; border-radius: 12px; font-size: 14px; font-weight: 700; cursor: pointer; transition: 0.2s; }
  .btn-group-later:hover { background: #e2e8f0; }
  .group-modal-check { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 12px; color: var(--text-muted); margin-top: 20px; cursor: pointer; }
</style>

<%
  const isGuest = !user;
  const avatarUrl = (!isGuest && user.avatar) ? user.avatar : '';
  const initial = isGuest ? '?' : (user.username || '?').charAt(0).toUpperCase();
  const community = (typeof config !== 'undefined' && config.community) ? config.community : {};
  const waRaw = ((typeof config !== 'undefined' && config.ownerWhatsapp) || '').replace(/[^0-9]/g, '');
  const waNumber = waRaw ? (waRaw.startsWith('0') ? '62' + waRaw.slice(1) : waRaw) : '';
  const waLink = waNumber ? ('https://wa.me/' + waNumber + '?text=' + encodeURIComponent('Halo ' + (config.siteName || '') + ', saya mau tanya-tanya.')) : '';
%>

<div class="phone-topbar">
  <button type="button" class="hamburger-btn" id="drawerOpenBtn" title="Menu" aria-label="Buka menu">
    <i class="fa-solid fa-bars"></i>
  </button>

  <a href="/produk" class="brand-center">
    <i class="fa-solid fa-bolt"></i> <%= config.siteName %>
    <small><%= config.siteTagline %></small>
  </a>

  <% if (isGuest) { %>
    <a href="/login" class="avatar-btn avatar-guest" title="Masuk / Daftar">
      <i class="fa-solid fa-user"></i>
    </a>
  <% } else { %>
    <a href="/profile" class="avatar-btn" title="Profil Saya">
      <% if (avatarUrl) { %>
        <img src="<%= avatarUrl %>" alt="<%= user.username %>">
      <% } else { %>
        <span class="avatar-initial"><%= initial %></span>
      <% } %>
    </a>
  <% } %>
</div>

<!-- ===== DRAWER MENU ===== -->
<div class="drawer-overlay" id="drawerOverlay"></div>
<aside class="drawer" id="drawerPanel">
  <div class="drawer-head">
    <div class="drawer-user">
      <div class="drawer-avatar">
        <% if (avatarUrl) { %>
          <img src="<%= avatarUrl %>" alt="<%= user.username %>">
        <% } else { %>
          <span><%= initial %></span>
        <% } %>
      </div>
      <div class="drawer-user-info">
        <div class="drawer-username"><%= isGuest ? 'Tamu' : user.username %></div>
        <% if (!isGuest) { %>
          <div class="drawer-saldo">Rp <%= user.saldo.toLocaleString('id-ID') %></div>
        <% } else { %>
          <div class="drawer-saldo" style="color: var(--text-muted); font-size: 11px;">Belum masuk akun</div>
        <% } %>
      </div>
    </div>
    <button type="button" id="drawerCloseBtn" title="Tutup" aria-label="Tutup menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <nav class="drawer-nav">
    <a href="/produk" class="drawer-link <%= active === 'produk' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-house"></i></span> Beranda</a>
    <a href="/jasa-sosmed" class="drawer-link <%= active === 'jasa-sosmed' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-share-nodes"></i></span> Jasa Sosmed</a>
    <a href="/daftar-harga" class="drawer-link <%= active === 'harga' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-tags"></i></span> Daftar Harga</a>
    <% if (!isGuest) { %>
      <a href="/topup" class="drawer-link <%= active === 'topup' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-credit-card"></i></span> Deposit / Top Up</a>
      <a href="/riwayat" class="drawer-link <%= active === 'riwayat' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-clock-rotate-left"></i></span> Riwayat Order</a>
      <a href="/riwayat-saldo" class="drawer-link <%= active === 'riwayat-saldo' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-wallet"></i></span> Riwayat Saldo</a>
      <a href="/profile" class="drawer-link <%= active === 'profile' ? 'active' : '' %>"><span class="nav-icon"><i class="fa-solid fa-user-gear"></i></span> Profil Saya</a>
    <% } else { %>
      <a href="/login" class="drawer-link"><span class="nav-icon"><i class="fa-solid fa-key"></i></span> Masuk</a>
      <a href="/register" class="drawer-link"><span class="nav-icon"><i class="fa-solid fa-user-plus"></i></span> Daftar Akun</a>
    <% } %>
    <% if (waLink) { %>
      <a href="<%= waLink %>" target="_blank" rel="noopener" class="drawer-link"><span class="nav-icon"><i class="fa-brands fa-whatsapp"></i></span> Bantuan / Kontak</a>
    <% } %>
    <% if (community.groupLink) { %>
      <a href="<%= community.groupLink %>" target="_blank" rel="noopener" class="drawer-link drawer-link-group"><span class="nav-icon"><i class="fa-solid fa-users"></i></span> Gabung Grup Komunitas</a>
    <% } %>
  </nav>

  <% if (!isGuest) { %>
    <form action="/logout" method="POST" class="drawer-logout">
      <button type="submit" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Keluar</button>
    </form>
  <% } %>
</aside>

<script>
(function () {
  var openBtn = document.getElementById('drawerOpenBtn');
  var closeBtn = document.getElementById('drawerCloseBtn');
  var overlay = document.getElementById('drawerOverlay');
  var panel = document.getElementById('drawerPanel');

  function openDrawer() {
    overlay.classList.add('show');
    panel.classList.add('show');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    overlay.classList.remove('show');
    panel.classList.remove('show');
    document.body.style.overflow = '';
  }
  if (openBtn) openBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay) overlay.addEventListener('click', closeDrawer);
})();
</script>

<!-- ===== POPUP NOTIFIKASI GRUP ===== -->
<% if (community.groupEnabled !== false && community.groupLink) { %>
<div class="group-modal-overlay" id="groupModalOverlay">
  <div class="group-modal">
    <div class="group-modal-icon"><i class="fa-solid fa-users"></i></div>
    <h3 class="group-modal-title"><%= community.groupTitle || 'Gabung Komunitas Kita!' %></h3>
    <p class="group-modal-msg"><%= community.groupMessage || 'Dapatkan info promo, update stok, dan bantuan tercepat lewat grup resmi kami.' %></p>
    <a href="<%= community.groupLink %>" target="_blank" rel="noopener" class="btn-group-cta" id="groupModalJoinBtn">
      <%= community.groupButtonText || 'Gabung Sekarang' %>
    </a>
    <button type="button" class="btn-group-later" id="groupModalLaterBtn">Nanti Saja</button>
    <label class="group-modal-check">
      <input type="checkbox" id="groupModalDontShow"> Jangan tampilkan notifikasi ini lagi
    </label>
  </div>
</div>
<script>
(function () {
  var HIDE_FOREVER_KEY = 'nx_hide_group_modal';
  var SHOWN_SESSION_KEY = 'nx_group_modal_shown';
  try {
    if (localStorage.getItem(HIDE_FOREVER_KEY) === '1') return;
    if (sessionStorage.getItem(SHOWN_SESSION_KEY) === '1') return;
  } catch (e) {}

  var overlay = document.getElementById('groupModalOverlay');
  if (!overlay) return;

  function hideModal() {
    overlay.classList.remove('show');
    document.body.style.overflow = '';
  }
  function persistIfChecked() {
    var checkbox = document.getElementById('groupModalDontShow');
    if (checkbox && checkbox.checked) {
      try { localStorage.setItem(HIDE_FOREVER_KEY, '1'); } catch (e) {}
    }
  }

  try { sessionStorage.setItem(SHOWN_SESSION_KEY, '1'); } catch (e) {}

  setTimeout(function () {
    overlay.classList.add('show');
    document.body.style.overflow = 'hidden';
  }, 400);

  var laterBtn = document.getElementById('groupModalLaterBtn');
  var joinBtn = document.getElementById('groupModalJoinBtn');
  if (laterBtn) laterBtn.addEventListener('click', function () { persistIfChecked(); hideModal(); });
  if (joinBtn) joinBtn.addEventListener('click', function () { persistIfChecked(); setTimeout(hideModal, 150); });
  overlay.addEventListener('click', function (e) { if (e.target === overlay) { persistIfChecked(); hideModal(); } });
})();
</script>
<% } %>

<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <style>
    .fs-price-now, .mono { color: var(--cyan) !important; }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/user-sidebar', { active: 'produk', user, config }) %>

  <div class="main no-bottom-nav">
    <div class="topbar" style="margin-bottom: 12px;">
      <h2 style="margin:0; font-size:20px;"><i class="fa-solid fa-bolt"></i> <%= settings.title || 'Flash Sale' %></h2>
    </div>

    <% if (items.length === 0) { %>
      <div class="card empty-state">
        <i class="fa-solid fa-bolt" style="font-size:26px; opacity:.4; display:block; margin-bottom:8px;"></i>
        Belum ada Flash Sale yang aktif saat ini. Cek lagi nanti ya!
      </div>
    <% } else { %>
      <div class="card" style="margin-bottom:16px; font-size:12px; color:var(--text-dim);">
        <i class="fa-solid fa-circle-info"></i> Harga Flash Sale <b style="color:var(--text-main);">berlaku sama untuk semua orang</b> (reguler, gold, maupun platinum) selama periode promo masih berjalan.
      </div>
      <%- include('partials/flashsale-carousel', {
        flashSaleItems: items,
        flashSaleSettings: settings,
        fsGrid: true,
        fsShowSeeAll: false
      }) %>
    <% } %>

    <%- include('partials/footer') %>
  </div>
</div>
</body>
</html>
